---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import config from '../../lib/config';

const pageTitle = "Areas We Serve";
const pageDescription = `${config.business.name} is headquartered in Tampa, FL and serves home service businesses across ${config.areas.length} Florida markets and nationwide. Local SEO, Google Ads, website design, and TV advertising.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas' },
];

const primaryArea = config.areas.find(a => a.is_primary);
const otherAreas = config.areas.filter(a => !a.is_primary);
const comboAreas = config.area_service_combos || [];
---

<Base title={pageTitle} description={pageDescription}>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />
      <h1>Based in Tampa. Serving Clients Nationwide.</h1>
      <p class="page-hero-desc">We are headquartered in Tampa, Florida, but our clients span the entire country. Our Spectrum Reach partnership covers 36 states. Our SEO and web design work has no geographic limit.</p>
    </div>
  </section>

  <section class="hq-section section">
    <div class="container hq-grid">
      <div class="hq-info">
        <span class="section-label">Headquarters</span>
        <h2>Tampa, Florida</h2>
        <p>{config.business.address.street}, {config.business.address.city}, {config.business.address.state} {config.business.address.zip}</p>
        <p class="hq-hours">{config.business.hours}</p>
        <div class="hq-actions">
          <a href={`/areas/${primaryArea?.slug}/`} class="btn btn-primary">Tampa Services</a>
          <a href={`tel:${config.business.phone_raw}`} class="btn btn-outline">{config.business.phone}</a>
        </div>
      </div>
      <div class="hq-stats">
        <div class="stat-card">
          <span class="stat-value">{config.areas.length}</span>
          <span class="stat-label">Florida Markets</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">36</span>
          <span class="stat-label">States via Spectrum Reach</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">50+</span>
          <span class="stat-label">Clients Nationwide</span>
        </div>
      </div>
    </div>
  </section>

  <section class="markets-section section">
    <div class="container">
      <h2>Florida Markets</h2>
      <p class="markets-intro">Our Florida clients get the full suite: local SEO with in-market knowledge, PPC through Spectrum Reach, website design, and TV/streaming advertising. These are the markets where we have deep local expertise.</p>
      <div class="markets-grid">
        {config.areas.map(area => (
          <a href={`/areas/${area.slug}/`} class={`market-card ${area.is_primary ? 'market-primary' : ''}`}>
            <div class="market-card-left">
              <strong>{area.name}, FL</strong>
              <span class="services-count">{config.services.length} services available</span>
            </div>
            <div class="market-card-right">
              {area.is_primary && <span class="hq-badge">HQ</span>}
              <span class="market-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="nationwide-section section section-dark">
    <div class="container nationwide-inner">
      <h2>Work With Us From Anywhere</h2>
      <p>Our local SEO, website design, and PPC services work for home service businesses in any US market. Our Spectrum Reach partnership provides first-party data targeting across 36 states and 30M+ households. Location does not limit what we can do for your business.</p>
      <a href="/contact" class="btn btn-primary btn-lg">Book a Strategy Call</a>
    </div>
  </section>

  <CTABand heading="Ready to Dominate Your Local Market?" />
  <Footer slot="footer" />
</Base>

<style>
  .page-hero { background: var(--color-dark); padding: var(--space-3xl) 0 var(--space-2xl); color: var(--color-white); }
  .page-hero h1 { color: var(--color-white); font-size: var(--text-3xl); margin-bottom: var(--space-sm); max-width: 600px; }
  .page-hero-desc { color: rgba(255, 255, 255, 0.75); font-size: var(--text-lg); max-width: 600px; }

  .section-label { display: block; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary); margin-bottom: var(--space-sm); }

  .hq-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); }
  @media (min-width: 768px) { .hq-grid { grid-template-columns: 1fr 1fr; align-items: start; } }
  .hq-info h2 { font-size: var(--text-2xl); margin-bottom: var(--space-sm); }
  .hq-info p { color: var(--color-text-light); margin-bottom: var(--space-xs); }
  .hq-hours { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-lg) !important; }
  .hq-actions { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .btn-outline { border: 2px solid var(--color-gray-300); color: var(--color-text); background: transparent; }
  .btn-outline:hover { border-color: var(--color-primary); color: var(--color-primary); }

  .hq-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
  .stat-card { text-align: center; padding: var(--space-lg); background: var(--color-gray-100); border-radius: 8px; }
  .stat-value { display: block; font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 800; color: var(--color-dark); }
  .stat-label { font-size: var(--text-xs); color: var(--color-text-light); }

  .markets-section h2 { font-size: var(--text-2xl); margin-bottom: var(--space-sm); }
  .markets-intro { color: var(--color-text-light); max-width: 700px; margin-bottom: var(--space-xl); }

  .markets-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-sm); }
  @media (min-width: 768px) { .markets-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .markets-grid { grid-template-columns: 1fr 1fr 1fr; } }
  .market-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .market-card:hover { border-color: var(--color-primary); box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-1px); }
  .market-card-left { display: flex; flex-direction: column; }
  .market-card-left strong { font-size: var(--text-sm); }
  .market-card-right { display: flex; align-items: center; gap: var(--space-sm); }
  .market-arrow { color: var(--color-gray-300); transition: color 0.15s; }
  .market-card:hover .market-arrow { color: var(--color-primary); }
  .market-primary { border-color: var(--color-primary); background: rgba(192,57,43,0.03); }
  .hq-badge { font-size: 0.6rem; font-weight: 700; background: var(--color-primary); color: var(--color-white); padding: 0.125rem 0.375rem; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.05em; }
  .services-count { font-size: var(--text-xs); color: var(--color-text-muted); white-space: nowrap; }

  .section-dark { background: var(--color-dark); color: var(--color-white); }
  .nationwide-inner { max-width: 600px; text-align: center; margin: 0 auto; }
  .nationwide-inner h2 { color: var(--color-white); font-size: var(--text-2xl); margin-bottom: var(--space-md); }
  .nationwide-inner p { color: rgba(255,255,255,0.7); margin-bottom: var(--space-xl); line-height: var(--leading-relaxed); }
</style>
