---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import config from '../../lib/config';

const pageTitle = "Areas We Serve in Central Florida";
const pageDescription = `${config.business.name} provides local SEO, Google Ads, website design, and streaming advertising to home service businesses across Central Florida. Tampa, Orlando, St. Petersburg, and 17 more markets.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas' },
];
---

<Base title={pageTitle} description={pageDescription}>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />
      <h1>{pageTitle}</h1>
      <p class="page-hero-desc">Based in Tampa, serving home service businesses across {config.areas.length} Central Florida markets. We also work with clients nationwide.</p>
    </div>
  </section>

  <section class="areas-section section">
    <div class="container">
      <div class="areas-grid">
        {config.areas.map(area => (
          <a href={`/areas/${area.slug}/`} class="area-card card">
            <div class="area-card-body">
              <h2>{area.name}</h2>
              <p>{area.is_primary ? 'Headquarters' : `${config.business.address.state_full}`}</p>
              {config.area_service_combos.includes(area.slug) && (
                <div class="area-services-mini">
                  {config.services.map(svc => (
                    <span class="micro-badge">{svc.name}</span>
                  ))}
                </div>
              )}
              <span class="card-link">View {area.name} &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand heading="Don't See Your City? We Work Nationwide." />
  <Footer slot="footer" />
</Base>

<style>
  .page-hero { background: var(--color-dark); padding: var(--space-3xl) 0 var(--space-2xl); color: var(--color-white); }
  .page-hero h1 { color: var(--color-white); font-size: var(--text-4xl); margin-bottom: var(--space-sm); }
  .page-hero-desc { color: rgba(255, 255, 255, 0.75); font-size: var(--text-lg); max-width: 600px; }

  .areas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-lg); }
  .area-card { text-decoration: none; color: inherit; transition: transform var(--transition-fast), box-shadow var(--transition-fast); }
  .area-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .area-card-body { padding: var(--space-lg); }
  .area-card-body h2 { font-size: var(--text-xl); margin-bottom: 0.25rem; }
  .area-card-body p { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-md); }
  .area-services-mini { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-bottom: var(--space-md); }
  .micro-badge { font-size: 0.6875rem; padding: 0.125rem 0.5rem; background: var(--color-gray-100); border-radius: 999px; color: var(--color-text-light); }
  .card-link { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }
</style>
