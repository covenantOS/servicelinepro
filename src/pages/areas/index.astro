---
import Base from '../../layouts/Base.astro';
import config from '../../lib/config';

const areas = config.areas;
const primary = areas.filter(a => a.is_primary);
const others = areas.filter(a => !a.is_primary);
---

<Base title="Service Areas" description={`ServiceLine Pro serves businesses across Florida including ${areas.slice(0, 5).map(a => a.name).join(', ')}, and more.`}>

<section class="section" style="padding-top: 5rem;">
  <div class="container">
    <div class="fade-in" style="text-align: center; margin-bottom: 3.5rem;">
      <span class="section-label">Where We Work</span>
      <h1>Service Areas</h1>
      <p class="section-subtitle" style="margin: 1rem auto 0;">We serve businesses across Florida and nationwide through our digital marketing services and Spectrum Reach partnership.</p>
    </div>

    <div class="areas-grid stagger">
      {areas.map(area => (
        <a href={`/areas/${area.slug}/`} class="area-card fade-in" style="text-decoration: none;">
          <h3 class="area-card__name">{area.name}</h3>
          <span class="area-card__state">{area.slug.split('-').pop()?.toUpperCase()}</span>
          {area.is_primary && <span class="badge" style="font-size: 0.65rem; padding: 0.2rem 0.5rem;">HQ</span>}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left: auto; color: var(--gray-600); transition: all 0.2s;"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Don't See Your Area?</h2>
    <p style="margin-bottom: 2rem;">Our digital marketing services work nationwide. Let's talk about growing your business.</p>
    <a href="/contact/" class="btn btn--primary btn--lg">Get Your Free Strategy Call</a>
  </div>
</section>

</Base>

<style>
.areas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 0.75rem;
}
.area-card {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.25rem;
  background: #f8f9fa;
  border: 1px solid #e5e7eb;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}
.area-card:hover {
  border-color: var(--gray-600);
  transform: translateX(4px);
}
.area-card:hover svg { color: var(--red-light); transform: translateX(4px); }
.area-card__name {
  font-size: 1rem;
  color: #1a1a1a;
}
.area-card__state {
  font-size: 0.75rem;
  color: #888888;
  font-weight: 600;
}
</style>
