---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import config from '../../lib/config';
import { renderMarkdown } from '../../lib/markdown';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  const paths: any[] = [];

  for (const area of config.areas) {
    // Main area page: /areas/tampa-fl/
    paths.push({
      params: { slug: area.slug },
      props: { area, type: 'area' },
    });
  }

  // Area-service combos for top areas: /areas/tampa-fl/local-seo/
  for (const areaSlug of config.area_service_combos) {
    const area = config.areas.find(a => a.slug === areaSlug);
    if (!area) continue;
    for (const service of config.services) {
      paths.push({
        params: { slug: `${area.slug}/${service.slug}` },
        props: { area, service, type: 'area-service' },
      });
    }
  }

  return paths;
}

const { area, service, type } = Astro.props;

let content = '';
let frontmatter: any = {};

function loadContent(dir: string, slug: string) {
  const filePath = path.resolve(`./src/content/${dir}/${slug}.md`);
  if (fs.existsSync(filePath)) {
    const raw = fs.readFileSync(filePath, 'utf8');
    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    if (fmMatch) {
      frontmatter = YAML.parse(fmMatch[1]);
      content = fmMatch[2];
    } else {
      content = raw;
    }
  }
}

if (type === 'area') {
  loadContent('areas', area.slug);
} else if (type === 'area-service' && service) {
  loadContent('area-services', `${area.slug}-${service.slug}`);
}

const isCombo = type === 'area-service' && service;

const pageTitle = isCombo
  ? frontmatter.title || `${service.name} in ${area.name}, ${config.business.address.state_full}`
  : frontmatter.title || `Digital Marketing Agency in ${area.name}, ${config.business.address.state_full}`;

const pageDescription = isCombo
  ? frontmatter.description || `${service.name} services in ${area.name}, FL. ${config.business.name} delivers results-driven ${service.name.toLowerCase()} for home service businesses.`
  : frontmatter.description || `${config.business.name} provides local SEO, Google Ads, website design, and TV advertising for home service businesses in ${area.name}, ${config.business.address.state_full}.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas', href: '/areas/' },
];

if (isCombo) {
  breadcrumbItems.push({ label: area.name, href: `/areas/${area.slug}/` });
  breadcrumbItems.push({ label: service.name });
} else {
  breadcrumbItems.push({ label: area.name });
}

const schemaType = area.is_primary ? 'LocalBusiness' : 'ProfessionalService';

const schema = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: config.business.name,
  description: pageDescription,
  url: `https://${config.seo.domain}/areas/${area.slug}/`,
  ...(area.is_primary && config.business.geo ? {
    geo: {
      '@type': 'GeoCoordinates',
      latitude: config.business.geo.latitude,
      longitude: config.business.geo.longitude,
    },
    address: {
      '@type': 'PostalAddress',
      streetAddress: config.business.address.street,
      addressLocality: config.business.address.city,
      addressRegion: config.business.address.state,
      postalCode: config.business.address.zip,
    },
  } : {}),
};

const faqQuestions = frontmatter.faq || [];
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <section class="area-hero">
    <div class="container area-hero-inner">
      <Breadcrumbs items={breadcrumbItems} />
      <div class="area-badge">{area.name}, {config.business.address.state_full}</div>
      <h1>{pageTitle}</h1>
      <p class="area-hero-desc">{isCombo ? service.short_description : `Full-service marketing agency helping home service businesses in ${area.name} dominate local search, run profitable ad campaigns, and build websites that convert.`}</p>
      <div class="area-hero-ctas">
        <a href="/contact" class="btn btn-primary">Free Strategy Call</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn-outline">{config.business.phone}</a>
      </div>
    </div>
  </section>

  <section class="area-content section">
    <div class="container content-layout">
      <div class="main-content">
        {content ? (
          <div class="prose" set:html={renderMarkdown(content)} />
        ) : (
          <div class="prose">
            <h2>{isCombo ? `${service.name} for ${area.name} Home Service Businesses` : `Home Service Marketing in ${area.name}`}</h2>
            <p>{config.business.name} works with home service companies in {area.name} and across Central Florida. Whether you need local SEO to dominate the Map Pack, Google Ads to fill your calendar, or a website that turns visitors into booked jobs, we build marketing that actually performs.</p>
          </div>
        )}

        {!isCombo && (
          <div class="area-services">
            <h2>Our Services in {area.name}</h2>
            <div class="area-services-grid">
              {config.services.map(svc => {
                const hasCombo = config.area_service_combos.includes(area.slug);
                const href = hasCombo ? `/areas/${area.slug}/${svc.slug}/` : `/services/${svc.slug}/`;
                return (
                  <a href={href} class="area-service-card card">
                    <div class="area-service-body">
                      <h3>{svc.name}</h3>
                      <p>{svc.short_description}</p>
                      <span class="card-link">Learn More &rarr;</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {faqQuestions.length > 0 && (
          <div class="faq-section">
            <h2>FAQ</h2>
            {faqQuestions.map((q: any) => (
              <details class="faq-item">
                <summary>{q.question}</summary>
                <div class="faq-answer" set:html={renderMarkdown(q.answer)} />
              </details>
            ))}
          </div>
        )}

        {!isCombo && (
          <div class="nearby-areas">
            <h2>Nearby Areas We Serve</h2>
            <div class="nearby-grid">
              {config.areas.filter(a => a.slug !== area.slug).map(a => (
                <a href={`/areas/${a.slug}/`} class="nearby-link">{a.name}</a>
              ))}
            </div>
          </div>
        )}
      </div>

      <aside class="sidebar">
        <div class="sidebar-card">
          <h3>Areas We Serve</h3>
          <ul class="sidebar-nav">
            {config.areas.map(a => (
              <li class={a.slug === area.slug ? 'active' : ''}>
                <a href={`/areas/${a.slug}/`}>{a.name}</a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-cta">
          <h3>Grow Your Business in {area.name}</h3>
          <p>Free strategy call. No pressure. Just straight answers about what will work in your market.</p>
          <a href="/contact" class="btn btn-primary btn-block">Book Now</a>
        </div>
      </aside>
    </div>
  </section>

  <CTABand heading={`Dominate ${area.name} Search Results`} />
  <ReviewsSection compact={true} maxReviews={3} />
  <Footer slot="footer" />
</Base>

<style>
  .area-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
  }

  .area-badge {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-white);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .area-hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
    max-width: 700px;
  }

  .area-hero-desc {
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--text-base);
    max-width: 600px;
    margin-bottom: var(--space-lg);
    line-height: var(--leading-relaxed);
  }

  .area-hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .area-hero .btn-outline {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 1024px) {
    .content-layout {
      grid-template-columns: 1fr 300px;
    }
  }

  .area-services { margin-top: var(--space-2xl); }

  .area-services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .area-service-card {
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .area-service-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .area-service-body {
    padding: var(--space-lg);
  }

  .area-service-body h3 { font-size: var(--text-lg); margin-bottom: var(--space-sm); }
  .area-service-body p { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-sm); }
  .card-link { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }

  .nearby-areas { margin-top: var(--space-2xl); }
  .nearby-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .nearby-link {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-gray-100);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .nearby-link:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .sidebar-card { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-md); padding: var(--space-lg); }
  .sidebar-card h3 { font-size: var(--text-base); margin-bottom: var(--space-md); }
  .sidebar-nav { list-style: none; padding: 0; margin: 0; max-height: 400px; overflow-y: auto; }
  .sidebar-nav li a { display: block; padding: 0.375rem 0.5rem; font-size: var(--text-sm); color: var(--color-text-light); border-radius: var(--radius-sm); transition: background var(--transition-fast); }
  .sidebar-nav li a:hover, .sidebar-nav li.active a { background: var(--color-gray-100); color: var(--color-primary); font-weight: 600; }
  .sidebar-cta { background: var(--color-dark); color: var(--color-white); border: none; }
  .sidebar-cta h3 { color: var(--color-white); }
  .sidebar-cta p { color: rgba(255, 255, 255, 0.7); margin-bottom: var(--space-md); }
  .btn-block { display: block; text-align: center; width: 100%; }
  .faq-section { margin-top: var(--space-2xl); }
  .faq-item { border-bottom: 1px solid var(--color-gray-200); padding: var(--space-md) 0; }
  .faq-item summary { font-weight: 600; cursor: pointer; }
  .faq-answer { padding-top: var(--space-sm); color: var(--color-text-light); }
</style>
