---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import config from '../lib/config';
---

<Base title="Privacy Policy" description={`Privacy policy for ${config.business.name}. Learn how we collect, use, and protect your information.`} noindex={true}>
  <Header slot="header" />

  <section class="policy-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Privacy Policy' }]} />
      <h1>Privacy Policy</h1>
    </div>
  </section>

  <section class="policy-content section">
    <div class="container policy-body">
      <p><strong>Effective Date:</strong> January 1, {config.business.founded_year}</p>
      <p>{config.business.legal_name} ("we," "us," or "our") operates the website https://{config.seo.domain}. This page informs you of our policies regarding the collection, use, and disclosure of personal information when you use our website.</p>

      <h2>Information We Collect</h2>
      <p>When you fill out a contact form on our website, we collect the following information: your name, phone number, email address, and details about your project inquiry. This information is submitted voluntarily and is used solely to respond to your request for an estimate or information about our services.</p>

      <h2>How We Use Your Information</h2>
      <p>We use the information you provide to respond to your inquiry, provide estimates, communicate about potential projects, and improve our services. We do not sell, trade, or rent your personal information to third parties.</p>

      <h2>Third-Party Services</h2>
      <p>Our contact form submissions may be processed through third-party services (such as Zapier) to facilitate our response. These services are bound by their own privacy policies and are used solely to deliver your message to our team.</p>

      <h2>Cookies</h2>
      <p>This website does not use tracking cookies or analytics that collect personal information. As a static website, we do not store session data or user preferences on your device.</p>

      <h2>Contact Us</h2>
      <p>If you have questions about this privacy policy, contact us at:</p>
      <p>{config.business.legal_name}<br />
      {config.business.address.street}, {config.business.address.city}, {config.business.address.state} {config.business.address.zip}<br />
      <a href={`tel:${config.business.phone_raw}`}>{config.business.phone}</a><br />
      <a href={`mailto:${config.business.email}`}>{config.business.email}</a></p>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .policy-hero {
    background: var(--color-dark);
    color: var(--color-white);
    padding: var(--space-3xl) 0 var(--space-2xl);
  }
  .policy-hero h1 { color: var(--color-white); margin-top: var(--space-sm); }
  .policy-hero :global(.breadcrumbs a), .policy-hero :global(.breadcrumbs span), .policy-hero :global(.breadcrumbs li) { color: rgba(255,255,255,0.7); }

  .policy-body {
    max-width: 720px;
  }
  .policy-body h2 {
    font-size: var(--text-xl);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-sm);
  }
  .policy-body p {
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
  }
</style>
