---
import Base from '../layouts/Base.astro';
import config from '../lib/config';

const team = config.business.team || [];
const teamImages: Record<string, string> = {
  'William Hamilton': '/media/team-will-opt.webp',
  'Victoria Hamilton': '/media/team-member-2-opt.webp',
  'Daniel Gomez': '/media/team-member-3-opt.webp',
  'Kevin Morales': '/media/team-member-4-opt.webp',
};
---

<Base title="About Us" description={`Meet the team behind ${config.business.name}. A performance-first marketing agency based in Tampa, Florida.`}>

<section class="section" style="padding-top: 5rem;">
  <div class="container">
    <div class="about-hero fade-in">
      <div class="about-hero__text">
        <span class="section-label">About Us</span>
        <h1>Built Different.<br/><span class="gradient-text--red">On Purpose.</span></h1>
        <p style="color: var(--gray-400); font-size: 1.05rem; line-height: 1.7; margin-top: 1.25rem;">
          ServiceLine Pro started in 2020 as Paradigm — a small agency with one mission: prove that marketing should generate measurable revenue, not just impressions. We rebranded to focus exclusively on what we do best — helping businesses dominate their local markets.
        </p>
        <p style="color: var(--gray-400); font-size: 1.05rem; line-height: 1.7; margin-top: 1rem;">
          Today, we're a full-service performance marketing agency based in Tampa, Florida. Our clients span industries from HVAC to legal, plumbing to real estate — and every one of them shares the same experience: real results, delivered fast, with complete transparency.
        </p>
      </div>
      <div class="about-hero__img hide-mobile">
        <img src="/media/live-team-photo.webp" alt="ServiceLine Pro team" width="480" height="360" loading="eager" style="border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);" />
      </div>
    </div>
  </div>
</section>

<!-- Values -->
<section class="section bg-dark">
  <div class="container">
    <div class="fade-in" style="text-align: center; margin-bottom: 3rem;">
      <span class="section-label">What Drives Us</span>
      <h2>Our Core Values</h2>
    </div>
    <div class="grid grid--3 stagger">
      <div class="card fade-in" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">📊</div>
        <h3 style="font-size: 1.15rem; margin-bottom: 0.5rem;">Results Over Vanity</h3>
        <p style="color: var(--gray-400); font-size: 0.9rem;">We measure success in revenue generated, leads booked, and phones ringing — not impressions or clicks.</p>
      </div>
      <div class="card fade-in" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">🤝</div>
        <h3 style="font-size: 1.15rem; margin-bottom: 0.5rem;">Radical Transparency</h3>
        <p style="color: var(--gray-400); font-size: 0.9rem;">No hidden fees, no black-box strategies. You see every dollar spent, every metric tracked, every decision made.</p>
      </div>
      <div class="card fade-in" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">🚀</div>
        <h3 style="font-size: 1.15rem; margin-bottom: 0.5rem;">Speed to Impact</h3>
        <p style="color: var(--gray-400); font-size: 0.9rem;">Our Local SEO clients see ranking movement in days, not months. We move fast because your revenue depends on it.</p>
      </div>
    </div>
  </div>
</section>

<!-- Team -->
<section class="section">
  <div class="container">
    <div class="fade-in" style="text-align: center; margin-bottom: 3rem;">
      <span class="section-label">The Team</span>
      <h2>Meet the People Behind the Results</h2>
    </div>
    <div class="team-grid stagger">
      {team.map(member => (
        <div class="team-card fade-in">
          {teamImages[member.name] ? (
            <img src={teamImages[member.name]} alt={member.name} width="280" height="280" loading="lazy" class="team-card__img" />
          ) : (
            <div class="team-card__placeholder">
              <span>{member.name.split(' ').map(n => n[0]).join('')}</span>
            </div>
          )}
          <h3 class="team-card__name">{member.name}</h3>
          <p class="team-card__role">{member.role}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Spectrum Partnership -->
<section class="section bg-dark">
  <div class="container">
    <div class="spectrum-row fade-in">
      <div>
        <span class="section-label">Strategic Partnership</span>
        <h2 style="margin-bottom: 1rem;">Spectrum Reach Certified Partner</h2>
        <p style="color: var(--gray-400); font-size: 1rem; line-height: 1.7;">
          Our partnership with Spectrum Reach — the advertising arm of Charter Communications — gives our clients access to first-party data from 30M+ households across 48 states. This means precision-targeted ad campaigns on Google, Bing, Yahoo, streaming platforms, and traditional TV — all with zero agency fees on qualifying budgets.
        </p>
        <div style="display: flex; gap: 2rem; margin-top: 1.5rem; flex-wrap: wrap;">
          <div>
            <span class="stat-number" style="font-size: 2rem;">30M+</span>
            <span class="stat-label">Households</span>
          </div>
          <div>
            <span class="stat-number" style="font-size: 2rem;">48</span>
            <span class="stat-label">States</span>
          </div>
          <div>
            <span class="stat-number" style="font-size: 2rem;">$0</span>
            <span class="stat-label">Agency Fee</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Let's Build Something Together</h2>
    <p style="margin-bottom: 2rem; font-size: 1.05rem;">We're always looking for businesses ready to grow. Let's talk about what that looks like for you.</p>
    <a href="/contact/" class="btn btn--primary btn--lg">Get Your Free Strategy Call</a>
  </div>
</section>

</Base>

<style>
.about-hero {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 3rem;
  align-items: center;
}
@media (max-width: 1024px) {
  .about-hero { grid-template-columns: 1fr; }
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1.5rem;
}
.team-card {
  text-align: center;
}
.team-card__img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  border-radius: var(--radius-md);
  margin-bottom: 1rem;
  background: var(--dark-2);
}
.team-card__placeholder {
  width: 100%;
  aspect-ratio: 1;
  background: var(--dark-2);
  border: 1px solid var(--dark-4);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
}
.team-card__placeholder span {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  color: var(--gray-600);
}
.team-card__name {
  font-size: 1rem;
  margin-bottom: 0.15rem;
}
.team-card__role {
  font-size: 0.8rem;
  color: var(--gray-500);
}

.spectrum-row {
  background: linear-gradient(135deg, rgba(192,57,43,0.06), transparent);
  border: 1px solid rgba(192,57,43,0.15);
  border-radius: var(--radius-lg);
  padding: var(--space-3xl);
}
</style>
