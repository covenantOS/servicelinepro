---
import Base from '../../layouts/Base.astro';
import config from '../../lib/config';

export function getStaticPaths() {
  return config.case_studies.map(cs => ({
    params: { slug: cs.slug },
    props: { caseStudy: cs },
  }));
}

const { caseStudy } = Astro.props;
const related = config.case_studies.filter(cs => cs.category === caseStudy.category && cs.slug !== caseStudy.slug).slice(0, 3);
---

<Base title={`${caseStudy.title} — Case Study`} description={`See how ${caseStudy.title} achieved ${caseStudy.result} with ServiceLine Pro's ${caseStudy.category} services.`}>

<section class="section" style="padding-top: 5rem;">
  <div class="container container--narrow">
    <a href="/case-studies/" class="back-link fade-in">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      All Case Studies
    </a>

    <div class="fade-in" style="margin-top: 1.5rem;">
      <div style="display: flex; gap: 0.75rem; align-items: center; margin-bottom: 1rem;">
        <span class="badge">{caseStudy.category}</span>
        {caseStudy.industry && <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--gray-400); border-color: var(--dark-4);">{caseStudy.industry}</span>}
        {caseStudy.location && <span style="font-size: 0.85rem; color: var(--gray-500);">{caseStudy.location}</span>}
      </div>
      <h1 style="margin-bottom: 1.5rem;">{caseStudy.title}</h1>
    </div>

    {caseStudy.image && (
      <img src={`/media/case-studies/${caseStudy.image}`} alt={caseStudy.title} width="800" height="450" loading="eager" class="cs-hero-img fade-in" />
    )}

    <!-- Metrics -->
    <div class="cs-metrics fade-in">
      {caseStudy.metrics?.primary && (
        <div class="cs-metric">
          <span class="cs-metric__value">{caseStudy.metrics.primary}</span>
          <span class="cs-metric__label">Primary Result</span>
        </div>
      )}
      {caseStudy.metrics?.secondary && (
        <div class="cs-metric">
          <span class="cs-metric__value">{caseStudy.metrics.secondary}</span>
          <span class="cs-metric__label">Secondary Result</span>
        </div>
      )}
    </div>

    <div class="cs-body fade-in">
      <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">The Results</h2>
      <p style="color: var(--gray-300); line-height: 1.7; margin-bottom: 1.5rem;">
        {caseStudy.title} came to ServiceLine Pro looking for measurable growth through {caseStudy.category.toLowerCase()} services.
        Our team developed and executed a custom strategy that delivered <strong style="color: var(--white);">{caseStudy.result}</strong>.
      </p>

      <div style="background: var(--dark-2); border: 1px solid var(--dark-4); border-radius: var(--radius-md); padding: 1.5rem; margin-bottom: 2rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">Want results like these?</h3>
        <p style="color: var(--gray-400); font-size: 0.9rem; margin-bottom: 1rem;">Every campaign we run is custom-built for your market, your audience, and your goals.</p>
        <a href="/contact/" class="btn btn--primary">Get Your Free Strategy Call</a>
      </div>
    </div>
  </div>
</section>

{related.length > 0 && (
  <section class="section bg-dark">
    <div class="container">
      <h2 style="margin-bottom: 2rem;">More {caseStudy.category} Results</h2>
      <div class="grid grid--3 stagger">
        {related.map(cs => (
          <a href={`/case-studies/${cs.slug}/`} class="case-card" style="text-decoration: none;">
            {cs.image && <img src={`/media/case-studies/${cs.image}`} alt={cs.title} width="400" height="250" loading="lazy" class="case-card__img" />}
            <div class="case-card__body">
              <span class="case-card__category">{cs.category}</span>
              <h4 class="case-card__title">{cs.title}</h4>
              <div class="case-card__metric">
                <span class="case-card__metric-value">{cs.metrics?.primary || cs.result}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Ready for Your Success Story?</h2>
    <p style="margin-bottom: 2rem;">Let us show you what's possible for your business.</p>
    <a href="/contact/" class="btn btn--lime btn--lg">Get Your Free Strategy Call</a>
  </div>
</section>

</Base>

<style>
.back-link {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.85rem;
  color: var(--gray-500);
  text-decoration: none;
  transition: color var(--transition-fast);
}
.back-link:hover { color: var(--white); }

.cs-hero-img {
  width: 100%;
  border-radius: var(--radius-lg);
  margin: 2rem 0;
  box-shadow: var(--shadow-lg);
}

.cs-metrics {
  display: flex;
  gap: 2rem;
  margin-bottom: 2.5rem;
  padding: 1.5rem;
  background: var(--dark-2);
  border: 1px solid var(--dark-4);
  border-radius: var(--radius-md);
}
.cs-metric {
  display: flex;
  flex-direction: column;
}
.cs-metric__value {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 1.75rem;
  color: var(--red-light);
  line-height: 1.2;
}
.cs-metric__label {
  font-size: 0.8rem;
  color: var(--gray-500);
  margin-top: 0.15rem;
}

.case-card {
  display: flex; flex-direction: column; background: var(--dark-2);
  border: 1px solid var(--dark-4); border-radius: var(--radius-md); overflow: hidden;
  transition: all var(--transition-med);
}
.case-card:hover { border-color: var(--gray-700); transform: translateY(-4px); box-shadow: var(--shadow-md); }
.case-card__img { width: 100%; height: 180px; object-fit: cover; }
.case-card__body { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
.case-card__category { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--lime); }
.case-card__title { font-size: 1rem; color: var(--white); line-height: 1.3; }
.case-card__metric { margin-top: auto; padding-top: 0.75rem; border-top: 1px solid var(--dark-4); }
.case-card__metric-value { font-family: var(--font-heading); font-weight: 700; font-size: 0.95rem; color: var(--red-light); }
</style>
