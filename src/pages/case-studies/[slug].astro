---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Sidebar from '../../components/Sidebar.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import config from '../../lib/config';
import { renderMarkdown } from '../../lib/markdown';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  return config.case_studies.map(cs => ({
    params: { slug: cs.slug },
    props: { caseStudy: cs },
  }));
}

const { caseStudy } = Astro.props;

let content = '';
let frontmatter: any = {};

const filePath = path.resolve(`./src/content/case-studies/${caseStudy.slug}.md`);
if (fs.existsSync(filePath)) {
  const raw = fs.readFileSync(filePath, 'utf8');
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (fmMatch) {
    frontmatter = YAML.parse(fmMatch[1]);
    content = fmMatch[2];
  } else {
    content = raw;
  }
}

const pageTitle = frontmatter.title || `${caseStudy.title} Case Study`;
const pageDescription = frontmatter.description || `See how ${caseStudy.title} achieved ${caseStudy.result} with ServiceLine Pro's ${caseStudy.category} services.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Results', href: '/case-studies/' },
  { label: caseStudy.title },
];

// Find related case studies (same category, exclude self)
const relatedStudies = config.case_studies
  .filter(cs => cs.category === caseStudy.category && cs.slug !== caseStudy.slug)
  .slice(0, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDescription,
  author: {
    '@type': 'Organization',
    name: config.business.name,
  },
  publisher: {
    '@type': 'Organization',
    name: config.business.name,
    url: `https://${config.seo.domain}`,
  },
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <section class="cs-hero">
    <div class="cs-hero-bg"></div>
    <div class="container cs-hero-inner">
      <Breadcrumbs items={breadcrumbItems} />
      <div class="cs-hero-tags">
        <span class="cs-badge">{caseStudy.category}</span>
        {caseStudy.industry && <span class="cs-badge cs-badge-industry">{caseStudy.industry}</span>}
        {caseStudy.location && <span class="cs-badge cs-badge-location">{caseStudy.location}</span>}
      </div>
      <h1>{pageTitle}</h1>
      <p class="cs-hero-desc">{pageDescription}</p>

      <!-- Results Strip -->
      <div class="cs-results-strip">
        <div class="cs-result-item cs-result-primary">
          <span class="cs-result-value">{caseStudy.metrics?.primary || caseStudy.result}</span>
          <span class="cs-result-label">Primary Result</span>
        </div>
        {caseStudy.metrics?.secondary && (
          <div class="cs-result-item">
            <span class="cs-result-value">{caseStudy.metrics.secondary}</span>
            <span class="cs-result-label">Secondary Result</span>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="cs-content section">
    <div class="container content-layout">
      <div class="main-content">
        {content ? (
          <div class="prose" set:html={renderMarkdown(content)} />
        ) : (
          <div class="prose">
            <h2>About This Campaign</h2>
            <p>ServiceLine Pro partnered with {caseStudy.title} to deliver measurable results through our {caseStudy.category} services. The campaign achieved {caseStudy.result}, demonstrating the power of targeted digital marketing for {caseStudy.industry?.toLowerCase() || 'local'} businesses.</p>
            <p>Want to see results like these for your business? <a href="/contact">Book a free strategy call</a> and we'll show you exactly what we can do.</p>
          </div>
        )}

        <!-- Related Case Studies -->
        {relatedStudies.length > 0 && (
          <div class="related-studies">
            <h2>More {caseStudy.category} Results</h2>
            <div class="related-grid">
              {relatedStudies.map(cs => (
                <a href={`/case-studies/${cs.slug}/`} class="related-card">
                  <span class="related-category">{cs.category}</span>
                  <h3>{cs.metrics?.primary || cs.result}</h3>
                  <span class="related-client">{cs.title}</span>
                  <span class="card-link">Read Case Study &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <Sidebar currentService={caseStudy.category === 'Local SEO' ? 'local-seo' : caseStudy.category === 'Google Ads' ? 'google-ads-ppc' : caseStudy.category === 'Website Design' ? 'website-design' : undefined} />
    </div>
  </section>

  <CTABand heading={`Want ${caseStudy.result} for Your Business?`} />
  <Footer slot="footer" />
</Base>

<style>
  .cs-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .cs-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 15% 85%, rgba(192,57,43,0.12) 0%, transparent 45%),
      radial-gradient(circle at 85% 15%, rgba(59,130,246,0.06) 0%, transparent 35%);
    pointer-events: none;
  }
  .cs-hero-inner { position: relative; z-index: 1; }

  .cs-hero-tags { display: flex; gap: 0.5rem; margin-bottom: var(--space-md); flex-wrap: wrap; }
  .cs-badge {
    display: inline-block;
    background: rgba(192,57,43,0.15);
    color: var(--color-primary);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid rgba(192,57,43,0.2);
  }
  .cs-badge-industry {
    background: rgba(59,130,246,0.12);
    color: #60a5fa;
    border-color: rgba(59,130,246,0.2);
  }
  .cs-badge-location {
    background: rgba(34,197,94,0.12);
    color: #4ade80;
    border-color: rgba(34,197,94,0.2);
  }

  .cs-hero h1 {
    color: var(--color-white);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
    max-width: 700px;
  }
  .cs-hero-desc {
    color: rgba(255,255,255,0.7);
    font-size: var(--text-lg);
    max-width: 600px;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  .cs-results-strip {
    display: flex;
    gap: var(--space-xl);
    padding: var(--space-lg) var(--space-xl);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    max-width: 500px;
  }
  .cs-result-item { display: flex; flex-direction: column; }
  .cs-result-value {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.2;
  }
  .cs-result-primary .cs-result-value { color: var(--color-primary); font-size: var(--text-2xl); }
  .cs-result-label { font-size: 0.7rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }
  @media (min-width: 1024px) {
    .content-layout {
      grid-template-columns: 1fr 300px;
    }
  }

  .related-studies { margin-top: var(--space-3xl); }
  .related-studies h2 { margin-bottom: var(--space-lg); }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-lg); }
  .related-card {
    display: block;
    padding: var(--space-lg);
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .related-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .related-category { display: inline-block; font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); margin-bottom: var(--space-sm); }
  .related-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-xs); }
  .related-client { display: block; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-sm); }
  .card-link { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }
</style>
