---
import Base from '../../layouts/Base.astro';
import config from '../../lib/config';

const caseStudies = config.case_studies;
const categories = [...new Set(caseStudies.map(cs => cs.category))];
---

<Base title="Case Studies" description="Real results from real clients. See how ServiceLine Pro delivers measurable ROI through SEO, PPC, web design, and reputation management.">

<section class="section" style="padding-top: 5rem;">
  <div class="container">
    <div class="fade-in" style="text-align: center; margin-bottom: 3.5rem;">
      <span class="section-label">Case Studies</span>
      <h1>Real Clients. <span class="gradient-text--red">Real Results.</span></h1>
      <p class="section-subtitle" style="margin: 1rem auto 0;">Every number below is verified from real campaigns. No hypotheticals. No projections. Just proven outcomes.</p>
    </div>

    <!-- Filter Tabs -->
    <div class="filter-tabs fade-in" id="filter-tabs">
      <button class="filter-tab is-active" data-filter="all">All</button>
      {categories.map(cat => (
        <button class="filter-tab" data-filter={cat}>{cat}</button>
      ))}
    </div>

    <div class="cs-grid stagger" id="cs-grid">
      {caseStudies.map(cs => (
        <a href={`/case-studies/${cs.slug}/`} class="case-card" data-category={cs.category} style="text-decoration: none;">
          {cs.image && <img src={`/media/case-studies/${cs.image}`} alt={cs.title} width="400" height="250" loading="lazy" class="case-card__img" />}
          <div class="case-card__body">
            <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
              <span class="case-card__category">{cs.category}</span>
              {cs.industry && <span style="font-size: 0.7rem; color: var(--gray-600);">/ {cs.industry}</span>}
            </div>
            <h3 class="case-card__title">{cs.title}</h3>
            {cs.location && <p style="font-size: 0.8rem; color: var(--gray-500); margin-top: 0.25rem;">{cs.location}</p>}
            <div class="case-card__metric">
              <span class="case-card__metric-value">{cs.metrics?.primary || cs.result}</span>
              {cs.metrics?.secondary && <span style="font-size: 0.8rem; color: var(--gray-500); display: block; margin-top: 0.15rem;">{cs.metrics.secondary}</span>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Want Results Like These?</h2>
    <p style="margin-bottom: 2rem; font-size: 1.05rem;">We'll analyze your market and show you exactly what's possible. Free, no obligation.</p>
    <a href="/contact/" class="btn btn--lime btn--lg">Get Your Free Strategy Call</a>
  </div>
</section>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  const tabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('#cs-grid .case-card');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      const filter = tab.dataset.filter;
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
});
</script>

</Base>

<style>
.filter-tabs {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 2.5rem;
}
.filter-tab {
  padding: 0.5rem 1.25rem;
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  border: 1px solid var(--dark-4);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--gray-400);
  cursor: pointer;
  transition: all var(--transition-fast);
}
.filter-tab:hover { border-color: var(--gray-600); color: var(--white); }
.filter-tab.is-active {
  background: var(--red);
  border-color: var(--red);
  color: var(--white);
}

.cs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}
.case-card {
  display: flex;
  flex-direction: column;
  background: var(--dark-2);
  border: 1px solid var(--dark-4);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: all var(--transition-med);
}
.case-card:hover {
  border-color: var(--gray-700);
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}
.case-card__img { width: 100%; height: 180px; object-fit: cover; }
.case-card__body { padding: 1.25rem; display: flex; flex-direction: column; flex: 1; }
.case-card__category {
  font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--lime);
}
.case-card__title { font-size: 1rem; color: var(--white); line-height: 1.3; }
.case-card__metric { margin-top: auto; padding-top: 0.75rem; border-top: 1px solid var(--dark-4); }
.case-card__metric-value {
  font-family: var(--font-heading); font-weight: 700; font-size: 0.95rem; color: var(--red-light);
}
</style>
