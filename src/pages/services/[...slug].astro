---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import LeadMagnet from '../../components/LeadMagnet.astro';
import config from '../../lib/config';
import { renderMarkdown } from '../../lib/markdown';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  const paths: any[] = [];

  for (const service of config.services) {
    // Main service page: /services/local-seo/
    paths.push({
      params: { slug: service.slug },
      props: { service, type: 'service' },
    });

    // Sub-service pages: /services/ppc/google-ads/
    if (service.sub_services) {
      for (const sub of service.sub_services) {
        paths.push({
          params: { slug: `${service.slug}/${sub.slug}` },
          props: { service, subService: sub, type: 'sub-service' },
        });
      }
    }
  }

  return paths;
}

const { service, subService, type } = Astro.props;

let content = '';
let frontmatter: any = {};

function loadContent(dir: string, slug: string) {
  const filePath = path.resolve(`./src/content/${dir}/${slug}.md`);
  if (fs.existsSync(filePath)) {
    const raw = fs.readFileSync(filePath, 'utf8');
    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    if (fmMatch) {
      frontmatter = YAML.parse(fmMatch[1]);
      content = fmMatch[2];
    } else {
      content = raw;
    }
  }
}

if (type === 'sub-service' && subService) {
  loadContent('services', `${service.slug}-${subService.slug}`);
  if (!content) loadContent('services', subService.slug);
} else {
  loadContent('services', service.slug);
}

const displayName = type === 'sub-service' && subService ? subService.name : service.name;
const displayDesc = type === 'sub-service' && subService ? (subService.short_description || service.short_description) : service.short_description;

const pageTitle = frontmatter.title || `${displayName} for Home Service Businesses`;
const pageDescription = frontmatter.description || `${displayDesc} ${config.business.name} delivers performance-driven results.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
];

if (type === 'sub-service' && subService) {
  breadcrumbItems.push({ label: service.name, href: `/services/${service.slug}/` });
  breadcrumbItems.push({ label: subService.name });
} else {
  breadcrumbItems.push({ label: service.name });
}

const pricingTiers = service.pricing?.tiers || [];
const faqQuestions = frontmatter.faq || [];
const processSteps = frontmatter.process_steps || [];

const isLocalSEO = service.slug === 'local-seo';
const isPPC = service.slug === 'ppc';
const isTV = service.slug === 'tv-streaming-advertising';

// Find relevant case studies for this service
const serviceCaseStudies = config.case_studies.filter(cs => {
  const cat = cs.category.toLowerCase();
  if (service.slug === 'local-seo') return cat.includes('seo');
  if (service.slug === 'ppc') return cat.includes('ads') || cat.includes('ppc');
  if (service.slug === 'website-design') return cat.includes('design') || cat.includes('website');
  return false;
});

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: displayName,
  description: pageDescription,
  provider: {
    '@type': 'ProfessionalService',
    name: config.business.name,
  },
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <section class="service-hero">
    <div class="hero-bg-pattern"></div>
    <div class="container service-hero-inner">
      <Breadcrumbs items={breadcrumbItems} />
      {isTV && <span class="hero-partner-badge">Spectrum Reach Partner</span>}
      {isPPC && <span class="hero-partner-badge">$0 Agency Fee on $5K+ Spend</span>}
      <h1>{pageTitle}</h1>
      <p class="service-hero-desc">{displayDesc}</p>
      <div class="service-hero-ctas">
        <a href="/contact" class="btn btn-primary">Get Your Free Strategy Call</a>
        <a href="/pricing/" class="btn btn-outline">View Pricing</a>
      </div>
      {serviceCaseStudies.length > 0 && (
        <div class="hero-results-strip">
          {serviceCaseStudies.slice(0, 3).map(cs => (
            <div class="hero-result-chip">
              <span class="hero-result-value">{cs.result}</span>
              <span class="hero-result-client">{cs.title}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="service-content section">
    <div class="container content-layout">
      <div class="main-content">
        {content ? (
          <div class="prose" set:html={renderMarkdown(content)} />
        ) : (
          <div class="prose">
            <h2>{displayName}</h2>
            <p>{config.business.name} provides {displayName.toLowerCase()} services designed to grow home service businesses. We focus on measurable results: more calls, more booked jobs, more revenue.</p>
          </div>
        )}

        {/* Sub-service cards */}
        {type === 'service' && service.sub_services && service.sub_services.length > 0 && (
          <div class="sub-services">
            <h2>{service.name} Services</h2>
            <div class="sub-services-grid">
              {service.sub_services.map((sub: any) => (
                <a href={`/services/${service.slug}/${sub.slug}/`} class="sub-service-card card">
                  <div class="sub-service-body">
                    <h3>{sub.name}</h3>
                    <p>{sub.short_description}</p>
                    <span class="card-link">Learn More &rarr;</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        {/* Pricing */}
        {pricingTiers.length > 0 && (
          <div class="inline-pricing">
            <h2>{displayName} Pricing</h2>
            <div class="pricing-grid">
              {pricingTiers.map((tier: any) => (
                <div class={`pricing-card ${tier.featured ? 'pricing-featured' : ''}`}>
                  {tier.featured && <div class="pricing-badge">Most Popular</div>}
                  <h3>{tier.name}</h3>
                  <div class="pricing-price">
                    {tier.price === 0 ? (
                      <span class="price-amount">{tier.price_label || 'Custom'}</span>
                    ) : (
                      <>
                        {tier.price_label === 'starting at' && <span class="price-label">Starting at</span>}
                        <span class="price-currency">$</span>
                        <span class="price-amount">{tier.price.toLocaleString()}</span>
                        {tier.price_label && tier.price_label !== 'starting at' && <span class="price-period">{tier.price_label}</span>}
                        {!tier.price_label && <span class="price-period">/mo</span>}
                      </>
                    )}
                  </div>
                  <p class="pricing-desc">{tier.description}</p>
                  <ul class="pricing-features">
                    {tier.features.map((f: string) => (
                      <li>{f}</li>
                    ))}
                  </ul>
                  <a href="/contact" class={`btn ${tier.featured ? 'btn-primary' : 'btn-outline'} btn-block`}>Get Started</a>
                </div>
              ))}
            </div>
            {service.pricing?.setup_fee && (
              <p class="setup-note">One-time setup fee: ${service.pricing.setup_fee.toLocaleString()}</p>
            )}
          </div>
        )}

        {/* Quote-based pricing */}
        {service.pricing?.quote_based && (
          <div class="quote-pricing">
            <h2>{displayName} Pricing</h2>
            <div class="quote-card">
              <p>{service.pricing.description}</p>
              <a href="/contact" class="btn btn-primary">Request a Custom Quote</a>
            </div>
          </div>
        )}

        {/* Process Steps */}
        {processSteps.length > 0 && (
          <div class="process-section">
            <h2>How {displayName} Works</h2>
            <div class="process-steps">
              {processSteps.map((step: any, i: number) => (
                <div class="process-step">
                  <div class="step-number">{i + 1}</div>
                  <div class="step-content">
                    <h3>{step.title}</h3>
                    <p>{step.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Lead Magnet */}
        <LeadMagnet service={service.slug} variant="inline" />

        {/* Case Studies for this service */}
        {serviceCaseStudies.length > 0 && (
          <div class="inline-case-studies">
            <h2>Real {displayName} Results</h2>
            <div class="inline-cases-grid">
              {serviceCaseStudies.slice(0, 4).map(cs => (
                <a href={`/case-studies/${cs.slug}/`} class="inline-case-card">
                  <span class="inline-case-tag">{cs.category}</span>
                  <h3>{cs.metrics?.primary || cs.result}</h3>
                  <span class="inline-case-client">{cs.title}</span>
                  {cs.metrics?.secondary && <span class="inline-case-secondary">{cs.metrics.secondary}</span>}
                  <span class="card-link">Read Full Case Study &rarr;</span>
                </a>
              ))}
            </div>
            <a href="/case-studies/" class="see-all-link">See All {config.case_studies.length} Case Studies &rarr;</a>
          </div>
        )}

        {/* Industries served */}
        <div class="industries-served">
          <h2>Industries We Serve with {displayName}</h2>
          <div class="industries-grid-small">
            {config.industries.slice(0, 12).map(ind => (
              <a href={`/industries/${ind.slug}/${service.slug}/`} class="industry-link">{ind.full_name}</a>
            ))}
          </div>
          <a href="/industries/" class="see-all-link">See All {config.industries.length} Industries &rarr;</a>
        </div>

        {/* FAQ */}
        {faqQuestions.length > 0 && (
          <div class="faq-section">
            <h2>{displayName} FAQ</h2>
            {faqQuestions.map((q: any) => (
              <details class="faq-item">
                <summary>{q.question}</summary>
                <div class="faq-answer" set:html={renderMarkdown(q.answer)} />
              </details>
            ))}
          </div>
        )}
      </div>

      <aside class="sidebar">
        <div class="sidebar-card">
          <h3>Our Services</h3>
          <ul class="sidebar-nav">
            {config.services.map(svc => (
              <li class={svc.slug === service.slug ? 'active' : ''}>
                <a href={`/services/${svc.slug}/`}>{svc.name}</a>
                {svc.slug === service.slug && svc.sub_services && (
                  <ul class="sidebar-sub-nav">
                    {svc.sub_services.map((sub: any) => (
                      <li class={subService?.slug === sub.slug ? 'active' : ''}>
                        <a href={`/services/${svc.slug}/${sub.slug}/`}>{sub.name}</a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-cta">
          <h3>Free Strategy Call</h3>
          <p>15 minutes. No pressure. We analyze your market and show you the gaps.</p>
          <a href="/contact" class="btn btn-primary btn-block">Book Now</a>
        </div>
      </aside>
    </div>
  </section>

  {/* Free 10-Day Boost - Local SEO only */}
  {isLocalSEO && (
    <section class="boost-band section-dark">
      <div class="boost-band-pattern"></div>
      <div class="container boost-band-grid">
        <div class="boost-band-content">
          <span class="boost-band-label">Limited Offer</span>
          <h2>Free 10-Day Local SEO Boost</h2>
          <p>We will optimize your Google Business Profile, fix your citations, and boost your local signals for 10 days. No charge. No commitment. If you see results, we talk.</p>
          <div class="boost-band-reqs">
            <span>Requirements:</span>
            <ul>
              <li>Physical Google Business Profile</li>
              <li>15+ existing Google reviews</li>
              <li>4.5+ star rating</li>
              <li>Existing website</li>
            </ul>
          </div>
          <a href="/contact?service=10-day-boost" class="btn btn-primary">Apply for Free Boost &rarr;</a>
        </div>
        <div class="boost-band-stats">
          <div class="boost-stat">
            <span class="boost-stat-val">+47%</span>
            <span class="boost-stat-desc">Search Appearances</span>
          </div>
          <div class="boost-stat">
            <span class="boost-stat-val">+23%</span>
            <span class="boost-stat-desc">Discovery Searches</span>
          </div>
          <div class="boost-stat">
            <span class="boost-stat-val">+15%</span>
            <span class="boost-stat-desc">Direction Requests</span>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* Spectrum Partnership callout - PPC and TV pages */}
  {(isPPC || isTV) && (
    <section class="spectrum-band section">
      <div class="container spectrum-band-inner">
        <span class="section-label">Exclusive Partnership</span>
        <h2>Powered by Spectrum Reach</h2>
        <div class="spectrum-band-grid">
          <div class="spectrum-band-stat">
            <span class="spectrum-num">30M+</span>
            <span>Households of First-Party Data</span>
          </div>
          <div class="spectrum-band-stat">
            <span class="spectrum-num">36</span>
            <span>States Covered</span>
          </div>
          <div class="spectrum-band-stat">
            <span class="spectrum-num">$0</span>
            <span>Agency Fee on $5K+ Spend</span>
          </div>
        </div>
      </div>
    </section>
  )}

  <CTABand heading={`Ready to Get Started with ${displayName}?`} />
  <ReviewsSection compact={true} maxReviews={3} />
  <Footer slot="footer" />
</Base>

<style>
  .service-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .hero-bg-pattern {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(192,57,43,0.12) 0%, transparent 45%),
      radial-gradient(circle at 80% 20%, rgba(192,57,43,0.06) 0%, transparent 35%);
    pointer-events: none;
  }
  .service-hero-inner { position: relative; z-index: 1; }

  .hero-partner-badge {
    display: inline-block; font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--color-primary); background: rgba(192,57,43,0.15);
    padding: 0.25rem 0.75rem; border-radius: 4px; margin-bottom: var(--space-md);
  }

  .service-hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
    max-width: 700px;
  }

  .service-hero-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-lg);
    max-width: 600px;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .service-hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .service-hero .btn-outline {
    border-color: rgba(255,255,255,0.3);
    color: var(--color-white);
  }
  .service-hero .btn-outline:hover {
    background: var(--color-white);
    color: var(--color-dark);
    border-color: var(--color-white);
  }

  .hero-results-strip {
    display: flex; gap: var(--space-xl); margin-top: var(--space-xl);
    padding-top: var(--space-lg); border-top: 1px solid rgba(255,255,255,0.08);
  }
  .hero-result-chip { display: flex; flex-direction: column; }
  .hero-result-value { font-family: var(--font-heading); font-size: var(--text-base); font-weight: 700; color: var(--color-primary); }
  .hero-result-client { font-size: 0.7rem; color: rgba(255,255,255,0.4); }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 1024px) {
    .content-layout {
      grid-template-columns: 1fr 300px;
    }
  }

  .prose { max-width: none; }
  .prose :global(h2) { font-size: var(--text-2xl); margin-top: var(--space-2xl); margin-bottom: var(--space-md); }
  .prose :global(h3) { font-size: var(--text-xl); margin-top: var(--space-xl); margin-bottom: var(--space-sm); }
  .prose :global(p) { color: var(--color-text-light); line-height: var(--leading-relaxed); }
  .prose :global(ul), .prose :global(ol) { margin-bottom: 1em; color: var(--color-text-light); }
  .prose :global(li) { margin-bottom: 0.375rem; line-height: var(--leading-relaxed); }
  .prose :global(strong) { color: var(--color-text); }

  .sub-services { margin: var(--space-2xl) 0; }
  .sub-services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-lg); margin-top: var(--space-lg); }
  .sub-service-card { text-decoration: none; color: inherit; transition: transform var(--transition-fast), box-shadow var(--transition-fast); }
  .sub-service-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .sub-service-body { padding: var(--space-lg); }
  .sub-service-body h3 { font-size: var(--text-lg); margin-bottom: var(--space-sm); }
  .sub-service-body p { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-sm); }
  .card-link { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }

  .inline-pricing { margin-top: var(--space-2xl); }
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-lg); margin-top: var(--space-lg); }
  .pricing-card { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-md); padding: var(--space-xl); position: relative; }
  .pricing-featured { border-color: var(--color-primary); box-shadow: 0 0 0 1px var(--color-primary); }
  .pricing-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--color-primary); color: var(--color-white); padding: 0.25rem 1rem; border-radius: 999px; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; white-space: nowrap; }
  .pricing-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-sm); }
  .pricing-price { margin-bottom: var(--space-sm); }
  .price-label { display: block; font-size: var(--text-xs); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; }
  .price-currency { font-size: var(--text-xl); font-weight: 700; vertical-align: top; }
  .price-amount { font-size: var(--text-3xl); font-weight: 800; line-height: 1; }
  .price-period { font-size: var(--text-sm); color: var(--color-text-light); }
  .pricing-desc { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-md); }
  .pricing-features { list-style: none; padding: 0; margin-bottom: var(--space-lg); }
  .pricing-features li { padding: 0.375rem 0; font-size: var(--text-sm); border-bottom: 1px solid var(--color-gray-100); }
  .pricing-features li::before { content: '✓ '; color: var(--color-primary); font-weight: 700; }
  .setup-note { text-align: center; color: var(--color-text-light); font-size: var(--text-sm); margin-top: var(--space-md); }

  .quote-pricing { margin-top: var(--space-2xl); }
  .quote-card { background: var(--color-gray-100); border-radius: var(--radius-md); padding: var(--space-xl); text-align: center; }
  .quote-card p { margin-bottom: var(--space-lg); color: var(--color-text-light); max-width: 500px; margin-left: auto; margin-right: auto; }

  .process-section { margin-top: var(--space-2xl); }
  .process-steps { margin-top: var(--space-lg); }
  .process-step { display: flex; gap: var(--space-lg); padding: var(--space-lg) 0; border-bottom: 1px solid var(--color-gray-200); }
  .step-number { width: 48px; height: 48px; border-radius: 50%; background: var(--color-primary); color: var(--color-white); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: var(--text-lg); flex-shrink: 0; }
  .step-content h3 { margin-bottom: var(--space-xs); }
  .step-content p { font-size: var(--text-sm); color: var(--color-text-light); }

  .industries-served { margin-top: var(--space-2xl); }
  .industries-grid-small { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
  .industry-link { display: inline-block; padding: 0.5rem 1rem; background: var(--color-gray-100); border-radius: var(--radius-sm); font-size: var(--text-sm); transition: background var(--transition-fast), color var(--transition-fast); }
  .industry-link:hover { background: var(--color-primary); color: var(--color-white); }
  .see-all-link { display: inline-block; margin-top: var(--space-md); font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }

  /* Inline Case Studies */
  .inline-case-studies { margin-top: var(--space-2xl); }
  .inline-cases-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: var(--space-md); margin-top: var(--space-lg); }
  .inline-case-card {
    display: flex; flex-direction: column; padding: var(--space-lg);
    background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 10px;
    text-decoration: none; color: inherit; transition: transform 0.15s, box-shadow 0.15s;
  }
  .inline-case-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .inline-case-tag { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); margin-bottom: var(--space-xs); }
  .inline-case-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-xs); }
  .inline-case-client { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: 0.25rem; }
  .inline-case-secondary { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-sm); }

  .sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .sidebar-card { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-md); padding: var(--space-lg); position: sticky; top: var(--space-lg); }
  .sidebar-card h3 { font-size: var(--text-base); margin-bottom: var(--space-md); }
  .sidebar-nav { list-style: none; padding: 0; margin: 0; }
  .sidebar-nav li a { display: block; padding: 0.5rem 0.75rem; font-size: var(--text-sm); color: var(--color-text-light); border-radius: var(--radius-sm); transition: background var(--transition-fast); }
  .sidebar-nav li a:hover, .sidebar-nav li.active > a { background: var(--color-gray-100); color: var(--color-primary); font-weight: 600; }
  .sidebar-sub-nav { list-style: none; padding: 0 0 0 var(--space-md); margin: 0; }
  .sidebar-sub-nav li a { font-size: var(--text-xs); padding: 0.375rem 0.5rem; }
  .sidebar-cta { background: var(--color-dark); color: var(--color-white); border: none; }
  .sidebar-cta h3 { color: var(--color-white); }
  .sidebar-cta p { color: rgba(255, 255, 255, 0.7); margin-bottom: var(--space-md); font-size: var(--text-sm); }
  .btn-block { display: block; text-align: center; width: 100%; }

