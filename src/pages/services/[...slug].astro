---
import Base from '../../layouts/Base.astro';
import config from '../../lib/config';
import reviews from '../../data/real-reviews.json';

export function getStaticPaths() {
  const paths: any[] = [];
  config.services.forEach(service => {
    paths.push({ params: { slug: service.slug }, props: { service, subService: null } });
    if (service.sub_services) {
      service.sub_services.forEach(sub => {
        paths.push({ params: { slug: `${service.slug}/${sub.slug}` }, props: { service, subService: sub } });
      });
    }
  });
  return paths;
}

const { service, subService } = Astro.props;
const relatedCaseStudies = config.case_studies.filter(cs =>
  cs.category.toLowerCase().includes(service.slug.split('-')[0]) ||
  cs.category.toLowerCase().includes(service.name.split(' ')[0].toLowerCase())
).slice(0, 4);

const featuredReviews = reviews.slice(0, 3);
const isLocalSeo = service.slug === 'local-seo';
const isPpc = service.slug === 'ppc';
const isWebDesign = service.slug === 'website-design';
const isTv = service.slug === 'tv-streaming-advertising';
---

<Base title={subService ? `${subService.name} — ${service.name}` : service.name} description={subService?.short_description || service.short_description}>

<!-- Hero -->
<section class="svc-hero glow-red" style="position: relative; overflow: hidden;">
  <div class="svc-hero__bg bg-grid"></div>
  <div class="container" style="position: relative; z-index: 1;">
    <div class="svc-hero__content fade-in">
      <a href="/services/" class="svc-hero__back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        All Services
      </a>
      <h1>{subService ? subService.name : service.name}</h1>
      <p class="svc-hero__sub">{subService?.short_description || service.short_description}</p>
      <div class="svc-hero__ctas">
        <a href="/contact/" class="btn btn--primary btn--lg">Get Started</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn--outline btn--lg">Call {config.business.phone}</a>
      </div>
    </div>
  </div>
</section>

<!-- Sub Services Navigation -->
{service.sub_services && service.sub_services.length > 0 && (
  <section class="section--sm bg-dark-2" style="border-bottom: 1px solid var(--dark-4);">
    <div class="container">
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center;">
        <a href={`/services/${service.slug}/`} class:list={['btn btn--sm', !subService ? 'btn--primary' : 'btn--outline']}>
          Overview
        </a>
        {service.sub_services.map(sub => (
          <a href={`/services/${service.slug}/${sub.slug}/`} class:list={['btn btn--sm', subService?.slug === sub.slug ? 'btn--primary' : 'btn--outline']}>
            {sub.name}
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- What You Get -->
<section class="section">
  <div class="container">
    <div class="svc-grid fade-in">
      <div>
        <span class="section-label">What You Get</span>
        {isLocalSeo && (
          <>
            <h2 style="margin-bottom: 1.25rem;">Map Pack Domination That Drives Real Calls</h2>
            <p style="color: var(--gray-400); line-height: 1.7; margin-bottom: 1rem;">When someone in your area searches for your service, you need to be in the Google Map Pack — the top 3 local results that capture 44% of all clicks. We make that happen fast.</p>
            <p style="color: var(--gray-400); line-height: 1.7; margin-bottom: 1.5rem;">Our approach combines complete Google Business Profile optimization, strategic citation building, review generation systems, and local authority development. Most clients see measurable ranking improvements within 10 days of our free boost.</p>
          </>
        )}
        {isPpc && (
          <>
            <h2 style="margin-bottom: 1.25rem;">Zero-Fee PPC Through Spectrum Reach</h2>
            <p style="color: var(--gray-400); line-height: 1.7; margin-bottom: 1rem;">Most agencies charge 15-30% of your ad spend as a management fee. Through our Spectrum Reach partnership, clients spending $5K+/month pay zero agency fees — 100% of your budget goes directly into your campaigns.</p>
            <p style="color: var(--gray-400); line-height: 1.7; margin-bottom: 1.5rem;">You also get access to first-party data from 30M+ households across 48 states, AI-powered real-time bid optimization, and campaigns across Google, Bing, and Yahoo simultaneously.</p>
          </>
        )}
        {isWebDesign && (
          <>
            <h2 style="margin-bottom: 1.25rem;">Websites That Convert Visitors Into Revenue</h2>
            <p style="color: var(--gray-400); line-height: 1.7; margin-bottom: 1rem;">A beautiful website means nothing if it doesn't generate leads. We build conversion-optimized sites that load in under 2 seconds and are engineered to turn every visitor into a potential customer.</p>
            <p style="color: var(--gray-400); line-height: 1.7; margin-bottom: 1.5rem;">Choose between our ultra-fast custom Astro builds (zero JavaScript, edge-deployed, starting at $2,500) or full-featured WordPress sites with CMS flexibility (starting at $4,000).</p>
          </>
        )}
        {isTv && (
          <>
            <h2 style="margin-bottom: 1.25rem;">TV & Streaming Ads That Reach Your Exact Audience</h2>
            <p style="color: var(--gray-400); line-height: 1.7; margin-bottom: 1rem;">Through Spectrum Reach, we place your brand on streaming platforms and connected TV with precision targeting — reaching specific demographics, neighborhoods, and behavioral profiles across 48 states.</p>
            <p style="color: var(--gray-400); line-height: 1.7; margin-bottom: 1.5rem;">Every campaign includes free professional video production in Florida (paid production available nationwide). Your budget goes directly to media placement — no agency markup.</p>
          </>
        )}
        <a href="/contact/" class="btn btn--primary">Get Your Free Strategy Call</a>
      </div>
      <div class="svc-features">
        <div class="svc-feature-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <h4 style="font-size: 0.95rem; margin-bottom: 0.25rem;">No Long-Term Contracts</h4>
            <p style="color: var(--gray-500); font-size: 0.85rem;">Our results keep you, not a contract.</p>
          </div>
        </div>
        <div class="svc-feature-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <h4 style="font-size: 0.95rem; margin-bottom: 0.25rem;">Dedicated Account Manager</h4>
            <p style="color: var(--gray-500); font-size: 0.85rem;">Direct access to your strategist. No middlemen.</p>
          </div>
        </div>
        <div class="svc-feature-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <h4 style="font-size: 0.95rem; margin-bottom: 0.25rem;">Real-Time Reporting</h4>
            <p style="color: var(--gray-500); font-size: 0.85rem;">See every metric that matters, when it matters.</p>
          </div>
        </div>
        <div class="svc-feature-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <h4 style="font-size: 0.95rem; margin-bottom: 0.25rem;">Full Transparency</h4>
            <p style="color: var(--gray-500); font-size: 0.85rem;">You see every dollar, every decision, every result.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pricing (if available) -->
{service.pricing && service.pricing.tiers && (
  <section class="section bg-dark" id="pricing">
    <div class="container">
      <div class="fade-in" style="text-align: center; margin-bottom: 3rem;">
        <span class="section-label">Pricing</span>
        <h2>Transparent Pricing. No Surprises.</h2>
        {service.pricing.setup_fee && <p style="color: var(--gray-500); font-size: 0.9rem; margin-top: 0.5rem;">One-time setup: ${service.pricing.setup_fee.toLocaleString()}</p>}
      </div>
      <div class="pricing-grid stagger">
        {service.pricing.tiers.map(tier => (
          <div class:list={['pricing-card', { 'pricing-card--featured': tier.featured }]}>
            {tier.featured && <div class="pricing-card__badge">Most Popular</div>}
            <h3 style="font-size: 1.15rem; margin-bottom: 0.25rem;">{tier.name}</h3>
            <p style="color: var(--gray-500); font-size: 0.85rem; margin-bottom: 1.25rem;">{tier.description}</p>
            <div class="pricing-card__price">
              {tier.price_label && tier.price === 0 ? (
                <span class="pricing-card__amount">{tier.price_label}</span>
              ) : (
                <>
                  <span class="pricing-card__amount">${tier.price.toLocaleString()}</span>
                  <span class="pricing-card__period">{tier.price_label || '/mo'}</span>
                </>
              )}
            </div>
            <ul class="pricing-card__features">
              {tier.features.map(f => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contact/" class:list={['btn', tier.featured ? 'btn--primary' : 'btn--outline', 'btn--lg']} style="width: 100%; margin-top: auto;">
              Get Started
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{service.pricing?.quote_based && (
  <section class="section bg-dark">
    <div class="container" style="text-align: center;">
      <div class="fade-in">
        <span class="section-label">Custom Pricing</span>
        <h2 style="margin-bottom: 1rem;">Every Campaign is Custom-Built</h2>
        <p style="color: var(--gray-400); max-width: 600px; margin: 0 auto 2rem;">{service.pricing.description}</p>
        <a href="/contact/" class="btn btn--primary btn--lg">Request a Custom Quote</a>
      </div>
    </div>
  </section>
)}

<!-- Reviews -->
{featuredReviews.length > 0 && (
  <section class="section">
    <div class="container">
      <div class="fade-in" style="text-align: center; margin-bottom: 2.5rem;">
        <span class="section-label">Client Reviews</span>
        <h2>What Our Clients Say</h2>
      </div>
      <div class="grid grid--3 stagger">
        {featuredReviews.map(r => (
          <div class="testimonial-card">
            <div class="stars" style="margin-bottom: 0.75rem;">
              {Array.from({length: r.rating}).map(() => (
                <svg viewBox="0 0 20 20"><path d="M10 1l2.39 4.84L17.3 6.7l-3.65 3.56.86 5.03L10 13.07l-4.51 2.22.86-5.03L2.7 6.7l4.91-.86L10 1z"/></svg>
              ))}
            </div>
            <p class="testimonial-card__quote">{r.text}</p>
            <span class="testimonial-card__author">{r.author}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Related Case Studies -->
{relatedCaseStudies.length > 0 && (
  <section class="section bg-dark">
    <div class="container">
      <div class="fade-in" style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem;">
        <div>
          <span class="section-label">Proven Results</span>
          <h2>Related Case Studies</h2>
        </div>
        <a href="/case-studies/" class="btn btn--ghost">View All <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
      </div>
      <div class="grid grid--4 stagger" style="gap: 1.25rem;">
        {relatedCaseStudies.map(cs => (
          <a href={`/case-studies/${cs.slug}/`} class="case-card" style="text-decoration:none;">
            {cs.image && <img src={`/media/case-studies/${cs.image}`} alt={cs.title} width="400" height="250" loading="lazy" class="case-card__img" />}
            <div class="case-card__body">
              <span class="case-card__category">{cs.category}</span>
              <h4 class="case-card__title">{cs.title}</h4>
              <div class="case-card__metric">
                <span class="case-card__metric-value">{cs.metrics?.primary || cs.result}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- CTA -->
<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Ready to Get Started?</h2>
    <p style="margin-bottom: 2rem; font-size: 1.05rem;">Book a free strategy call and we'll build a custom plan for your business.</p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/contact/" class="btn btn--lime btn--lg">Book Your Free Call</a>
      <a href={`tel:${config.business.phone_raw}`} class="btn btn--outline btn--lg" style="border-color: rgba(255,255,255,0.3); color: var(--white);">Call {config.business.phone}</a>
    </div>
  </div>
</section>

</Base>

<style>
.svc-hero {
  padding: 7rem 0 4rem;
}
.svc-hero__bg {
  position: absolute;
  inset: 0;
}
.svc-hero__back {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.8rem;
  color: var(--gray-500);
  margin-bottom: 1.5rem;
  text-decoration: none;
  transition: color var(--transition-fast);
}
.svc-hero__back:hover { color: var(--white); }
.svc-hero__content { max-width: 700px; }
.svc-hero__sub {
  font-size: 1.1rem;
  color: var(--gray-400);
  line-height: 1.7;
  margin: 1.25rem 0 2rem;
}
.svc-hero__ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.svc-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 4rem;
  align-items: flex-start;
}
@media (max-width: 1024px) {
  .svc-grid { grid-template-columns: 1fr; gap: 2.5rem; }
}

.svc-features {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.svc-feature-card {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  background: var(--dark-2);
  border: 1px solid var(--dark-4);
  border-radius: var(--radius-md);
  padding: 1.25rem;
}

/* Pricing */
.pricing-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}
.pricing-card {
  background: var(--dark-2);
  border: 1px solid var(--dark-4);
  border-radius: var(--radius-lg);
  padding: 2rem;
  display: flex;
  flex-direction: column;
  position: relative;
}
.pricing-card--featured {
  border-color: var(--red);
  background: linear-gradient(135deg, rgba(192,57,43,0.06), var(--dark-2));
}
.pricing-card__badge {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--red);
  color: var(--white);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.3rem 1rem;
  border-radius: var(--radius-full);
}
.pricing-card__price {
  display: flex;
  align-items: baseline;
  gap: 0.25rem;
  margin-bottom: 1.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--dark-4);
}
.pricing-card__amount {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 2.25rem;
  color: var(--white);
}
.pricing-card__period {
  font-size: 0.9rem;
  color: var(--gray-500);
}
.pricing-card__features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  margin-bottom: 1.5rem;
  flex: 1;
}
.pricing-card__features li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  color: var(--gray-300);
}

/* Case study cards (repeated from index for scoped) */
.case-card {
  display: flex;
  flex-direction: column;
  background: var(--dark-2);
  border: 1px solid var(--dark-4);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: all var(--transition-med);
}
.case-card:hover { border-color: var(--gray-700); transform: translateY(-4px); box-shadow: var(--shadow-md); }
.case-card__img { width: 100%; height: 180px; object-fit: cover; }
.case-card__body { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
.case-card__category { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--lime); }
.case-card__title { font-size: 1rem; color: var(--white); line-height: 1.3; }
.case-card__metric { margin-top: auto; padding-top: 0.75rem; border-top: 1px solid var(--dark-4); }
.case-card__metric-value { font-family: var(--font-heading); font-weight: 700; font-size: 0.95rem; color: var(--red-light); }
</style>
