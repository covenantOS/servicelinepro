            <div class="svc-timeline__step">
              <div class="svc-timeline__marker">
                <div class="svc-timeline__num">{i + 1}</div>
                {i < processSteps.length - 1 && <div class="svc-timeline__line"></div>}
              </div>
              <div class="svc-timeline__content">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== 10-DAY BOOST — Local SEO Only ===== -->
  {isLocalSEO && (
    <section class="svc-section svc-section--dark">
      <div class="svc-section__bg"></div>
      <div class="container" style="position:relative;z-index:1;">
        <div class="svc-boost-grid">
          <div class="svc-boost__copy">
            <span class="svc-eyebrow">Limited Offer</span>
            <h2 class="svc-h2--light">Free 10-Day Local SEO Boost</h2>
            <p class="svc-boost__desc">We will optimize your Google Business Profile, fix your citations, and boost your local signals for 10 days. No charge. No commitment.</p>
            <a href="/contact?service=10-day-boost" class="svc-btn svc-btn--primary">Apply for Free Boost</a>
          </div>
          <div class="svc-boost__stats">
            <div class="svc-boost__stat"><span class="svc-boost__stat-val">+47%</span><span class="svc-boost__stat-label">Search Appearances</span></div>
            <div class="svc-boost__stat"><span class="svc-boost__stat-val">+23%</span><span class="svc-boost__stat-label">Discovery Searches</span></div>
            <div class="svc-boost__stat"><span class="svc-boost__stat-val">+15%</span><span class="svc-boost__stat-label">Direction Requests</span></div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== SPECTRUM — PPC & TV ===== -->
  {(isPPC || isTV) && (
    <section class="svc-section svc-section--light">
      <div class="container" style="text-align:center;max-width:800px;">
        <span class="svc-eyebrow svc-eyebrow--dark">Exclusive Partnership</span>
        <h2 class="svc-h2--dark">Powered by Spectrum Reach</h2>
        <p style="color:rgba(0,0,0,0.55);max-width:600px;margin:0 auto var(--space-xl);">Your campaigns run across Google AND Yahoo, powered by first-party data from 30M+ households.</p>
        <div class="svc-spectrum-stats">
          <div class="svc-spectrum__item"><span class="svc-spectrum__val">30M+</span><span class="svc-spectrum__label">Households</span></div>
          <div class="svc-spectrum__item"><span class="svc-spectrum__val">Google + Yahoo</span><span class="svc-spectrum__label">Multi-Platform</span></div>
          <div class="svc-spectrum__item"><span class="svc-spectrum__val">36</span><span class="svc-spectrum__label">States</span></div>
          <div class="svc-spectrum__item"><span class="svc-spectrum__val">$0</span><span class="svc-spectrum__label">Agency Fee</span></div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== INDUSTRIES (dark) ===== -->
  <section class="svc-section svc-section--dark">
    <div class="svc-section__bg"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="svc-section-header svc-section-header--center">
        <span class="svc-eyebrow">Who We Work With</span>
        <h2 class="svc-h2--light">Industries We Serve</h2>
      </div>
      <div class="svc-chips">
        {config.industries.slice(0, 12).map(ind => (
          <a href={`/industries/${ind.slug}/${service.slug}/`} class="svc-chip">{ind.full_name}</a>
        ))}
      </div>
      <a href="/industries/" class="svc-see-all">See All {config.industries.length} Industries →</a>
    </div>
  </section>

  <!-- ===== FAQ (light) ===== -->
  {faqQuestions.length > 0 && (
    <section class="svc-section svc-section--light" style="background:#f5f5f5;">
      <div class="container" style="max-width:800px;">
        <div class="svc-section-header svc-section-header--center">
          <span class="svc-eyebrow svc-eyebrow--dark">Common Questions</span>
          <h2 class="svc-h2--dark">Frequently Asked Questions</h2>
        </div>
        <div class="svc-faq">
          {faqQuestions.map((q: any) => (
            <details class="svc-faq__item">
              <summary>{q.question}</summary>
              <div class="svc-faq__answer" set:html={renderMarkdown(q.answer)} />
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== PRICING ===== -->
  {pricingTiers.length > 0 && (
    <section class="svc-section svc-section--light">
      <div class="container">
        <div class="svc-section-header svc-section-header--center">
          <span class="svc-eyebrow svc-eyebrow--dark">{isLocalSEO ? 'Map Pack Guarantee' : 'Transparent Pricing'}</span>
          <h2 class="svc-h2--dark">{displayName} Pricing</h2>
        </div>
        <div class="svc-pricing-grid">
          {pricingTiers.map((tier: any) => (
            <div class={`svc-pricing ${tier.featured ? 'svc-pricing--featured' : ''}`}>
              {tier.featured && <div class="svc-pricing__badge">Most Popular</div>}
              <h3 class="svc-pricing__name">{tier.name}</h3>
              <div class="svc-pricing__price">
                {tier.price === 0 ? (
                  <span class="svc-pricing__amount">{tier.price_label || 'Custom'}</span>
                ) : (
                  <>
                    {tier.price_label === 'starting at' && <span class="svc-pricing__label">Starting at</span>}
                    <span class="svc-pricing__currency">$</span>
                    <span class="svc-pricing__amount">{tier.price.toLocaleString()}</span>
                    {tier.price_label && tier.price_label !== 'starting at' && <span class="svc-pricing__period">{tier.price_label}</span>}
                    {!tier.price_label && <span class="svc-pricing__period">/mo</span>}
                  </>
                )}
              </div>
              <p class="svc-pricing__desc">{tier.description}</p>
              <ul class="svc-pricing__features">
                {tier.features.map((f: string) => <li>{f}</li>)}
              </ul>
              <a href="/contact" class={`svc-btn ${tier.featured ? 'svc-btn--primary' : 'svc-btn--outline'} svc-btn--full`}>Get Started</a>
            </div>
          ))}
        </div>
        {service.pricing?.setup_fee && <p class="svc-pricing__setup">One-time setup fee: ${service.pricing.setup_fee.toLocaleString()}</p>}
      </div>
    </section>
  )}

  {service.pricing?.quote_based && (
    <section class="svc-section svc-section--light">
      <div class="container" style="max-width:600px;text-align:center;">
        <span class="svc-eyebrow svc-eyebrow--dark">Custom Pricing</span>
        <h2 class="svc-h2--dark">{displayName} Pricing</h2>
        <p style="color:rgba(0,0,0,0.55);margin-bottom:var(--space-xl);">{service.pricing.description}</p>
        <a href="/contact" class="svc-btn svc-btn--primary">Request a Custom Quote</a>
      </div>
    </section>
  )}

  <!-- ===== FINAL CTA (dark, dramatic) ===== -->
  <section class="svc-final-cta">
    <div class="svc-final-cta__bg"></div>
    <div class="container" style="position:relative;z-index:1;text-align:center;max-width:700px;">
      <h2 class="svc-final-cta__h2">Ready to Get Started?</h2>
      <p class="svc-final-cta__sub">Book a 15-minute strategy call. No pressure. No hard sell. Just a conversation about your goals.</p>
      <div class="svc-final-cta__actions">
        <a href="/contact" class="svc-btn svc-btn--primary svc-btn--lg">Schedule Your Strategy Call</a>
        <a href="tel:8135213199" class="svc-final-cta__phone">(813) 521-3199</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --svc-dark: #111;
    --svc-dark-card: #1e1e1e;
    --svc-light: #f9f9f9;
    --svc-red: #c0392b;
    --svc-red-hover: #a5311f;
    --svc-text-muted: rgba(255,255,255,0.6);
    --svc-text-body: rgba(255,255,255,0.85);
    --svc-border-light: rgba(255,255,255,0.06);
    --svc-border-dark: rgba(0,0,0,0.08);
  }

  /* ===== HERO ===== */
