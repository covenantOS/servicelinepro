---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import IconBulletList from '../../components/IconBulletList.astro';
import StatBar from '../../components/StatBar.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import HandwrittenCTA from '../../components/HandwrittenCTA.astro';
import StatCallout from '../../components/StatCallout.astro';
import SplitContent from '../../components/SplitContent.astro';
import IconCardGrid from '../../components/IconCardGrid.astro';
import config from '../../lib/config';
import { renderMarkdown, splitMarkdownSections } from '../../lib/markdown';
import InlineTestimonial from '../../components/InlineTestimonial.astro';
import QualifierBlock from '../../components/QualifierBlock.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const service of config.services) {
    paths.push({ params: { slug: service.slug }, props: { service, type: 'service' } });
    if (service.sub_services) {
      for (const sub of service.sub_services) {
        paths.push({ params: { slug: `${service.slug}/${sub.slug}` }, props: { service, subService: sub, type: 'sub-service' } });
      }
    }
  }
  return paths;
}

const { service, subService, type } = Astro.props;

let content = '';
let frontmatter: any = {};

function loadContent(dir: string, slug: string) {
  const filePath = path.resolve(`./src/content/${dir}/${slug}.md`);
  if (fs.existsSync(filePath)) {
    const raw = fs.readFileSync(filePath, 'utf8');
    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    if (fmMatch) {
      frontmatter = YAML.parse(fmMatch[1]);
      content = fmMatch[2];
    } else {
      content = raw;
    }
  }
}

if (type === 'sub-service' && subService) {
  loadContent('services', `${service.slug}-${subService.slug}`);
  if (!content) loadContent('services', subService.slug);
} else {
  loadContent('services', service.slug);
}

const displayName = type === 'sub-service' && subService ? subService.name : service.name;
const displayDesc = type === 'sub-service' && subService ? (subService.short_description || service.short_description) : service.short_description;
const pageTitle = frontmatter.title || `${displayName} for Home Service Businesses`;
const pageDescription = frontmatter.description || `${displayDesc} ${config.business.name} delivers performance-driven results.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
];
if (type === 'sub-service' && subService) {
  breadcrumbItems.push({ label: service.name, href: `/services/${service.slug}/` });
  breadcrumbItems.push({ label: subService.name });
} else {
  breadcrumbItems.push({ label: service.name });
}

const pricingTiers = service.pricing?.tiers || [];
const faqQuestions = frontmatter.faq || [];
const processSteps = frontmatter.process_steps || [];
const isLocalSEO = service.slug === 'local-seo';
const isPPC = service.slug === 'ppc';
const isTV = service.slug === 'tv-streaming-advertising';

const allServiceCases = config.case_studies.filter(cs => {
  const cat = cs.category.toLowerCase();
  if (service.slug === 'local-seo') return cat.includes('seo');
  if (service.slug === 'ppc') return cat.includes('ads') || cat.includes('ppc');
  if (service.slug === 'website-design') return cat.includes('design') || cat.includes('website');
  return false;
});
const serviceCaseStudies = allServiceCases.sort((a, b) => {
  if (a.slug === 'remodeling') return -1;
  if (b.slug === 'remodeling') return 1;
  return 0;
});

const contentSections = content ? splitMarkdownSections(content) : [];
const inlineReview = config.reviews?.[0];

const qualifiers: Record<string, { good: string[]; not: string[] }> = {
  'local-seo': {
    good: ['You have a physical Google Business Profile', 'You want more phone calls from local searches', 'You have 15+ Google reviews and a 4.5+ rating', 'You generate $1M+ in annual revenue', 'You want a marketing partner, not a vendor'],
    not: ['You need leads by tomorrow (try Google Ads instead)', 'You have no physical business location', 'You serve customers nationwide, not locally', 'You want to do it all yourself with no help'],
  },
  'ppc': {
    good: ['You want leads within 48 hours of launch', 'You can invest $5K+/month in ad spend', 'You want $0 agency fees on your campaigns', 'You want ads across Google, Bing, AND Yahoo', 'You want first-party data targeting, not guesswork'],
    not: ['Your monthly ad budget is under $2,000', 'You want to manage campaigns yourself', 'You only want organic traffic, not paid'],
  },
  'website-design': {
    good: ['Your current site takes more than 3 seconds to load', 'Your site looks good but does not generate calls', 'You want a site you own, not one held hostage', 'You want sub-2-second load times and mobile-first design', 'You want to pay monthly instead of a big lump sum'],
    not: ['You just need a basic landing page', 'You want to build it yourself on Wix or Squarespace', 'You do not have an established service business yet'],
  },
  'tv-streaming-advertising': {
    good: ['You want to build brand awareness beyond search', 'You want professional video production at no extra cost', 'You are ready to reach 30M+ households across 48 states', 'You want TV, streaming, AND connected TV coverage', 'You want full attribution and reporting on every dollar'],
    not: ['You only want search-based leads', 'Your total marketing budget is under $3,000/month', 'You already have a TV production team and media buyer'],
  },
};
const qualifier = qualifiers[service.slug];

const heroProofPoints: Record<string, { icon: string; text: string }[]> = {
  'local-seo': [
    { icon: 'map', text: '<strong>Map Pack SEO</strong> — Monthly retainer with a free 10-day boost' },
    { icon: 'zap', text: '<strong>10 Days Free</strong> — No credit card, no commitment' },
    { icon: 'bar', text: '<strong>Geo-Grid Tracking</strong> — See exactly where you rank' },
  ],
  'ppc': [
    { icon: 'money', text: '<strong>$0 Agency Fee</strong> on $5K+ monthly ad spend' },
    { icon: 'target', text: '<strong>First-Party Data</strong> from 30M+ households' },
    { icon: 'bar', text: '<strong>30-50% Higher CTR</strong>, 33% lower CPC' },
  ],
  'website-design': [
    { icon: 'zap', text: '<strong>Sub-2-Second Loads</strong> — Performance-first builds' },
    { icon: 'phone', text: '<strong>Conversion-Focused</strong> — Turn visitors into booked jobs' },
    { icon: 'shield', text: '<strong>You Own It</strong> — Your site, your data, always' },
  ],
  'tv-streaming-advertising': [
    { icon: 'tv', text: '<strong>Free Video Production</strong> included with every campaign' },
    { icon: 'globe', text: '<strong>30M+ Households</strong> across 48 states' },
    { icon: 'eye', text: '<strong>Full Attribution</strong> — Track every dollar' },
  ],
};
const proofPoints = heroProofPoints[service.slug] || heroProofPoints['local-seo'];

const eyebrows: Record<string, string> = {
  'local-seo': 'Proven Local SEO',
  'ppc': 'Performance-Driven PPC',
  'website-design': 'Conversion-Focused Design',
  'tv-streaming-advertising': 'TV & Streaming Advertising',
};

const serviceIconCards: Record<string, Array<{icon: string, title: string, description: string}>> = {
  'local-seo': [
    { icon: 'map', title: 'Google Business Profile', description: 'Full optimization of your GBP listing with weekly updates, photo uploads, and review management.' },
    { icon: 'target', title: 'Citation Building', description: 'Consistent NAP across 60+ directories. We fix existing errors and build authority signals.' },
    { icon: 'bar', title: 'Geo-Grid Tracking', description: 'See exactly where you rank across your service area with visual geo-grid reports every month.' },
    { icon: 'zap', title: '10-Day Free Boost', description: 'No credit card required. We optimize your profile and boost local signals at zero cost.' },
    { icon: 'star', title: 'Review Strategy', description: 'Automated review request flows and reputation monitoring to build social proof.' },
    { icon: 'chart', title: 'Monthly Reporting', description: 'Transparent dashboards showing rankings, calls, and direction requests month over month.' },
  ],
  'ppc': [
    { icon: 'money', title: '$0 Agency Fee', description: 'On ad spend of $5K+/month, 100% of your budget funds your campaigns. Zero management fees.' },
    { icon: 'target', title: 'First-Party Data', description: 'Access to 30M+ household records for precision targeting that third-party cookies cannot match.' },
    { icon: 'globe', title: 'Multi-Platform Ads', description: 'Your campaigns run across Google, Bing, AND Yahoo simultaneously from one dashboard.' },
    { icon: 'chart', title: '30-50% Higher CTR', description: 'First-party data targeting delivers dramatically better click-through rates than standard campaigns.' },
    { icon: 'zap', title: '1-2 Week Launch', description: 'From strategy call to live campaigns in under two weeks. No months-long onboarding.' },
    { icon: 'eye', title: 'Full Attribution', description: 'Track every call, form fill, and booked job back to the exact ad and keyword.' },
  ],
  'website-design': [
    { icon: 'zap', title: 'Sub-2s Load Times', description: 'Performance-first architecture. Every site loads in under 2 seconds on mobile and desktop.' },
    { icon: 'phone', title: 'Conversion Focused', description: 'Every element is designed to convert visitors into phone calls and booked appointments.' },
    { icon: 'shield', title: 'You Own Everything', description: 'Your site, your domain, your data. No hostage situations. Leave anytime with everything.' },
    { icon: 'code', title: 'Mobile-First Design', description: 'Built for the 70%+ of your customers who find you on their phones first.' },
    { icon: 'chart', title: '100/100 PageSpeed', description: 'Perfect Google PageSpeed scores mean better rankings and better user experience.' },
    { icon: 'globe', title: 'SEO Built In', description: 'Schema markup, meta tags, sitemap, and technical SEO configured from day one.' },
  ],
  'tv-streaming-advertising': [
    { icon: 'tv', title: 'Free Video Production', description: 'Professional broadcast-quality commercials included at no extra cost for Florida clients.' },
    { icon: 'globe', title: '30M+ Households', description: 'Reach audiences across 48 states through connected TV, streaming, and linear TV.' },
    { icon: 'eye', title: 'Full Attribution', description: 'Track every impression, view, and conversion with complete campaign attribution.' },
    { icon: 'target', title: 'Precision Targeting', description: 'Target by geography, demographics, interests, and viewing habits for maximum efficiency.' },
    { icon: 'chart', title: 'Cross-Platform', description: 'Connected TV, streaming apps, and linear TV combined into one cohesive campaign.' },
    { icon: 'zap', title: 'Fast Turnaround', description: 'From concept to on-air in weeks, not months. Quick iteration on creative and targeting.' },
  ],
};
const iconCards = serviceIconCards[service.slug] || serviceIconCards['local-seo'];

const serviceStatCallouts: Record<string, Array<{value: string, label: string}>> = {
  'local-seo': [
    { value: '+47%', label: 'Search Appearances' },
    { value: 'Top 3', label: 'Map Pack Rankings' },
    { value: '10 Days', label: 'Free SEO Boost' },
    { value: '5.0\u2605', label: 'Google Rating' },
  ],
  'ppc': [
    { value: '$0', label: 'Agency Fee' },
    { value: '30M+', label: 'Households' },
    { value: '33%', label: 'Lower CPC' },
    { value: '1-2 Weeks', label: 'To Launch' },
  ],
  'website-design': [
    { value: 'Sub-2s', label: 'Load Time' },
    { value: '100/100', label: 'PageSpeed' },
    { value: 'Mobile-First', label: 'Every Build' },
    { value: 'You Own It', label: 'Always' },
  ],
  'tv-streaming-advertising': [
    { value: 'FREE', label: 'Video Production' },
    { value: '30M+', label: 'Households' },
    { value: '36', label: 'States' },
    { value: '100%', label: 'Attribution' },
  ],
};
const statCalloutData = serviceStatCallouts[service.slug] || serviceStatCallouts['local-seo'];

const serviceImages: Record<string, string[]> = {
  'local-seo': ['/media/local-seo-graphic.webp', '/media/live-local-map-ranker.webp', '/media/seo-ppc-presentation.webp'],
  'ppc': ['/media/ppc-graphic.webp', '/media/live-pay-per-result.webp', '/media/live-presentation.png'],
  'website-design': ['/media/live-website-designs.webp', '/media/case-studies/Website-Design-1.webp', '/media/service-presentation.webp'],
  'tv-streaming-advertising': ['/media/service-presentation.webp', '/media/live-presentation.png', '/media/seo-ppc-presentation.webp'],
};
const images = serviceImages[service.slug] || ['/media/service-presentation.webp', '/media/live-presentation.png', '/media/seo-ppc-presentation.webp'];
const isWebDesign = service.slug === 'website-design';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: displayName,
  description: pageDescription,
  provider: { '@type': 'ProfessionalService', name: config.business.name },
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <!-- ===== HERO — Cinematic Dark Split ===== -->
  <section class="svc-hero">
    <div class="svc-hero__bg"></div>
    <div class="container svc-hero__grid">
      <div class="svc-hero__copy">
        <span class="svc-eyebrow">{eyebrows[service.slug] || displayName}</span>
        <h1 class="svc-hero__h1">{displayName}</h1>
        <p class="svc-hero__sub">{displayDesc}</p>
        <IconBulletList items={proofPoints} variant="dark" />
        <div class="svc-hero__ctas">
          <a href="/contact" class="svc-btn svc-btn--primary">Book Strategy Call</a>
          {serviceCaseStudies.length > 0 && (
            <a href="#results" class="svc-btn svc-btn--ghost">See Our Results</a>
          )}
        </div>
      </div>
      <div class="svc-hero__img">
        {service.slug === 'ppc' && <img src="/media/ppc-graphic.webp" alt="No Fee Google Ads Management" width="520" height="400" />}
        {service.slug === 'local-seo' && <img src="/media/local-seo-graphic.webp" alt="Local SEO Map Pack Rankings" width="520" height="400" />}
        {service.slug === 'website-design' && <img src="/media/case-studies/Website-Design-1.webp" alt="Custom Website Design" width="520" height="400" />}
        {service.slug === 'tv-streaming-advertising' && <img src="/media/service-presentation.webp" alt="TV & Streaming Advertising" width="520" height="400" />}
      </div>
    </div>
  </section>

  <!-- ===== SOCIAL PROOF STRIP (thin, dark) ===== -->
  <section class="svc-proof-strip">
    <div class="container">
      {serviceCaseStudies.length > 0 ? (
        <div class="svc-proof__row">
          {serviceCaseStudies.slice(0, 3).map(cs => (
            <div class="svc-proof__item">
              <span class="svc-proof__val">{cs.metrics?.primary || cs.result}</span>
              <span class="svc-proof__label">{cs.title}</span>
            </div>
          ))}
        </div>
      ) : (
        <div class="svc-proof__row">
          <div class="svc-proof__item">
            <span class="svc-proof__val">5.0 ★★★★★</span>
            <span class="svc-proof__label">Google Rating</span>
          </div>
          <div class="svc-proof__item">
            <span class="svc-proof__val">Spectrum</span>
            <span class="svc-proof__label">Reach Partner</span>
          </div>
          <div class="svc-proof__item">
            <span class="svc-proof__val">Tampa</span>
            <span class="svc-proof__label">Based &amp; Operated</span>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ===== STAT CALLOUT BAR (red accent) ===== -->
  <section class="svc-stat-bar">
    <div class="container">
      <div class="svc-stat-bar__row">
        {statCalloutData.map((stat, i) => (
          <>
            <div class="svc-stat-bar__item">
              <span class="svc-stat-bar__val">{stat.value}</span>
              <span class="svc-stat-bar__label">{stat.label}</span>
            </div>
            {i < statCalloutData.length - 1 && <div class="svc-stat-bar__div"></div>}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== VALUE PROP — Split Layout (light contrast break) ===== -->
  {contentSections.length > 0 && (
    <section class="svc-section svc-section--light">
      <div class="container">
        <div class="svc-split">
          <div class="svc-split__text">
            <div class="svc-prose" set:html={contentSections[0].html} />
          </div>
          <div class="svc-split__img">
            <img src={images[0]} alt={`${displayName} results`} loading="lazy" />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== KEY CAPABILITIES (dark) ===== -->
  <section class="svc-section svc-section--dark">
    <div class="svc-section__bg"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="svc-section-header svc-section-header--center">
        <span class="svc-eyebrow">Key Capabilities</span>
        <h2 class="svc-h2--light">What You Get</h2>
      </div>
      <div class="svc-cards-grid">
        {iconCards.map(card => (
          <div class="svc-card">
            <div class="svc-card__icon">{card.icon === 'map' ? '📍' : card.icon === 'target' ? '🎯' : card.icon === 'bar' ? '📊' : card.icon === 'zap' ? '⚡' : card.icon === 'star' ? '⭐' : card.icon === 'chart' ? '📈' : card.icon === 'money' ? '💰' : card.icon === 'globe' ? '🌐' : card.icon === 'eye' ? '👁' : card.icon === 'phone' ? '📱' : card.icon === 'shield' ? '🛡' : card.icon === 'code' ? '💻' : card.icon === 'tv' ? '📺' : '✦'}</div>
            <h3 class="svc-card__title">{card.title}</h3>
            <p class="svc-card__desc">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== QUALIFIER BLOCK (light contrast break) ===== -->
  {qualifier && (
    <section class="svc-section svc-section--light">
      <div class="container">
        <div class="svc-section-header svc-section-header--center">
          <span class="svc-eyebrow svc-eyebrow--dark">Is This Right For You?</span>
          <h2 class="svc-h2--dark">Find Out If We Are a Fit</h2>
        </div>
        <div class="svc-qual-grid">
          <div class="svc-qual-col svc-qual-col--good">
            <h3 class="svc-qual__heading svc-qual__heading--good">✓ Good Fit</h3>
            <ul class="svc-qual__list">
              {qualifier.good.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
          <div class="svc-qual-col svc-qual-col--not">
            <h3 class="svc-qual__heading svc-qual__heading--not">✕ Not For You</h3>
            <ul class="svc-qual__list">
              {qualifier.not.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== VIDEO PRODUCTION — TV Only ===== -->
  {isTV && (
    <section class="svc-section svc-section--dark">
      <div class="svc-section__bg"></div>
      <div class="container" style="position:relative;z-index:1;">
        <div class="svc-video-grid">
          <div class="svc-video__copy">
            <span class="svc-eyebrow">Major Differentiator</span>
            <h2 class="svc-h2--light">Free Professional Video Production</h2>
            <p class="svc-video__desc">Most agencies charge $5,000 to $15,000+ for a single commercial. We include broadcast-quality video production at <strong>no extra cost</strong> for Florida clients running TV & streaming campaigns.</p>
            <div class="svc-video__stats">
              <div class="svc-video__stat">
                <span class="svc-video__stat-val">FREE</span>
                <span class="svc-video__stat-label">For Florida Clients</span>
              </div>
              <div class="svc-video__stat">
                <span class="svc-video__stat-val">Nationwide</span>
                <span class="svc-video__stat-label">Available at Cost</span>
              </div>
              <div class="svc-video__stat">
                <span class="svc-video__stat-val">Broadcast</span>
                <span class="svc-video__stat-label">Quality Production</span>
              </div>
            </div>
            <p class="svc-video__credit">Video Director: <strong>Cade Hansen</strong></p>
          </div>
          <div class="svc-video__card">
            <span class="svc-video__badge">Included Free</span>
            <h3 class="svc-video__card-title">What You Get</h3>
            <ul class="svc-video__list">
              <li>Professional script development</li>
              <li>On-location or studio filming</li>
              <li>15-second and 30-second spots</li>
              <li>Broadcast-quality editing and post-production</li>
              <li>Platform-optimized formatting</li>
              <li>Multiple revisions until you love it</li>
            </ul>
            <a href="/contact" class="svc-btn svc-btn--primary svc-btn--full">Get Free Video Production</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== MID-CTA BAND (red accent) ===== -->
  <section class="svc-cta-band">
    <div class="container">
      <div class="svc-cta-band__inner">
        <div class="svc-cta-band__text">
          <h3>{isLocalSEO ? '10 Days Free. No Credit Card.' : isPPC ? '$0 Agency Fee on $5K+ Spend' : isTV ? 'Free Video Production Included' : 'Get Started Today'}</h3>
          <p>{isLocalSEO ? 'We boost your Google Business Profile for 10 days at zero cost.' : isPPC ? '100% of your ad budget funds your campaign.' : isTV ? 'Every campaign includes professional video production.' : 'Book a 15-minute strategy call. No pressure.'}</p>
        </div>
        <a href="/contact" class="svc-btn svc-btn--white">{isLocalSEO ? 'Apply for Free Boost' : 'Get Your Free Strategy Call'}</a>
      </div>
    </div>
  </section>

  <!-- ===== CASE STUDIES (dark) ===== -->
  {serviceCaseStudies.length > 0 && (
    <section class="svc-section svc-section--dark" id="results">
      <div class="svc-section__bg"></div>
      <div class="container" style="position:relative;z-index:1;">
        <div class="svc-section-header svc-section-header--center">
          <span class="svc-eyebrow">Proven Results</span>
          <h2 class="svc-h2--light">Real {displayName} Results</h2>
        </div>
        <div class="svc-cases-grid">
          {serviceCaseStudies.slice(0, 3).map(cs => (
            <a href={`/case-studies/${cs.slug}/`} class="svc-case">
              {cs.image && (
                <div class="svc-case__img">
                  <img src={`/media/case-studies/${cs.image}`} alt={cs.title} loading="lazy" width="400" height="225" />
                </div>
              )}
              <div class="svc-case__body">
                <span class="svc-case__tag">{cs.category}</span>
                <h3 class="svc-case__result">{cs.metrics?.primary || cs.result}</h3>
                <span class="svc-case__client">{cs.title}</span>
                <span class="svc-case__link">Read Case Study →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== TESTIMONIAL (light) ===== -->
  {inlineReview && (
    <section class="svc-section svc-section--light">
      <div class="container" style="max-width:800px;">
        <div class="svc-testimonial">
          <div class="svc-testimonial__stars">★★★★★</div>
          <blockquote class="svc-testimonial__quote">"{inlineReview.text}"</blockquote>
          <p class="svc-testimonial__author">— {inlineReview.author}{inlineReview.company && `, ${inlineReview.company}`}</p>
        </div>
      </div>
    </section>
  )}

  <!-- ===== MORE CONTENT — Alternating Split ===== -->
  {contentSections.slice(1).map((section, i) => (
    <section class={`svc-section ${i % 2 === 0 ? 'svc-section--dark' : 'svc-section--light'}`}>
      {i % 2 === 0 && <div class="svc-section__bg"></div>}
      <div class="container" style="position:relative;z-index:1;">
        <div class={`svc-split ${i % 2 !== 0 ? 'svc-split--reverse' : ''}`}>
          <div class="svc-split__text">
            <div class={`svc-prose ${i % 2 === 0 ? 'svc-prose--light' : ''}`} set:html={section.html} />
          </div>
          <div class="svc-split__img">
            <img src={images[(i + 1) % images.length]} alt={displayName} loading="lazy" />
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ===== COMPARISON TABLE (light) ===== -->
