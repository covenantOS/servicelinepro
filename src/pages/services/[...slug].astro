              <p>{sub.short_description}</p>
              <span class="svc-sub-card__link">Learn More →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== PROCESS STEPS (dark) ===== -->
  {processSteps.length > 0 && (
    <section class="svc-section svc-section--dark">
      <div class="svc-section__bg"></div>
      <div class="container" style="position:relative;z-index:1;">
        <div class="svc-section-header svc-section-header--center">
          <span class="svc-eyebrow">How It Works</span>
          <h2 class="svc-h2--light">Your {displayName} Journey</h2>
