      radial-gradient(circle at 20% 80%, rgba(192,57,43,0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(192,57,43,0.08) 0%, transparent 40%);
    pointer-events: none;
  }
  .svc-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative; z-index: 1;
  }
  .svc-hero__copy { max-width: 600px; }
  .svc-hero__h1 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .svc-hero__sub {
    color: var(--svc-text-muted);
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 520px;
  }
  .svc-hero__ctas {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .svc-hero__img {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .svc-hero__img img {
    width: 100%;
    max-width: 520px;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }
  @media (max-width: 900px) {
    .svc-hero__grid { grid-template-columns: 1fr; }
    .svc-hero__img { display: none; }
  }

  /* ===== EYEBROW ===== */
  .svc-eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--svc-red);
    margin-bottom: 1rem;
  }
  .svc-eyebrow--dark { color: var(--svc-red); }

  /* ===== BUTTONS ===== */
  .svc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
    border: 2px solid transparent;
    cursor: pointer;
  }
  .svc-btn--primary {
    background: var(--svc-red);
    color: #fff;
    border-color: var(--svc-red);
  }
  .svc-btn--primary:hover { background: var(--svc-red-hover); border-color: var(--svc-red-hover); }
  .svc-btn--ghost {
    background: transparent;
    color: #fff;
    border-color: rgba(255,255,255,0.3);
  }
  .svc-btn--ghost:hover { border-color: #fff; }
  .svc-btn--white {
    background: #fff;
    color: var(--svc-red);
    border-color: #fff;
  }
  .svc-btn--white:hover { background: #f0f0f0; }
  .svc-btn--outline {
    background: transparent;
    color: var(--svc-red);
    border-color: var(--svc-red);
  }
  .svc-btn--outline:hover { background: rgba(192,57,43,0.08); }
  .svc-btn--full { width: 100%; text-align: center; }
  .svc-btn--lg { padding: 1rem 2.5rem; font-size: 1rem; }

  /* ===== PROOF STRIP ===== */
  .svc-proof-strip {
    background: var(--svc-dark);
    border-top: 1px solid var(--svc-border-light);
    padding: 1.5rem 0;
  }
  .svc-proof__row {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
