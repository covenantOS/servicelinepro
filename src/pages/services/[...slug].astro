    <section class="svc-section svc-section--light">
      <div class="container" style="max-width:900px;">
        <ComparisonTable />
      </div>
    </section>
  )}

  <!-- ===== SUB-SERVICES ===== -->
  {type === 'service' && service.sub_services && service.sub_services.length > 0 && (
    <section class="svc-section svc-section--light" style="background:#f0f0f0;">
      <div class="container">
        <div class="svc-section-header">
          <span class="svc-eyebrow svc-eyebrow--dark">{service.name} Specializations</span>
          <h2 class="svc-h2--dark">{service.name} Services</h2>
        </div>
