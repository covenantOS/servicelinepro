---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import IconBulletList from '../../components/IconBulletList.astro';
import StatBar from '../../components/StatBar.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import HandwrittenCTA from '../../components/HandwrittenCTA.astro';
import config from '../../lib/config';
import { renderMarkdown, splitMarkdownSections } from '../../lib/markdown';
import InlineTestimonial from '../../components/InlineTestimonial.astro';
import QualifierBlock from '../../components/QualifierBlock.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const service of config.services) {
    paths.push({ params: { slug: service.slug }, props: { service, type: 'service' } });
    if (service.sub_services) {
      for (const sub of service.sub_services) {
        paths.push({ params: { slug: `${service.slug}/${sub.slug}` }, props: { service, subService: sub, type: 'sub-service' } });
      }
    }
  }
  return paths;
}

const { service, subService, type } = Astro.props;

let content = '';
let frontmatter: any = {};

function loadContent(dir: string, slug: string) {
  const filePath = path.resolve(`./src/content/${dir}/${slug}.md`);
  if (fs.existsSync(filePath)) {
    const raw = fs.readFileSync(filePath, 'utf8');
    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    if (fmMatch) {
      frontmatter = YAML.parse(fmMatch[1]);
      content = fmMatch[2];
    } else {
      content = raw;
    }
  }
}

if (type === 'sub-service' && subService) {
  loadContent('services', `${service.slug}-${subService.slug}`);
  if (!content) loadContent('services', subService.slug);
} else {
  loadContent('services', service.slug);
}

const displayName = type === 'sub-service' && subService ? subService.name : service.name;
const displayDesc = type === 'sub-service' && subService ? (subService.short_description || service.short_description) : service.short_description;
const pageTitle = frontmatter.title || `${displayName} for Home Service Businesses`;
const pageDescription = frontmatter.description || `${displayDesc} ${config.business.name} delivers performance-driven results.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
];
if (type === 'sub-service' && subService) {
  breadcrumbItems.push({ label: service.name, href: `/services/${service.slug}/` });
  breadcrumbItems.push({ label: subService.name });
} else {
  breadcrumbItems.push({ label: service.name });
}

const pricingTiers = service.pricing?.tiers || [];
const faqQuestions = frontmatter.faq || [];
const processSteps = frontmatter.process_steps || [];
const isLocalSEO = service.slug === 'local-seo';
const isPPC = service.slug === 'ppc';
const isTV = service.slug === 'tv-streaming-advertising';

const allServiceCases = config.case_studies.filter(cs => {
  const cat = cs.category.toLowerCase();
  if (service.slug === 'local-seo') return cat.includes('seo');
  if (service.slug === 'ppc') return cat.includes('ads') || cat.includes('ppc');
  if (service.slug === 'website-design') return cat.includes('design') || cat.includes('website');
  return false;
});
const serviceCaseStudies = allServiceCases.sort((a, b) => {
  if (a.slug === 'remodeling') return -1;
  if (b.slug === 'remodeling') return 1;
  return 0;
});

const contentSections = content ? splitMarkdownSections(content) : [];
const inlineReview = config.reviews?.[0];

const qualifiers: Record<string, { good: string[]; not: string[] }> = {
  'local-seo': {
    good: ['You have a physical Google Business Profile', 'You want more phone calls from local searches', 'You have 15+ Google reviews and a 4.5+ rating', 'You generate $1M+ in annual revenue', 'You want a marketing partner, not a vendor'],
    not: ['You need leads by tomorrow (try Google Ads instead)', 'You have no physical business location', 'You serve customers nationwide, not locally', 'You want to do it all yourself with no help'],
  },
  'ppc': {
    good: ['You want leads within 48 hours of launch', 'You can invest $5K+/month in ad spend', 'You want $0 agency fees on your campaigns', 'You want ads across Google, Bing, AND Yahoo', 'You want first-party data targeting, not guesswork'],
    not: ['Your monthly ad budget is under $2,000', 'You want to manage campaigns yourself', 'You only want organic traffic, not paid'],
  },
  'website-design': {
    good: ['Your current site takes more than 3 seconds to load', 'Your site looks good but does not generate calls', 'You want a site you own, not one held hostage', 'You want sub-2-second load times and mobile-first design', 'You want to pay monthly instead of a big lump sum'],
    not: ['You just need a basic landing page', 'You want to build it yourself on Wix or Squarespace', 'You do not have an established service business yet'],
  },
  'tv-streaming-advertising': {
    good: ['You want to build brand awareness beyond search', 'You want professional video production at no extra cost', 'You are ready to reach 30M+ households across 36 states', 'You want TV, streaming, AND connected TV coverage', 'You want full attribution and reporting on every dollar'],
    not: ['You only want search-based leads', 'Your total marketing budget is under $3,000/month', 'You already have a TV production team and media buyer'],
  },
};
const qualifier = qualifiers[service.slug];

const heroProofPoints: Record<string, { icon: string; text: string }[]> = {
  'local-seo': [
    { icon: 'map', text: '<strong>Map Pack SEO</strong> — Monthly retainer with a free 10-day boost' },
    { icon: 'zap', text: '<strong>10 Days Free</strong> — No credit card, no commitment' },
    { icon: 'bar', text: '<strong>Geo-Grid Tracking</strong> — See exactly where you rank' },
  ],
  'ppc': [
    { icon: 'money', text: '<strong>$0 Agency Fee</strong> on $5K+ monthly ad spend' },
    { icon: 'target', text: '<strong>First-Party Data</strong> from 30M+ households' },
    { icon: 'bar', text: '<strong>30-50% Higher CTR</strong>, 33% lower CPC' },
  ],
  'website-design': [
    { icon: 'zap', text: '<strong>Sub-2-Second Loads</strong> — Performance-first builds' },
    { icon: 'phone', text: '<strong>Conversion-Focused</strong> — Turn visitors into booked jobs' },
    { icon: 'shield', text: '<strong>You Own It</strong> — Your site, your data, always' },
  ],
  'tv-streaming-advertising': [
    { icon: 'tv', text: '<strong>Free Video Production</strong> included with every campaign' },
    { icon: 'globe', text: '<strong>30M+ Households</strong> across 36 states' },
    { icon: 'eye', text: '<strong>Full Attribution</strong> — Track every dollar' },
  ],
};
const proofPoints = heroProofPoints[service.slug] || heroProofPoints['local-seo'];

const eyebrows: Record<string, string> = {
  'local-seo': 'Proven Local SEO',
  'ppc': 'Performance-Driven PPC',
  'website-design': 'Conversion-Focused Design',
  'tv-streaming-advertising': 'TV & Streaming Advertising',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: displayName,
  description: pageDescription,
  provider: { '@type': 'ProfessionalService', name: config.business.name },
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <!-- ===== HERO — Full-Width Dark, Hook Agency Style ===== -->
  <section class="svc-hero">
    <div class="svc-hero-texture"></div>
    <div class="container svc-hero-inner">
      <span class="svc-hero-eyebrow">{eyebrows[service.slug] || displayName}</span>
      <h1>{pageTitle}</h1>
      <IconBulletList items={proofPoints} variant="dark" />
      <div class="svc-hero-ctas">
        <a href="/contact" class="btn btn-ghost btn-lg">Get In Touch</a>
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <section class="svc-trust-strip">
    <div class="container">
      {serviceCaseStudies.length > 0 ? (
        <div class="trust-proof-bar">
          {serviceCaseStudies.slice(0, 3).map(cs => (
            <div class="trust-proof-item">
              <span class="trust-proof-val">{cs.metrics?.primary || cs.result}</span>
              <span class="trust-proof-client">{cs.title}</span>
            </div>
          ))}
        </div>
      ) : (
        <StatBar stats={[
          { value: '5.0 ★', label: 'Google Rating' },
          { value: '$2M+', label: 'Revenue Generated' },
          { value: '300+', label: 'Leads Delivered' },
        ]} variant="dark" />
      )}
    </div>
  </section>

  <!-- ===== VALUE PROPOSITION — Dark Split ===== -->
  {contentSections.length > 0 && (
    <section class="svc-section svc-dark">
      <div class="container svc-split-grid">
        <div class="svc-split-text">
          <div class="prose" set:html={contentSections[0].html} />
        </div>
        <div class="svc-split-visual">
          {isLocalSEO && <img src="/media/local-seo-graphic.webp" alt="Local SEO results" width="520" height="400" loading="lazy" />}
          {isPPC && <img src="/media/ppc-graphic.webp" alt="PPC campaign performance" width="520" height="400" loading="lazy" />}
          {!isLocalSEO && !isPPC && !isTV && <img src="/media/service-presentation.webp" alt={displayName} width="520" height="400" loading="lazy" />}
        </div>
      </div>
    </section>
  )}

  <!-- ===== TESTIMONIAL 1 ===== -->
  {inlineReview && (
    <section class="svc-section" style="background: var(--color-gray-100);">
      <div class="container" style="max-width: 800px;">
        <InlineTestimonial quote={inlineReview.text} author={inlineReview.author} company={inlineReview.company} rating={inlineReview.rating} />
      </div>
    </section>
  )}

  <!-- ===== QUALIFIER BLOCK — White ===== -->
  {qualifier && (
    <section class="svc-section">
      <div class="container">
        <QualifierBlock goodFit={qualifier.good} notFit={qualifier.not} />
      </div>
    </section>
  )}

  <!-- ===== FEATURE GRID — Dark ===== -->
  {contentSections.length > 1 && (
    <section class="svc-section svc-dark">
      <div class="container">
        <span class="section-eyebrow" style="color: var(--color-primary);">Key Capabilities</span>
        <h2 style="color: var(--color-white); margin-bottom: var(--space-xl);">What You Get</h2>
        <div class="prose" set:html={contentSections[1].html} />
      </div>
    </section>
  )}

  <!-- ===== VIDEO PRODUCTION — TV Only ===== -->
  {isTV && (
    <section class="svc-section svc-dark">
      <div class="container">
        <div class="video-prod-grid">
          <div class="video-prod-content">
            <span class="section-eyebrow" style="color: var(--color-primary);">Major Differentiator</span>
            <h2 style="color: var(--color-white); margin-bottom: var(--space-md);">Free Professional Video Production</h2>
            <p style="color: rgba(255,255,255,0.7); line-height: 1.7; margin-bottom: var(--space-lg); max-width: 520px;">Most agencies charge $5,000 to $15,000+ for a single commercial. We include broadcast-quality video production at <strong style="color: var(--color-white);">no extra cost</strong> for Florida clients running TV & streaming campaigns.</p>
            <div class="video-prod-highlights">
              <div class="vp-highlight">
                <span class="vp-highlight-val">FREE</span>
                <span class="vp-highlight-label">For Florida Clients</span>
              </div>
              <div class="vp-highlight">
                <span class="vp-highlight-val">Nationwide</span>
                <span class="vp-highlight-label">Available at Cost</span>
              </div>
              <div class="vp-highlight">
                <span class="vp-highlight-val">Broadcast</span>
                <span class="vp-highlight-label">Quality Production</span>
              </div>
            </div>
            <p style="color: rgba(255,255,255,0.5); font-size: var(--text-sm); margin-top: var(--space-lg);">Video Director: <strong style="color: rgba(255,255,255,0.8);">Cade Hansen</strong></p>
          </div>
          <div class="video-prod-card">
            <div class="vp-card-inner">
              <span class="vp-card-badge">Included Free</span>
              <h3 style="color: var(--color-white); font-size: var(--text-xl); margin-bottom: var(--space-md); text-transform: none;">What You Get</h3>
              <ul class="vp-card-list">
                <li>Professional script development</li>
                <li>On-location or studio filming</li>
                <li>15-second and 30-second spots</li>
                <li>Broadcast-quality editing and post-production</li>
                <li>Platform-optimized formatting</li>
                <li>Multiple revisions until you love it</li>
              </ul>
              <a href="/contact" class="btn btn-primary btn-lg" style="width: 100%; text-align: center; margin-top: var(--space-md);">Get Free Video Production</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== MID-CTA ===== -->
  <section class="svc-section svc-dark svc-cta-band">
    <div class="container">
      <div class="svc-cta-inner">
        <div class="svc-cta-text">
          <h3>{isLocalSEO ? '10 Days Free. No Credit Card.' : isPPC ? '$0 Agency Fee on $5K+ Spend' : isTV ? 'Free Video Production Included' : 'Get Started Today'}</h3>
          <p>{isLocalSEO ? 'We boost your Google Business Profile for 10 days at zero cost.' : isPPC ? '100% of your ad budget funds your campaign.' : isTV ? 'Every campaign includes professional video production.' : 'Book a 15-minute strategy call. No pressure.'}</p>
        </div>
        <a href="/contact" class="btn btn-primary">{isLocalSEO ? 'Apply for Free Boost' : 'Get Your Free Strategy Call'}</a>
      </div>
    </div>
  </section>

  <!-- ===== COMPARISON TABLE — White ===== -->
  {type === 'service' && (
    <section class="svc-section">
      <div class="container" style="max-width: 900px;">
        <ComparisonTable />
      </div>
    </section>
  )}

  <!-- ===== MORE CONTENT — Intentional Dark/White Rhythm ===== -->
  {contentSections.slice(2).map((section, i) => (
    <section class={`svc-section ${i % 2 === 0 ? 'svc-dark' : ''}`}>
      <div class="container" style="max-width: 800px;">
        <div class="prose" set:html={section.html} />
      </div>
    </section>
  ))}

  <!-- ===== CASE STUDIES — Dark ===== -->
  {serviceCaseStudies.length > 0 && (
    <section class="svc-section svc-dark">
      <div class="container">
        <span class="section-eyebrow" style="color: var(--color-primary);">Proven Results</span>
        <h2 style="color: var(--color-white); margin-bottom: var(--space-xl);">Real {displayName} Results</h2>
        <div class="svc-cases-grid">
          {serviceCaseStudies.slice(0, 3).map(cs => (
            <a href={`/case-studies/${cs.slug}/`} class="svc-case-card">
              {cs.image && (
                <div class="svc-case-img">
                  <img src={`/media/case-studies/${cs.image}`} alt={cs.title} loading="lazy" width="400" height="225" />
                </div>
              )}
              <div class="svc-case-body">
                <span class="svc-case-tag">{cs.category}</span>
                <h3>{cs.metrics?.primary || cs.result}</h3>
                <span class="svc-case-client">{cs.title}</span>
                <span class="card-link">Read Case Study &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== SECOND TESTIMONIAL ===== -->
  {config.reviews?.[1] && (
    <section class="svc-section">
      <div class="container" style="max-width: 800px;">
        <InlineTestimonial quote={config.reviews[1].text} author={config.reviews[1].author} company={config.reviews[1].company} rating={config.reviews[1].rating} />
      </div>
    </section>
  )}

  <!-- ===== SUB-SERVICES ===== -->
  {type === 'service' && service.sub_services && service.sub_services.length > 0 && (
    <section class="svc-section" style="background: var(--color-gray-100);">
      <div class="container">
        <span class="section-eyebrow">{service.name} Specializations</span>
        <h2>{service.name} Services</h2>
        <div class="svc-sub-grid">
          {service.sub_services.map((sub: any) => (
            <a href={`/services/${service.slug}/${sub.slug}/`} class="svc-sub-card card">
              <div class="svc-sub-body">
                <h3>{sub.name}</h3>
                <p>{sub.short_description}</p>
                <span class="card-link">Learn More &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== PROCESS STEPS — White ===== -->
  {processSteps.length > 0 && (
    <section class="svc-section">
      <div class="container">
        <span class="section-eyebrow">How It Works</span>
        <h2>Your {displayName} Journey</h2>
        <div class="svc-timeline">
          {processSteps.map((step: any, i: number) => (
            <div class="timeline-step">
              <div class="timeline-marker">
                <div class="timeline-number">{i + 1}</div>
                {i < processSteps.length - 1 && <div class="timeline-line"></div>}
              </div>
              <div class="timeline-content">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== INDUSTRIES — Dark ===== -->
  <section class="svc-section svc-dark">
    <div class="container">
      <span class="section-eyebrow" style="color: var(--color-primary);">Who We Work With</span>
      <h2 style="color: var(--color-white); margin-bottom: var(--space-lg);">Industries We Serve with {displayName}</h2>
      <div class="svc-chips">
        {config.industries.slice(0, 12).map(ind => (
          <a href={`/industries/${ind.slug}/${service.slug}/`} class="svc-chip">{ind.full_name}</a>
        ))}
      </div>
      <a href="/industries/" class="see-all-light">See All {config.industries.length} Industries &rarr;</a>
    </div>
  </section>

  <!-- ===== FAQ — White ===== -->
  {faqQuestions.length > 0 && (
    <section class="svc-section" style="background: var(--color-gray-100);">
      <div class="container" style="max-width: 800px;">
        <span class="section-eyebrow">Common Questions</span>
        <h2>Frequently Asked Questions About {displayName}</h2>
        <div class="svc-faq">
          {faqQuestions.map((q: any) => (
            <details class="faq-item">
              <summary>{q.question}</summary>
              <div class="faq-answer" set:html={renderMarkdown(q.answer)} />
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== PRICING ===== -->
  {pricingTiers.length > 0 && (
    <section class="svc-section">
      <div class="container">
        <div style="text-align: center; margin-bottom: var(--space-xl);">
          <span class="section-eyebrow">{isLocalSEO ? 'Map Pack Guarantee' : 'Transparent Pricing'}</span>
          <h2>{displayName} Pricing</h2>
        </div>
        <div class="svc-pricing-grid">
          {pricingTiers.map((tier: any) => (
            <div class={`svc-pricing-card ${tier.featured ? 'svc-pricing-featured' : ''}`}>
              {tier.featured && <div class="svc-pricing-badge">Most Popular</div>}
              <h3>{tier.name}</h3>
              <div class="svc-pricing-price">
                {tier.price === 0 ? (
                  <span class="price-amount">{tier.price_label || 'Custom'}</span>
                ) : (
                  <>
                    {tier.price_label === 'starting at' && <span class="price-label">Starting at</span>}
                    <span class="price-currency">$</span>
                    <span class="price-amount">{tier.price.toLocaleString()}</span>
                    {tier.price_label && tier.price_label !== 'starting at' && <span class="price-period">{tier.price_label}</span>}
                    {!tier.price_label && <span class="price-period">/mo</span>}
                  </>
                )}
              </div>
              <p class="svc-pricing-desc">{tier.description}</p>
              <ul class="svc-pricing-features">
                {tier.features.map((f: string) => <li>{f}</li>)}
              </ul>
              <a href="/contact" class={`btn ${tier.featured ? 'btn-primary' : 'btn-outline'} btn-block`}>Get Started</a>
            </div>
          ))}
        </div>
        {service.pricing?.setup_fee && <p class="setup-note">One-time setup fee: ${service.pricing.setup_fee.toLocaleString()}</p>}
      </div>
    </section>
  )}

  {service.pricing?.quote_based && (
    <section class="svc-section">
      <div class="container" style="max-width: 600px; text-align: center;">
        <span class="section-eyebrow">Custom Pricing</span>
        <h2>{displayName} Pricing</h2>
        <p style="color: var(--color-text-light); margin-bottom: var(--space-xl);">{service.pricing.description}</p>
        <a href="/contact" class="btn btn-primary btn-lg">Request a Custom Quote</a>
      </div>
    </section>
  )}

  <!-- ===== 10-DAY BOOST — Local SEO Only ===== -->
  {isLocalSEO && (
    <section class="svc-section svc-dark">
      <div class="container boost-grid">
        <div class="boost-content">
          <span class="section-eyebrow" style="color: var(--color-primary);">Limited Offer</span>
          <h2 style="color: var(--color-white);">Free 10-Day Local SEO Boost</h2>
          <p style="color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: var(--space-lg);">We will optimize your Google Business Profile, fix your citations, and boost your local signals for 10 days. No charge. No commitment.</p>
          <a href="/contact?service=10-day-boost" class="btn btn-primary">Apply for Free Boost</a>
        </div>
        <div class="boost-stats">
          <div class="boost-stat"><span class="boost-stat-val">+47%</span><span class="boost-stat-desc">Search Appearances</span></div>
          <div class="boost-stat"><span class="boost-stat-val">+23%</span><span class="boost-stat-desc">Discovery Searches</span></div>
          <div class="boost-stat"><span class="boost-stat-val">+15%</span><span class="boost-stat-desc">Direction Requests</span></div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== SPECTRUM — PPC & TV ===== -->
  {(isPPC || isTV) && (
    <section class="svc-section">
      <div class="container" style="text-align: center;">
        <span class="section-eyebrow">Exclusive Partnership</span>
        <h2>Powered by Spectrum Reach</h2>
        <p style="color: var(--color-text-light); max-width: 600px; margin: 0 auto var(--space-xl);">Your campaigns run across Google AND Yahoo, powered by first-party data from 30M+ households.</p>
        <StatBar stats={[
          { value: '30M+', label: 'Households' },
          { value: 'Google + Yahoo', label: 'Multi-Platform' },
          { value: '36', label: 'States' },
          { value: '$0', label: 'Agency Fee' },
        ]} variant="light" />
      </div>
    </section>
  )}

  <!-- ===== FINAL CTA ===== -->
  <HandwrittenCTA
    heading={`Ready to Get Started with ${displayName}?`}
    buttonText="Schedule Your Strategy Call"
    annotation="No obligation. Just a quick call."
  />

  <ReviewsSection compact={true} maxReviews={3} />
  <Footer slot="footer" />
</Base>

<style>
  /* ===== HERO ===== */
  .svc-hero {
    min-height: 70vh;
    display: flex;
    align-items: center;
    background: var(--color-dark);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
    padding: var(--space-4xl) 0;
  }
  .svc-hero-texture {
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.02) 10px, rgba(255,255,255,0.02) 11px),
      radial-gradient(circle at 20% 80%, rgba(192,57,43,0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(192,57,43,0.08) 0%, transparent 40%);
    pointer-events: none;
  }
  .svc-hero-inner {
    position: relative; z-index: 1;
