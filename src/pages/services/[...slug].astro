  .svc-prose :global(h3) { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.75rem; }
  .svc-prose :global(p) { font-size: 1rem; line-height: 1.7; color: rgba(0,0,0,0.65); margin-bottom: 1rem; }
  .svc-prose :global(ul), .svc-prose :global(ol) { margin-bottom: 1rem; padding-left: 1.25rem; }
  .svc-prose :global(li) { font-size: 0.95rem; line-height: 1.6; color: rgba(0,0,0,0.65); margin-bottom: 0.5rem; }
  .svc-prose--light :global(h2), .svc-prose--light :global(h3) { color: #fff; }
  .svc-prose--light :global(p), .svc-prose--light :global(li) { color: var(--svc-text-body); }
  @media (max-width: 900px) {
    .svc-split { grid-template-columns: 1fr; }
    .svc-split--reverse { direction: ltr; }
