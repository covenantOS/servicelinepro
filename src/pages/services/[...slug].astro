---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import LeadMagnet from '../../components/LeadMagnet.astro';
import config from '../../lib/config';
import { renderMarkdown, splitMarkdownSections } from '../../lib/markdown';
import InlineTestimonial from '../../components/InlineTestimonial.astro';
import QualifierBlock from '../../components/QualifierBlock.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  const paths: any[] = [];

  for (const service of config.services) {
    // Main service page: /services/local-seo/
    paths.push({
      params: { slug: service.slug },
      props: { service, type: 'service' },
    });

    // Sub-service pages: /services/ppc/google-ads/
    if (service.sub_services) {
      for (const sub of service.sub_services) {
        paths.push({
          params: { slug: `${service.slug}/${sub.slug}` },
          props: { service, subService: sub, type: 'sub-service' },
        });
      }
    }
  }

  return paths;
}

const { service, subService, type } = Astro.props;

let content = '';
let frontmatter: any = {};

function loadContent(dir: string, slug: string) {
  const filePath = path.resolve(`./src/content/${dir}/${slug}.md`);
  if (fs.existsSync(filePath)) {
    const raw = fs.readFileSync(filePath, 'utf8');
    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    if (fmMatch) {
      frontmatter = YAML.parse(fmMatch[1]);
      content = fmMatch[2];
    } else {
      content = raw;
    }
  }
}

if (type === 'sub-service' && subService) {
  loadContent('services', `${service.slug}-${subService.slug}`);
  if (!content) loadContent('services', subService.slug);
} else {
  loadContent('services', service.slug);
}

const displayName = type === 'sub-service' && subService ? subService.name : service.name;
const displayDesc = type === 'sub-service' && subService ? (subService.short_description || service.short_description) : service.short_description;

const pageTitle = frontmatter.title || `${displayName} for Home Service Businesses`;
const pageDescription = frontmatter.description || `${displayDesc} ${config.business.name} delivers performance-driven results.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
];

if (type === 'sub-service' && subService) {
  breadcrumbItems.push({ label: service.name, href: `/services/${service.slug}/` });
  breadcrumbItems.push({ label: subService.name });
} else {
  breadcrumbItems.push({ label: service.name });
}

const pricingTiers = service.pricing?.tiers || [];
const faqQuestions = frontmatter.faq || [];
const processSteps = frontmatter.process_steps || [];

const isLocalSEO = service.slug === 'local-seo';
const isPPC = service.slug === 'ppc';
const isTV = service.slug === 'tv-streaming-advertising';

// Find relevant case studies for this service - prioritize Isaac & Mark (remodeling)
const allServiceCases = config.case_studies.filter(cs => {
  const cat = cs.category.toLowerCase();
  if (service.slug === 'local-seo') return cat.includes('seo');
  if (service.slug === 'ppc') return cat.includes('ads') || cat.includes('ppc');
  if (service.slug === 'website-design') return cat.includes('design') || cat.includes('website');
  return false;
});
// Put Isaac & Mark (slug: remodeling) first if present
const serviceCaseStudies = allServiceCases.sort((a, b) => {
  if (a.slug === 'remodeling') return -1;
  if (b.slug === 'remodeling') return 1;
  return 0;
});

// Split content into sections for CRO module injection
const contentSections = content ? splitMarkdownSections(content) : [];

// Find a review to use as inline testimonial
const inlineReview = config.reviews?.[0];

// Qualifier data per service
const qualifiers: Record<string, { good: string[]; not: string[] }> = {
  'local-seo': {
    good: [
      'You have a physical Google Business Profile',
      'You want more phone calls from local searches',
      'You have 15+ Google reviews and a 4.5+ rating',
      'You generate $1M+ in annual revenue',
      'You want a marketing partner, not a vendor',
    ],
    not: [
      'You need leads by tomorrow (try Google Ads instead)',
      'You have no physical business location',
      'You serve customers nationwide, not locally',
      'You want to do it all yourself with no help',
    ],
  },
  'ppc': {
    good: [
      'You want leads within 48 hours of launch',
      'You can invest $5K+/month in ad spend',
      'You want $0 agency fees on your campaigns',
      'You want ads across Google, Bing, AND Yahoo',
      'You want first-party data targeting, not guesswork',
    ],
    not: [
      'Your monthly ad budget is under $2,000',
      'You want to manage campaigns yourself',
      'You only want organic traffic, not paid',
    ],
  },
  'website-design': {
    good: [
      'Your current site takes more than 3 seconds to load',
      'Your site looks good but does not generate calls',
      'You want a site you own, not one held hostage',
      'You want sub-2-second load times and mobile-first design',
      'You want to pay monthly instead of a big lump sum',
    ],
    not: [
      'You just need a basic landing page',
      'You want to build it yourself on Wix or Squarespace',
      'You do not have an established service business yet',
    ],
  },
  'tv-streaming-advertising': {
    good: [
      'You want to build brand awareness beyond search',
      'You want professional video production at no extra cost',
      'You are ready to reach 30M+ households across 36 states',
      'You want TV, streaming, AND connected TV coverage',
      'You want full attribution and reporting on every dollar',
    ],
    not: [
      'You only want search-based leads',
      'Your total marketing budget is under $3,000/month',
      'You already have a TV production team and media buyer',
    ],
  },
};
const qualifier = qualifiers[service.slug];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: displayName,
  description: pageDescription,
  provider: {
    '@type': 'ProfessionalService',
    name: config.business.name,
  },
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <section class="service-hero">
    <div class="hero-bg-pattern"></div>
    <div class="container service-hero-inner">
      <div class="hero-text">
        <Breadcrumbs items={breadcrumbItems} />
        {isTV && <span class="hero-partner-badge">Spectrum Reach Partner</span>}
        {isPPC && <span class="hero-partner-badge">$0 Agency Fee on $5K+ Spend</span>}
        {isLocalSEO && <span class="hero-partner-badge">Map Pack Guarantee</span>}
        <h1>{pageTitle}</h1>
        <p class="service-hero-desc">{displayDesc}</p>
        <div class="service-hero-ctas">
          <a href="/contact" class="btn btn-primary">Get Your Free Strategy Call</a>
          <a href="/pricing/" class="btn btn-outline">View Pricing</a>
        </div>
        {/* Always show Isaac & Mark first, then service-specific results */}
        {(() => {
          const isaacMark = config.case_studies.find(cs => cs.slug === 'remodeling');
          const others = serviceCaseStudies.filter(cs => cs.slug !== 'remodeling').slice(0, 2);
          const heroResults = isaacMark ? [isaacMark, ...others] : serviceCaseStudies.slice(0, 3);
          return heroResults.length > 0 ? (
            <div class="hero-results-strip">
              {heroResults.map(cs => (
                <div class="hero-result-chip">
                  <span class="hero-result-value">{cs.result}</span>
                  <span class="hero-result-client">{cs.title}</span>
                </div>
              ))}
            </div>
          ) : null;
        })()}
      </div>
      <div class="hero-visual">
        {isLocalSEO && <img src="/media/local-seo-graphic.webp" alt="Local SEO results dashboard" width="520" height="400" />}
        {isPPC && <img src="/media/ppc-graphic.webp" alt="PPC campaign performance" width="520" height="400" />}
        {isTV && <img src="/media/seo-ppc-presentation.webp" alt="TV & streaming advertising" width="520" height="400" />}
        {!isLocalSEO && !isPPC && !isTV && <img src="/media/service-presentation.webp" alt={`${displayName} services`} width="520" height="400" />}
      </div>
    </div>
  </section>

  {/* === FULL-WIDTH CONTENT SECTIONS — NO SIDEBAR === */}

  {/* Qualifier Block - full width */}
  {qualifier && (
    <section class="fw-section">
      <div class="container">
        <QualifierBlock goodFit={qualifier.good} notFit={qualifier.not} />
      </div>
    </section>
  )}

  {/* Content sections rendered as full-width alternating modules */}
  {contentSections.length > 0 ? (
    contentSections.map((section, i) => (
      <>
        <section class={`fw-section ${i % 3 === 1 ? 'fw-alt' : ''} ${i % 5 === 3 ? 'fw-dark' : ''} ${i % 7 === 5 ? 'fw-accent' : ''}`}>
          <div class="container fw-narrow">
            <div class="prose" set:html={section.html} />
          </div>
        </section>

        {/* CRO modules as their own full-width sections */}
        {i === 0 && inlineReview && (
          <section class="fw-section fw-alt">
            <div class="container fw-narrow">
              <InlineTestimonial
                quote={inlineReview.text}
                author={inlineReview.author}
                company={inlineReview.company}
                rating={inlineReview.rating}
              />
            </div>
          </section>
        )}

        {i === 1 && (
          <section class="fw-section fw-dark fw-cta-band">
            <div class="container">
              <div class="mid-cta-inner">
                <div class="mid-cta-text">
                  <h3>{isLocalSEO ? '10 Days Free. No Credit Card.' : isPPC ? '$0 Agency Fee on $5K+ Spend' : isTV ? 'Free Video Production Included' : 'Get Started Today'}</h3>
                  <p>{isLocalSEO ? 'We boost your Google Business Profile for 10 days at zero cost. Keep every improvement even if you walk away.' : isPPC ? '100% of your ad budget funds your campaign. We get paid through our Spectrum Reach partnership.' : isTV ? 'Every TV and streaming campaign includes professional video production at no extra charge.' : 'Book a 15-minute strategy call. No pressure, no pitch deck.'}</p>
                </div>
                <a href="/contact" class="btn btn-primary">{isLocalSEO ? 'Apply for Free Boost' : 'Get Your Free Strategy Call'}</a>
              </div>
            </div>
          </section>
        )}

        {i === 2 && serviceCaseStudies.length > 0 && (
          <section class="fw-section fw-dark">
            <div class="container">
              <span class="section-label section-label-light">Proven Results</span>
              <h2 class="fw-heading-light">Real {displayName} Results</h2>
              <div class="inline-cases-grid">
                {serviceCaseStudies.slice(0, 3).map(cs => (
                  <a href={`/case-studies/${cs.slug}/`} class="inline-case-card inline-case-dark">
                    {cs.image && (
                      <div class="inline-case-img">
                        <img src={`/media/case-studies/${cs.image}`} alt={cs.title} loading="lazy" width="400" height="225" />
                      </div>
                    )}
                    <div class="inline-case-body">
                      <span class="inline-case-tag">{cs.category}</span>
                      <h3>{cs.metrics?.primary || cs.result}</h3>
                      <span class="inline-case-client">{cs.title}</span>
                      <span class="card-link">Read Case Study &rarr;</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </section>
        )}

        {i === 3 && type === 'service' && (
          <section class="fw-section fw-alt">
            <div class="container fw-narrow">
              <ComparisonTable />
            </div>
          </section>
        )}

        {i === 4 && config.reviews?.[1] && (
          <section class="fw-section">
            <div class="container fw-narrow">
              <InlineTestimonial
                quote={config.reviews[1].text}
                author={config.reviews[1].author}
                company={config.reviews[1].company}
                rating={config.reviews[1].rating}
              />
            </div>
          </section>
        )}

        {i === 6 && (
          <section class="fw-section fw-dark fw-cta-band">
            <div class="container">
              <div class="mid-cta-inner">
                <div class="mid-cta-text">
                  <h3>Ready to Talk?</h3>
                  <p>15-minute strategy call. We analyze your market, identify the gaps, and show you the plan. No pressure.</p>
                </div>
                <a href="/contact" class="btn btn-primary">Book Your Free Call</a>
              </div>
            </div>
          </section>
        )}
      </>
    ))
  ) : (
    <section class="fw-section">
      <div class="container fw-narrow">
        <div class="prose">
          <h2>{displayName}</h2>
          <p>{config.business.name} provides {displayName.toLowerCase()} services designed to grow home service businesses.</p>
        </div>
      </div>
    </section>
  )}

  {/* Sub-service cards - full width */}
  {type === 'service' && service.sub_services && service.sub_services.length > 0 && (
    <section class="fw-section fw-alt">
      <div class="container">
        <span class="section-label">{service.name} Specializations</span>
        <h2>{service.name} Services</h2>
        <div class="sub-services-grid">
          {service.sub_services.map((sub: any) => (
            <a href={`/services/${service.slug}/${sub.slug}/`} class="sub-service-card card">
              <div class="sub-service-body">
                <h3>{sub.name}</h3>
                <p>{sub.short_description}</p>
                <span class="card-link">Learn More &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Process Steps - full width */}
  {processSteps.length > 0 && (
    <section class="fw-section">
      <div class="container">
        <span class="section-label">How It Works</span>
        <h2>Your {displayName} Journey</h2>
        <div class="process-timeline">
          {processSteps.map((step: any, i: number) => (
            <div class="timeline-step">
              <div class="timeline-marker">
                <div class="timeline-number">{i + 1}</div>
                {i < processSteps.length - 1 && <div class="timeline-line"></div>}
              </div>
              <div class="timeline-content">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Industries - full width dark */}
  <section class="fw-section fw-dark">
    <div class="container">
      <span class="section-label section-label-light">Who We Work With</span>
      <h2 class="fw-heading-light">Industries We Serve with {displayName}</h2>
      <div class="industries-chip-grid">
        {config.industries.slice(0, 12).map(ind => (
          <a href={`/industries/${ind.slug}/${service.slug}/`} class="industry-chip">{ind.full_name}</a>
        ))}
      </div>
      <a href="/industries/" class="see-all-link-light">See All {config.industries.length} Industries &rarr;</a>
    </div>
  </section>

  {/* FAQ - full width */}
  {faqQuestions.length > 0 && (
    <section class="fw-section fw-alt">
      <div class="container fw-narrow">
        <span class="section-label">Common Questions</span>
        <h2>Frequently Asked Questions About {displayName}</h2>
        <div class="faq-grid">
          {faqQuestions.map((q: any) => (
            <details class="faq-item">
              <summary>{q.question}</summary>
              <div class="faq-answer" set:html={renderMarkdown(q.answer)} />
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Pricing - full width section */}
  {pricingTiers.length > 0 && (
    <section class="pricing-section section section-alt">
      <div class="container">
        <span class="section-label">{isLocalSEO ? 'Map Pack Guarantee' : 'Transparent Pricing'}</span>
        <h2>{displayName} Pricing</h2>
        <div class="pricing-grid">
          {pricingTiers.map((tier: any) => (
            <div class={`pricing-card ${tier.featured ? 'pricing-featured' : ''}`}>
              {tier.featured && <div class="pricing-badge">Most Popular</div>}
              <h3>{tier.name}</h3>
              <div class="pricing-price">
                {tier.price === 0 ? (
                  <span class="price-amount">{tier.price_label || 'Custom'}</span>
                ) : (
                  <>
                    {tier.price_label === 'starting at' && <span class="price-label">Starting at</span>}
                    <span class="price-currency">$</span>
                    <span class="price-amount">{tier.price.toLocaleString()}</span>
                    {tier.price_label && tier.price_label !== 'starting at' && <span class="price-period">{tier.price_label}</span>}
                    {!tier.price_label && <span class="price-period">/mo</span>}
                  </>
                )}
              </div>
              <p class="pricing-desc">{tier.description}</p>
              <ul class="pricing-features">
                {tier.features.map((f: string) => (
                  <li>{f}</li>
                ))}
              </ul>
              <a href="/contact" class={`btn ${tier.featured ? 'btn-primary' : 'btn-outline'} btn-block`}>Get Started</a>
            </div>
          ))}
        </div>
        {service.pricing?.setup_fee && (
          <p class="setup-note">One-time setup fee: ${service.pricing.setup_fee.toLocaleString()}</p>
        )}
      </div>
    </section>
  )}

  {/* Quote-based pricing - full width */}
  {service.pricing?.quote_based && (
    <section class="pricing-section section section-alt">
      <div class="container" style="max-width: 600px; text-align: center;">
        <span class="section-label">Custom Pricing</span>
        <h2>{displayName} Pricing</h2>
        <p style="color: var(--color-text-light); margin-bottom: var(--space-xl);">{service.pricing.description}</p>
        <a href="/contact" class="btn btn-primary btn-lg">Request a Custom Quote</a>
      </div>
    </section>
  )}

  {/* Free 10-Day Boost - Local SEO only */}
  {isLocalSEO && (
    <section class="boost-band section-dark">
      <div class="boost-band-pattern"></div>
      <div class="container boost-band-grid">
        <div class="boost-band-content">
          <span class="boost-band-label">Limited Offer</span>
          <h2>Free 10-Day Local SEO Boost</h2>
          <p>We will optimize your Google Business Profile, fix your citations, and boost your local signals for 10 days. No charge. No commitment. If you see results, we talk.</p>
          <div class="boost-band-reqs">
            <span>Requirements:</span>
            <ul>
              <li>Physical Google Business Profile</li>
              <li>15+ existing Google reviews</li>
              <li>4.5+ star rating</li>
              <li>Existing website</li>
            </ul>
          </div>
          <a href="/contact?service=10-day-boost" class="btn btn-primary">Apply for Free Boost &rarr;</a>
        </div>
        <div class="boost-band-stats">
          <div class="boost-stat">
            <span class="boost-stat-val">+47%</span>
            <span class="boost-stat-desc">Search Appearances</span>
          </div>
          <div class="boost-stat">
            <span class="boost-stat-val">+23%</span>
            <span class="boost-stat-desc">Discovery Searches</span>
          </div>
          <div class="boost-stat">
            <span class="boost-stat-val">+15%</span>
            <span class="boost-stat-desc">Direction Requests</span>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* Spectrum Partnership callout - PPC and TV pages */}
  {(isPPC || isTV) && (
    <section class="spectrum-band section">
      <div class="container spectrum-band-inner">
        <span class="section-label">Exclusive Partnership</span>
        <h2>Powered by Spectrum Reach</h2>
        <p class="spectrum-desc">Your campaigns run across Google AND Yahoo, powered by first-party data from 30M+ households. Not just search. TV, streaming, display, and connected devices.</p>
        <div class="spectrum-band-grid">
          <div class="spectrum-band-stat">
            <span class="spectrum-num">30M+</span>
            <span>Households of First-Party Data</span>
          </div>
          <div class="spectrum-band-stat">
            <span class="spectrum-num">Google + Yahoo</span>
            <span>Multi-Platform Search Coverage</span>
          </div>
          <div class="spectrum-band-stat">
            <span class="spectrum-num">36</span>
            <span>States Covered</span>
          </div>
          <div class="spectrum-band-stat">
            <span class="spectrum-num">$0</span>
            <span>Agency Fee on $5K+ Spend</span>
          </div>
        </div>
      </div>
    </section>
  )}

  <CTABand heading={`Ready to Get Started with ${displayName}?`} />
  <ReviewsSection compact={true} maxReviews={3} />
  <Footer slot="footer" />
</Base>

<style>
  .service-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .hero-bg-pattern {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(192,57,43,0.12) 0%, transparent 45%),
      radial-gradient(circle at 80% 20%, rgba(192,57,43,0.06) 0%, transparent 35%);
    pointer-events: none;
  }
  .service-hero-inner {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr; gap: var(--space-xl); align-items: center;
  }
  @media (min-width: 1024px) {
    .service-hero-inner { grid-template-columns: 1.1fr 0.9fr; }
  }
  .hero-visual {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-visual { display: block; }
  }
  .hero-visual img {
    width: 100%; height: auto; border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }

  .hero-partner-badge {
    display: inline-block; font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--color-primary); background: rgba(192,57,43,0.15);
    padding: 0.25rem 0.75rem; border-radius: 4px; margin-bottom: var(--space-md);
  }

  .service-hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
    max-width: 700px;
  }

  .service-hero-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-lg);
    max-width: 600px;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .service-hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .service-hero .btn-outline {
    border-color: rgba(255,255,255,0.3);
    color: var(--color-white);
  }
  .service-hero .btn-outline:hover {
    background: var(--color-white);
    color: var(--color-dark);
    border-color: var(--color-white);
  }

  .hero-results-strip {
    display: flex; gap: var(--space-xl); margin-top: var(--space-xl);
    padding-top: var(--space-lg); border-top: 1px solid rgba(255,255,255,0.08);
  }
  .hero-result-chip { display: flex; flex-direction: column; }
  .hero-result-value { font-family: var(--font-heading); font-size: var(--text-base); font-weight: 700; color: var(--color-primary); }
  .hero-result-client { font-size: 0.7rem; color: rgba(255,255,255,0.4); }

  /* === FULL-WIDTH SECTION SYSTEM === */
  .fw-section {
    padding: var(--space-3xl) 0;
  }
  .fw-alt {
    background: var(--color-gray-100);
  }
  .fw-dark {
    background: var(--color-dark);
    color: var(--color-white);
  }
  .fw-dark h2, .fw-dark h3, .fw-dark h4 { color: var(--color-white); }
  .fw-dark h2::before { background: var(--color-primary); }
  .fw-dark p, .fw-dark li { color: rgba(255,255,255,0.7); }
