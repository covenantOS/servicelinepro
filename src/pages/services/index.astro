---
import Base from '../../layouts/Base.astro';
import config from '../../lib/config';
---

<Base title="Our Services" description="Local SEO, PPC, website design, and TV/streaming advertising services from ServiceLine Pro.">

<section class="section" style="padding-top: 5rem;">
  <div class="container">
    <div class="fade-in" style="text-align: center; margin-bottom: 3.5rem;">
      <span class="section-label">Our Services</span>
      <h1>Marketing That <span class="gradient-text--red">Generates Revenue</span></h1>
      <p class="section-subtitle" style="margin: 1rem auto 0;">Every service is built around one metric: the dollars that land in your account. No vanity metrics. No fluff.</p>
    </div>

    <div class="services-list stagger">
      {config.services.map((service, i) => (
        <a href={`/services/${service.slug}/`} class="service-row fade-in" style="text-decoration: none;">
          <div class="service-row__number">0{i + 1}</div>
          <div class="service-row__content">
            <h2 class="service-row__title">{service.name}</h2>
            <p class="service-row__desc">{service.short_description}</p>
          </div>
          <div class="service-row__arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Not Sure Which Service is Right?</h2>
    <p style="margin-bottom: 2rem; font-size: 1.05rem;">Our team will audit your current marketing and recommend the exact combination of services to hit your revenue goals.</p>
    <a href="/contact/" class="btn btn--lime btn--lg">Get Your Free Strategy Call</a>
  </div>
</section>

</Base>

<style>
.services-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.service-row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 2rem;
  align-items: center;
  padding: 2rem 1.5rem;
  background: var(--dark-2);
  border: 1px solid var(--dark-4);
  border-radius: var(--radius-md);
  transition: all var(--transition-med);
  margin-bottom: 0.75rem;
}
.service-row:hover {
  border-color: var(--gray-700);
  transform: translateX(8px);
}
.service-row__number {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 2.5rem;
  color: var(--dark-4);
  min-width: 60px;
  transition: color var(--transition-fast);
}
.service-row:hover .service-row__number { color: var(--red); }
.service-row__title {
  font-size: 1.35rem;
  color: var(--white);
  margin-bottom: 0.35rem;
}
.service-row__desc {
  font-size: 0.9rem;
  color: var(--gray-400);
  line-height: 1.5;
}
.service-row__arrow {
  color: var(--gray-600);
  transition: all var(--transition-fast);
}
.service-row:hover .service-row__arrow {
  color: var(--lime);
  transform: translateX(4px);
}
@media (max-width: 640px) {
  .service-row { grid-template-columns: 1fr; gap: 0.75rem; }
  .service-row__number { font-size: 1.5rem; }
  .service-row__arrow { display: none; }
}
</style>
