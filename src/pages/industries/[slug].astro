---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import LeadMagnet from '../../components/LeadMagnet.astro';
import config from '../../lib/config';
import { renderMarkdown } from '../../lib/markdown';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  return config.industries.map(industry => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;

let content = '';
let frontmatter: any = {};

const filePath = path.resolve(`./src/content/industries/${industry.slug}.md`);
if (fs.existsSync(filePath)) {
  const raw = fs.readFileSync(filePath, 'utf8');
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (fmMatch) {
    frontmatter = YAML.parse(fmMatch[1]);
    content = fmMatch[2];
  } else {
    content = raw;
  }
}

const pageTitle = frontmatter.title || `Marketing for ${industry.full_name}`;
const pageDescription = frontmatter.description || `${config.business.name} provides local SEO, Google Ads, and website design for ${industry.full_name.toLowerCase()}. Scale your ${industry.name.toLowerCase()} business with performance-driven marketing.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Who We Work With', href: '/industries/' },
  { label: industry.full_name },
];

const faqQuestions = frontmatter.faq || [];

// Find case studies matching this industry
const industryCases = config.case_studies.filter(cs =>
  cs.industry && cs.industry.toLowerCase().includes(industry.name.toLowerCase().split('/')[0].trim().toLowerCase())
).slice(0, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: config.business.name,
  description: pageDescription,
  url: `https://${config.seo.domain}/industries/${industry.slug}/`,
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <section class="industry-hero">
    <div class="industry-hero-bg"></div>
    <div class="container industry-hero-inner">
      <Breadcrumbs items={breadcrumbItems} />
      <div class="industry-hero-badge">{industry.name} Marketing</div>
      <h1>{pageTitle}</h1>
      <p class="industry-hero-desc">{industry.description}</p>
      <div class="industry-hero-ctas">
        <a href="/contact" class="btn btn-primary">Get Your Free Strategy Call</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn-outline">{config.business.phone}</a>
      </div>
    </div>
  </section>

  <section class="industry-content section">
    <div class="container content-layout">
      <div class="main-content">
        {content ? (
          <div class="prose" set:html={renderMarkdown(content)} />
        ) : (
          <div class="prose">
            <h2>Digital Marketing Built for {industry.full_name}</h2>
            <p>{config.business.name} specializes in performance-driven marketing for {industry.full_name.toLowerCase()}. We understand the unique challenges of your industry and build campaigns that generate real leads, not vanity metrics.</p>
          </div>
        )}

        {/* Mid-content CTA */}
        <div class="mid-cta-module">
          <div class="mid-cta-inner">
            <div class="mid-cta-text">
              <h3>Ready to Grow Your {industry.name} Business?</h3>
              <p>Free 15-minute strategy call. We analyze your market, your competition, and show you where the opportunities are.</p>
            </div>
            <a href="/contact" class="btn btn-primary">Free Strategy Call</a>
          </div>
        </div>

        {/* Lead Magnet */}
        <LeadMagnet variant="inline" />

        {/* Areas served */}
        <div class="industry-areas">
          <h2>{industry.name} Marketing Across the United States</h2>
          <div class="industry-areas-grid">
            {config.areas.slice(0, 10).map(a => (
              <a href={`/areas/${a.slug}/`} class="industry-area-link">{a.name}</a>
            ))}
          </div>
          <a href="/areas/" class="see-all-link">See All {config.areas.length} Areas &rarr;</a>
        </div>

        {faqQuestions.length > 0 && (
          <div class="faq-section">
            <h2>Frequently Asked Questions About {industry.name} Marketing</h2>
            {faqQuestions.map((q: any) => (
              <details class="faq-item">
                <summary>{q.question}</summary>
                <div class="faq-answer" set:html={renderMarkdown(q.answer)} />
              </details>
            ))}
          </div>
        )}
      </div>

      <Sidebar currentIndustry={industry.slug} />
    </div>
  </section>

  {/* Services for this industry - full width module */}
  <section class="industry-services-section section section-alt">
    <div class="container">
      <span class="section-label">{industry.name} Solutions</span>
      <h2>Our Services for {industry.full_name}</h2>
      <div class="industry-services-grid-fw">
        {config.services.map(service => (
          <a href={`/industries/${industry.slug}/${service.slug}/`} class="industry-service-card-fw">
            <div class="isvc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <h3>{service.name} for {industry.full_name}</h3>
            <p>{service.short_description.split('.')[0]}.</p>
            <span class="card-link">Learn More &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Case Studies for this industry */}
  {industryCases.length > 0 && (
    <section class="industry-cases-section section section-dark">
      <div class="container">
        <span class="section-label section-label-light">{industry.name} Results</span>
        <h2>Real Results for {industry.full_name}</h2>
        <div class="industry-cases-grid-fw">
          {industryCases.map(cs => (
            <a href={`/case-studies/${cs.slug}/`} class="ind-case-card-fw">
              <span class="ind-case-tag">{cs.category}</span>
              <h3>{cs.metrics?.primary || cs.result}</h3>
              <span class="ind-case-client">{cs.title}</span>
              {cs.metrics?.secondary && <span class="ind-case-secondary">{cs.metrics.secondary}</span>}
              <span class="card-link">Read Case Study &rarr;</span>
            </a>
          ))}
        </div>
        <div style="text-align: center; margin-top: var(--space-xl);">
          <a href="/case-studies/" class="btn btn-outline-light">See All {config.case_studies.length} Case Studies &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <CTABand heading={`Ready to Dominate ${industry.name} Marketing?`} />
  <ReviewsSection compact={true} maxReviews={3} />
  <Footer slot="footer" />
</Base>

<style>
  .industry-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .industry-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 15% 85%, rgba(192,57,43,0.1) 0%, transparent 40%),
      radial-gradient(circle at 85% 15%, rgba(59,130,246,0.06) 0%, transparent 35%);
    pointer-events: none;
  }
  .industry-hero-inner { position: relative; z-index: 1; }

  .industry-hero-badge {
    display: inline-block;
    background: rgba(192,57,43,0.15);
    color: var(--color-primary);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
    border: 1px solid rgba(192,57,43,0.2);
  }

  .industry-hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
    max-width: 700px;
  }

  .industry-hero-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-lg);
    max-width: 600px;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .industry-hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .industry-hero .btn-outline {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .industry-hero .btn-outline:hover {
    background: var(--color-white);
    color: var(--color-dark);
  }

  .card-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
  }

  /* Mid-content CTA */
  .mid-cta-module {
    margin: var(--space-2xl) 0;
    background: var(--color-dark);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    position: relative;
    overflow: hidden;
  }
  .mid-cta-module::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 200px; height: 100%;
    background: radial-gradient(circle at 100% 50%, rgba(192,57,43,0.2) 0%, transparent 70%);
    pointer-events: none;
  }
  .mid-cta-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-lg); flex-wrap: wrap; position: relative; z-index: 1;
  }
  .mid-cta-text h3 { color: var(--color-white); font-size: var(--text-lg); margin-bottom: var(--space-xs); }
  .mid-cta-text h3::before { display: none; }
  .mid-cta-text p { color: rgba(255,255,255,0.6); font-size: var(--text-sm); margin-bottom: 0; max-width: 500px; }

  /* Full-width services section */
  .industry-services-section h2 { margin-bottom: var(--space-xl); }
  .industry-services-section h2::before { display: none; }
  .industry-services-grid-fw {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-lg);
  }
  .industry-service-card-fw {
    text-decoration: none; color: inherit;
    padding: var(--space-xl);
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-card);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .industry-service-card-fw:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .isvc-icon {
    width: 48px; height: 48px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(192,57,43,0.08); border-radius: 10px;
    color: var(--color-primary); margin-bottom: var(--space-md);
  }
  .industry-service-card-fw h3 { font-size: var(--text-lg); margin-bottom: var(--space-sm); }
  .industry-service-card-fw p { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-md); }

  /* Full-width case studies section */
  .industry-cases-section h2 { color: var(--color-white); margin-bottom: var(--space-xl); }
  .industry-cases-section h2::before { display: none; }
  .section-label-light { color: rgba(255,255,255,0.4); }
  .industry-cases-grid-fw { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: var(--space-lg); }
  .ind-case-card-fw {
    display: flex; flex-direction: column; padding: var(--space-lg);
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
    text-decoration: none; color: inherit; transition: background 0.15s;
  }
  .ind-case-card-fw:hover { background: rgba(255,255,255,0.08); }
  .ind-case-tag { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); margin-bottom: var(--space-xs); }
  .ind-case-card-fw h3 { font-size: var(--text-xl); margin-bottom: var(--space-xs); color: var(--color-white); }
  .ind-case-client { font-size: var(--text-sm); color: rgba(255,255,255,0.5); margin-bottom: 0.25rem; }
  .ind-case-secondary { font-size: var(--text-sm); color: rgba(255,255,255,0.4); margin-bottom: var(--space-sm); display: block; }
  .btn-outline-light { border: 2px solid rgba(255,255,255,0.3); color: var(--color-white); background: transparent; }
  .btn-outline-light:hover { background: var(--color-white); color: var(--color-dark); border-color: var(--color-white); }

  .see-all-link { display: inline-block; margin-top: var(--space-md); font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }

  /* Industry Areas */
  .industry-areas { margin-top: var(--space-2xl); }
  .industry-areas-grid { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
  .industry-area-link {
    display: inline-block; padding: 0.5rem 1rem;
    background: var(--color-gray-100); border-radius: 6px; font-size: var(--text-sm);
    text-decoration: none; color: var(--color-text-light);
    transition: background 0.15s, color 0.15s;
  }
  .industry-area-link:hover { background: var(--color-primary); color: var(--color-white); }

  .faq-section { margin-top: var(--space-2xl); }
  .faq-item { border: 1px solid var(--color-gray-200); border-radius: var(--radius-md); padding: var(--space-md) var(--space-lg); margin-bottom: var(--space-sm); background: var(--color-white); transition: box-shadow 0.15s; }
  .faq-item[open] { box-shadow: var(--shadow-sm); border-color: var(--color-primary); }
  .faq-item summary { font-weight: 600; cursor: pointer; font-size: var(--text-base); list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: var(--text-xl); color: var(--color-primary); font-weight: 300; flex-shrink: 0; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-answer { padding-top: var(--space-md); color: var(--color-text-light); border-top: 1px solid var(--color-gray-100); margin-top: var(--space-md); }
</style>
