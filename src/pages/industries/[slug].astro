---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import LeadMagnet from '../../components/LeadMagnet.astro';
import config from '../../lib/config';
import { renderMarkdown } from '../../lib/markdown';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  return config.industries.map(industry => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;

let content = '';
let frontmatter: any = {};

const filePath = path.resolve(`./src/content/industries/${industry.slug}.md`);
if (fs.existsSync(filePath)) {
  const raw = fs.readFileSync(filePath, 'utf8');
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (fmMatch) {
    frontmatter = YAML.parse(fmMatch[1]);
    content = fmMatch[2];
  } else {
    content = raw;
  }
}

const pageTitle = frontmatter.title || `Marketing for ${industry.full_name}`;
const pageDescription = frontmatter.description || `${config.business.name} provides local SEO, Google Ads, and website design for ${industry.full_name.toLowerCase()}. Scale your ${industry.name.toLowerCase()} business with performance-driven marketing.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Who We Work With', href: '/industries/' },
  { label: industry.full_name },
];

const faqQuestions = frontmatter.faq || [];

// Find case studies matching this industry
const industryCases = config.case_studies.filter(cs =>
  cs.industry && cs.industry.toLowerCase().includes(industry.name.toLowerCase().split('/')[0].trim().toLowerCase())
).slice(0, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: config.business.name,
  description: pageDescription,
  url: `https://${config.seo.domain}/industries/${industry.slug}/`,
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <section class="industry-hero">
    <div class="industry-hero-bg"></div>
    <div class="container industry-hero-inner">
      <Breadcrumbs items={breadcrumbItems} />
      <div class="industry-hero-badge">{industry.name} Marketing</div>
      <h1>{pageTitle}</h1>
      <p class="industry-hero-desc">{industry.description}</p>
      <div class="industry-hero-ctas">
        <a href="/contact" class="btn btn-primary">Get Your Free Strategy Call</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn-outline">{config.business.phone}</a>
      </div>
    </div>
  </section>

  <section class="industry-content section">
    <div class="container content-layout">
      <div class="main-content">
        {content ? (
          <div class="prose" set:html={renderMarkdown(content)} />
        ) : (
          <div class="prose">
            <h2>Digital Marketing Built for {industry.full_name}</h2>
            <p>{config.business.name} specializes in performance-driven marketing for {industry.full_name.toLowerCase()}. We understand the unique challenges of your industry and build campaigns that generate real leads, not vanity metrics.</p>
          </div>
        )}

        <div class="industry-services">
          <h2>Our Services for {industry.full_name}</h2>
          <div class="industry-services-grid">
            {config.services.map(service => (
              <a href={`/industries/${industry.slug}/${service.slug}/`} class="industry-service-card card">
                <div class="industry-service-body">
                  <h3>{service.name} for {industry.full_name}</h3>
                  <p>{service.short_description}</p>
                  <span class="card-link">Learn More &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        {/* Case Studies for this industry */}
        {industryCases.length > 0 && (
          <div class="industry-cases">
            <h2>{industry.name} Results</h2>
            <div class="industry-cases-grid">
              {industryCases.map(cs => (
                <a href={`/case-studies/${cs.slug}/`} class="ind-case-card">
                  <span class="ind-case-tag">{cs.category}</span>
                  <h3>{cs.metrics?.primary || cs.result}</h3>
                  <span class="ind-case-client">{cs.title}</span>
                  <span class="card-link">Read Case Study &rarr;</span>
                </a>
              ))}
            </div>
            <a href="/case-studies/" class="see-all-link">See All {config.case_studies.length} Case Studies &rarr;</a>
          </div>
        )}

        {/* Lead Magnet */}
        <LeadMagnet variant="inline" />

        {/* Areas served */}
        <div class="industry-areas">
          <h2>{industry.name} Marketing in Central Florida</h2>
          <div class="industry-areas-grid">
            {config.areas.slice(0, 10).map(a => (
              <a href={`/areas/${a.slug}/`} class="industry-area-link">{a.name}</a>
            ))}
          </div>
          <a href="/areas/" class="see-all-link">See All {config.areas.length} Areas &rarr;</a>
        </div>

        {faqQuestions.length > 0 && (
          <div class="faq-section">
            <h2>{industry.name} Marketing FAQ</h2>
            {faqQuestions.map((q: any) => (
              <details class="faq-item">
                <summary>{q.question}</summary>
                <div class="faq-answer" set:html={renderMarkdown(q.answer)} />
              </details>
            ))}
          </div>
        )}
      </div>

      <Sidebar currentIndustry={industry.slug} />
    </div>
  </section>

  <CTABand heading={`Ready to Dominate ${industry.name} Marketing?`} />
  <ReviewsSection compact={true} maxReviews={3} />
  <Footer slot="footer" />
</Base>

<style>
  .industry-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .industry-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 15% 85%, rgba(192,57,43,0.1) 0%, transparent 40%),
      radial-gradient(circle at 85% 15%, rgba(59,130,246,0.06) 0%, transparent 35%);
    pointer-events: none;
  }
  .industry-hero-inner { position: relative; z-index: 1; }

  .industry-hero-badge {
    display: inline-block;
    background: rgba(192,57,43,0.15);
    color: var(--color-primary);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
    border: 1px solid rgba(192,57,43,0.2);
  }

  .industry-hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
    max-width: 700px;
  }

  .industry-hero-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-lg);
    max-width: 600px;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .industry-hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .industry-hero .btn-outline {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .industry-hero .btn-outline:hover {
    background: var(--color-white);
    color: var(--color-dark);
  }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 1024px) {
    .content-layout {
      grid-template-columns: 1fr 300px;
    }
  }

  .industry-services {
    margin-top: var(--space-2xl);
  }

  .industry-services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .industry-service-card {
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .industry-service-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .industry-service-body {
    padding: var(--space-lg);
  }

  .industry-service-body h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }

  .industry-service-body p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-sm);
  }

  .card-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
  }

  /* Industry Case Studies */
  .industry-cases { margin-top: var(--space-2xl); }
  .industry-cases-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-md); margin-top: var(--space-lg); }
  .ind-case-card {
    display: flex; flex-direction: column; padding: var(--space-lg);
    background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 10px;
    text-decoration: none; color: inherit; transition: transform 0.15s, box-shadow 0.15s;
  }
  .ind-case-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .ind-case-tag { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); margin-bottom: var(--space-xs); }
  .ind-case-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-xs); }
  .ind-case-client { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-sm); }
  .see-all-link { display: inline-block; margin-top: var(--space-md); font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }

  /* Industry Areas */
  .industry-areas { margin-top: var(--space-2xl); }
  .industry-areas-grid { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
  .industry-area-link {
    display: inline-block; padding: 0.5rem 1rem;
    background: var(--color-gray-100); border-radius: 6px; font-size: var(--text-sm);
    text-decoration: none; color: var(--color-text-light);
    transition: background 0.15s, color 0.15s;
  }
  .industry-area-link:hover { background: var(--color-primary); color: var(--color-white); }

  .faq-section {
    margin-top: var(--space-2xl);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-gray-200);
    padding: var(--space-md) 0;
  }

  .faq-item summary {
    font-weight: 600;
    cursor: pointer;
    font-size: var(--text-base);
  }

  .faq-answer {
    padding-top: var(--space-sm);
    color: var(--color-text-light);
  }
</style>
