---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ReviewsSection from '../../../components/ReviewsSection.astro';
import CTABand from '../../../components/CTABand.astro';
import Footer from '../../../components/Footer.astro';
import Sidebar from '../../../components/Sidebar.astro';
import LeadMagnet from '../../../components/LeadMagnet.astro';
import config from '../../../lib/config';
import { renderMarkdown } from '../../../lib/markdown';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const industry of config.industries) {
    for (const service of config.services) {
      paths.push({
        params: { industry: industry.slug, service: service.slug },
        props: { industry, service },
      });
    }
  }
  return paths;
}

const { industry, service } = Astro.props;

let content = '';
let frontmatter: any = {};

const filePath = path.resolve(`./src/content/industry-services/${industry.slug}-${service.slug}.md`);
if (fs.existsSync(filePath)) {
  const raw = fs.readFileSync(filePath, 'utf8');
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (fmMatch) {
    frontmatter = YAML.parse(fmMatch[1]);
    content = fmMatch[2];
  } else {
    content = raw;
  }
}

const pageTitle = frontmatter.title || `${service.name} for ${industry.full_name}`;
const pageDescription = frontmatter.description || `${service.name} services designed specifically for ${industry.full_name.toLowerCase()}. ${config.business.name} delivers results-driven ${service.name.toLowerCase()} campaigns that generate real leads.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Industries', href: '/industries/' },
  { label: industry.full_name, href: `/industries/${industry.slug}/` },
  { label: `${service.name}` },
];

const faqQuestions = frontmatter.faq || [];
const pricingTiers = service.pricing?.tiers || [];

// Find case studies matching this service category or industry
const serviceKeyword = service.name.toLowerCase().split(' ')[0];
const industryKeyword = industry.name.toLowerCase().split('/')[0].trim();
const relevantCases = config.case_studies.filter(cs =>
  cs.category.toLowerCase().includes(serviceKeyword) ||
  (cs.industry && cs.industry.toLowerCase().includes(industryKeyword))
).slice(0, 4);

// Other services for this industry (cross-links)
const otherServices = config.services.filter(s => s.slug !== service.slug);

// Other industries for this service (cross-links)
const otherIndustries = config.industries.filter(i => i.slug !== industry.slug).slice(0, 8);

// Nearby areas for internal linking
const topAreas = config.areas.slice(0, 6);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.name} for ${industry.full_name}`,
  description: pageDescription,
  provider: {
    '@type': 'ProfessionalService',
    name: config.business.name,
  },
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <section class="combo-hero">
    <div class="combo-hero-bg"></div>
    <div class="container combo-hero-inner">
      <Breadcrumbs items={breadcrumbItems} />
      <div class="combo-badges">
        <span class="badge badge-industry">{industry.name}</span>
        <span class="badge badge-service">{service.name}</span>
      </div>
      <h1>{pageTitle}</h1>
      <p class="combo-hero-desc">{pageDescription}</p>
      <div class="combo-hero-ctas">
        <a href="/contact" class="btn btn-primary">Get Your Free Strategy Call</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn-outline">{config.business.phone}</a>
      </div>
    </div>
  </section>

  <section class="combo-content section">
    <div class="container content-layout">
      <div class="main-content">
        {content ? (
          <div class="prose" set:html={renderMarkdown(content)} />
        ) : (
          <div class="prose">
            <h2>{service.name} Built for the {industry.name} Industry</h2>
            <p>{config.business.name} delivers {service.name.toLowerCase()} campaigns designed specifically for {industry.full_name.toLowerCase()}. We understand how {industry.name.toLowerCase()} customers search, what triggers them to call, and how to position your business as the obvious choice.</p>
            <p>Every {industry.name.toLowerCase()} company has a different competitive landscape. Your <a href={`/services/${service.slug}/`}>{service.name.toLowerCase()} strategy</a> needs to account for seasonal demand, local search patterns, and the specific language your customers use when they need your services.</p>
            <p>We have worked with <a href={`/industries/${industry.slug}/`}>{industry.full_name.toLowerCase()}</a> across Central Florida and know what moves the needle. No cookie-cutter campaigns. No vanity metrics. Just leads that turn into revenue.</p>
          </div>
        )}

        {/* Case Studies */}
        {relevantCases.length > 0 && (
          <div class="combo-cases">
            <h2>{service.name} Results in {industry.name}</h2>
            <div class="combo-cases-grid">
              {relevantCases.map(cs => (
                <a href={`/case-studies/${cs.slug}/`} class="combo-case-card">
                  <span class="combo-case-tag">{cs.category}</span>
                  <h3>{cs.metrics?.primary || cs.result}</h3>
                  <span class="combo-case-client">{cs.title}</span>
                  <span class="card-link">Read Case Study &rarr;</span>
                </a>
              ))}
            </div>
            <a href="/case-studies/" class="see-all-link">See All {config.case_studies.length} Case Studies &rarr;</a>
          </div>
        )}

        {pricingTiers.length > 0 && (
          <div class="inline-pricing">
            <h2>{service.name} Pricing for {industry.full_name}</h2>
            <div class="pricing-grid">
              {pricingTiers.map((tier: any) => (
                <div class={`pricing-card ${tier.featured ? 'pricing-featured' : ''}`}>
                  {tier.featured && <div class="pricing-badge">Most Popular</div>}
                  <h3>{tier.name}</h3>
                  <div class="pricing-price">
                    {tier.price === 0 ? (
                      <span class="price-amount">{tier.price_label || 'Custom'}</span>
                    ) : (
                      <>
                        <span class="price-currency">$</span>
                        <span class="price-amount">{tier.price.toLocaleString()}</span>
                        <span class="price-period">{tier.price_label || '/mo'}</span>
                      </>
                    )}
                  </div>
                  <p class="pricing-desc">{tier.description}</p>
                  <ul class="pricing-features">
                    {tier.features.map((f: string) => (
                      <li>{f}</li>
                    ))}
                  </ul>
                  <a href="/contact" class={`btn ${tier.featured ? 'btn-primary' : 'btn-outline'} btn-block`}>Get Started</a>
                </div>
              ))}
            </div>
            {service.pricing?.setup_fee && (
              <p class="setup-note">One-time setup fee: ${service.pricing.setup_fee.toLocaleString()}</p>
            )}
          </div>
        )}

        {/* Lead Magnet */}
        <LeadMagnet service={service.slug} variant="dark" />

        {/* Other services for this industry */}
        <div class="combo-cross-links">
          <h2>Other Services for {industry.full_name}</h2>
          <div class="cross-link-grid">
            {otherServices.map(svc => (
              <a href={`/industries/${industry.slug}/${svc.slug}/`} class="cross-link-card">
                <h3>{svc.name}</h3>
                <p>{svc.short_description}</p>
                <span class="card-link">{svc.name} for {industry.name} &rarr;</span>
              </a>
            ))}
          </div>
        </div>

        {/* This service for other industries */}
        <div class="combo-industries">
          <h2>{service.name} for Other Industries</h2>
          <div class="industry-chips">
            {otherIndustries.map(ind => (
              <a href={`/industries/${ind.slug}/${service.slug}/`} class="industry-chip">{ind.full_name}</a>
            ))}
          </div>
          <a href="/industries/" class="see-all-link">See All {config.industries.length} Industries &rarr;</a>
        </div>

        {/* Areas served */}
        <div class="combo-areas">
          <h2>{service.name} for {industry.name} in Central Florida</h2>
          <div class="area-chips">
            {topAreas.map(a => (
              <a href={`/areas/${a.slug}/${service.slug}/`} class="area-chip">{a.name}</a>
            ))}
          </div>
          <a href="/areas/" class="see-all-link">See All {config.areas.length} Areas &rarr;</a>
        </div>

        {faqQuestions.length > 0 && (
          <div class="faq-section">
            <h2>{service.name} FAQ for {industry.full_name}</h2>
            {faqQuestions.map((q: any) => (
              <details class="faq-item">
                <summary>{q.question}</summary>
                <div class="faq-answer" set:html={renderMarkdown(q.answer)} />
              </details>
            ))}
          </div>
        )}
      </div>

      <Sidebar currentService={service.slug} currentIndustry={industry.slug} />
    </div>
  </section>

  <CTABand heading={`Get ${service.name} Results for Your ${industry.name} Business`} />
  <ReviewsSection compact={true} maxReviews={3} />
  <Footer slot="footer" />
</Base>

<style>
  .combo-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .combo-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(192,57,43,0.12) 0%, transparent 40%),
      radial-gradient(circle at 80% 20%, rgba(59,130,246,0.06) 0%, transparent 35%);
    pointer-events: none;
  }
  .combo-hero-inner { position: relative; z-index: 1; }

  .combo-badges {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .badge-industry {
    background: rgba(192,57,43,0.15);
    color: var(--color-primary);
    border: 1px solid rgba(192,57,43,0.2);
  }

  .badge-service {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255,255,255,0.8);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .combo-hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
    max-width: 700px;
  }

  .combo-hero-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-lg);
    max-width: 600px;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .combo-hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .combo-hero .btn-outline {
    border-color: var(--color-white);
    color: var(--color-white);
  }
  .combo-hero .btn-outline:hover {
    background: var(--color-white);
    color: var(--color-dark);
  }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 1024px) {
    .content-layout {
      grid-template-columns: 1fr 300px;
    }
  }

  /* Case Studies */
  .combo-cases { margin-top: var(--space-2xl); }
  .combo-cases-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-md); margin-top: var(--space-lg); }
  .combo-case-card {
    display: flex; flex-direction: column; padding: var(--space-lg);
    background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 10px;
    text-decoration: none; color: inherit; transition: transform 0.15s, box-shadow 0.15s;
  }
  .combo-case-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .combo-case-tag { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); margin-bottom: var(--space-xs); }
  .combo-case-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-xs); }
  .combo-case-client { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-sm); }
  .card-link { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }
  .see-all-link { display: inline-block; margin-top: var(--space-md); font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }

  /* Pricing */
  .inline-pricing { margin-top: var(--space-2xl); }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .pricing-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 10px;
    padding: var(--space-xl);
    position: relative;
  }

  .pricing-featured {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary);
  }

  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: var(--color-white);
    padding: 0.25rem 1rem;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .pricing-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-sm); }
  .pricing-price { margin-bottom: var(--space-sm); }
  .price-currency { font-size: var(--text-xl); font-weight: 700; vertical-align: top; }
  .price-amount { font-size: var(--text-3xl); font-weight: 800; line-height: 1; }
  .price-period { font-size: var(--text-sm); color: var(--color-text-light); }
  .pricing-desc { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-md); }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin-bottom: var(--space-lg);
  }

  .pricing-features li {
    padding: 0.375rem 0;
    font-size: var(--text-sm);
    border-bottom: 1px solid var(--color-gray-100);
  }

  .pricing-features li::before {
    content: '✓ ';
    color: var(--color-primary);
    font-weight: 700;
  }

  .setup-note { text-align: center; color: var(--color-text-light); font-size: var(--text-sm); margin-top: var(--space-md); }
  .btn-block { display: block; text-align: center; width: 100%; }

  /* Cross-links */
  .combo-cross-links { margin-top: var(--space-2xl); }
  .cross-link-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-md); margin-top: var(--space-lg); }
  .cross-link-card {
    display: block; padding: var(--space-lg);
    background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 10px;
    text-decoration: none; color: inherit; transition: transform 0.15s, box-shadow 0.15s;
  }
  .cross-link-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .cross-link-card h3 { font-size: var(--text-base); margin-bottom: var(--space-xs); }
  .cross-link-card p { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-sm); }

  /* Industry chips */
  .combo-industries { margin-top: var(--space-2xl); }
  .industry-chips { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
  .industry-chip {
    display: inline-block; padding: 0.5rem 1rem;
    background: rgba(192,57,43,0.06); border: 1px solid rgba(192,57,43,0.12); border-radius: 6px;
    font-size: var(--text-sm); text-decoration: none; color: var(--color-text-light);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .industry-chip:hover { background: var(--color-primary); color: var(--color-white); border-color: var(--color-primary); }

  /* Area chips */
  .combo-areas { margin-top: var(--space-2xl); }
  .area-chips { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
  .area-chip {
    display: inline-block; padding: 0.5rem 1rem;
    background: var(--color-gray-100); border-radius: 6px; font-size: var(--text-sm);
    text-decoration: none; color: var(--color-text-light);
    transition: background 0.15s, color 0.15s;
  }
  .area-chip:hover { background: var(--color-primary); color: var(--color-white); }

  /* FAQ */
  .faq-section { margin-top: var(--space-2xl); }
  .faq-item { border-bottom: 1px solid var(--color-gray-200); padding: var(--space-md) 0; }
  .faq-item summary { font-weight: 600; cursor: pointer; font-size: var(--text-base); }
  .faq-answer { padding-top: var(--space-sm); color: var(--color-text-light); }
</style>
