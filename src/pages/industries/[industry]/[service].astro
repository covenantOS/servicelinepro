---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ReviewsSection from '../../../components/ReviewsSection.astro';
import CTABand from '../../../components/CTABand.astro';
import Footer from '../../../components/Footer.astro';
import LeadMagnet from '../../../components/LeadMagnet.astro';
import config from '../../../lib/config';
import { renderMarkdown, splitMarkdownSections } from '../../../lib/markdown';
import InlineTestimonial from '../../../components/InlineTestimonial.astro';
import fs from 'node:fs';
import path from 'node:path';
import YAML from 'yaml';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const industry of config.industries) {
    for (const service of config.services) {
      paths.push({
        params: { industry: industry.slug, service: service.slug },
        props: { industry, service },
      });
    }
  }
  return paths;
}

const { industry, service } = Astro.props;

let content = '';
let frontmatter: any = {};

const filePath = path.resolve(`./src/content/industry-services/${industry.slug}-${service.slug}.md`);
if (fs.existsSync(filePath)) {
  const raw = fs.readFileSync(filePath, 'utf8');
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (fmMatch) {
    frontmatter = YAML.parse(fmMatch[1]);
    content = fmMatch[2];
  } else {
    content = raw;
  }
}

const pageTitle = frontmatter.title || `${service.name} for ${industry.full_name}`;
const pageDescription = frontmatter.description || `${service.name} services designed specifically for ${industry.full_name.toLowerCase()}. ${config.business.name} delivers results-driven ${service.name.toLowerCase()} campaigns that generate real leads.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Industries', href: '/industries/' },
  { label: industry.full_name, href: `/industries/${industry.slug}/` },
  { label: `${service.name}` },
];

const faqQuestions = frontmatter.faq || [];
const contentSections = content ? splitMarkdownSections(content) : [];
const inlineReview = config.reviews?.[0];
const pricingTiers = service.pricing?.tiers || [];

// Find case studies matching this service category or industry
const serviceKeyword = service.name.toLowerCase().split(' ')[0];
const industryKeyword = industry.name.toLowerCase().split('/')[0].trim();
const relevantCases = config.case_studies.filter(cs =>
  cs.category.toLowerCase().includes(serviceKeyword) ||
  (cs.industry && cs.industry.toLowerCase().includes(industryKeyword))
).slice(0, 4);

// Other services for this industry (cross-links)
const otherServices = config.services.filter(s => s.slug !== service.slug);

// Other industries for this service (cross-links)
const otherIndustries = config.industries.filter(i => i.slug !== industry.slug).slice(0, 8);

// Nearby areas for internal linking
const topAreas = config.areas.slice(0, 6);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.name} for ${industry.full_name}`,
  description: pageDescription,
  provider: {
    '@type': 'ProfessionalService',
    name: config.business.name,
  },
};
---

<Base title={pageTitle} description={pageDescription} schema={schema}>
  <Header slot="header" />

  <section class="combo-hero">
    <div class="combo-hero-bg"></div>
    <div class="container combo-hero-inner">
      <Breadcrumbs items={breadcrumbItems} />
      <div class="combo-badges">
        <span class="badge badge-industry">{industry.name}</span>
        <span class="badge badge-service">{service.name}</span>
      </div>
      <h1>{pageTitle}</h1>
      <p class="combo-hero-desc">{pageDescription}</p>
      <div class="combo-hero-ctas">
        <a href="/contact" class="btn btn-primary">Get Your Free Strategy Call</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn-outline">{config.business.phone}</a>
      </div>
    </div>
  </section>

  {/* === FULL-WIDTH CONTENT SECTIONS — NO SIDEBAR === */}
  {contentSections.length > 0 ? (
    contentSections.map((section, i) => (
      <>
        <section class={`fw-section ${i % 3 === 1 ? 'fw-alt' : ''} ${i % 5 === 3 ? 'fw-dark' : ''}`}>
          <div class="container fw-narrow">
            <div class="prose" set:html={section.html} />
          </div>
        </section>

        {i === 0 && inlineReview && (
          <section class="fw-section fw-alt">
            <div class="container fw-narrow">
              <InlineTestimonial quote={inlineReview.text} author={inlineReview.author} company={inlineReview.company} rating={inlineReview.rating} />
            </div>
          </section>
        )}

        {i === 1 && (
          <section class="fw-section fw-dark fw-cta-band">
            <div class="container">
              <div class="fw-cta-inner">
                <div>
                  <h3>Ready to Grow Your {industry.name} Business?</h3>
                  <p>15-minute strategy call. No pitch deck. We show you where the money is.</p>
                </div>
                <a href="/contact" class="btn btn-primary">Free Strategy Call</a>
              </div>
            </div>
          </section>
        )}

        {i === 3 && config.reviews?.[1] && (
          <section class="fw-section">
            <div class="container fw-narrow">
              <InlineTestimonial quote={config.reviews[1].text} author={config.reviews[1].author} company={config.reviews[1].company} rating={config.reviews[1].rating} />
            </div>
          </section>
        )}
      </>
    ))
  ) : (
    <section class="fw-section">
      <div class="container fw-narrow">
        <div class="prose">
          <h2>{service.name} Built for the {industry.name} Industry</h2>
          <p>{config.business.name} delivers {service.name.toLowerCase()} campaigns designed specifically for {industry.full_name.toLowerCase()}.</p>
          <p>Your <a href={`/services/${service.slug}/`}>{service.name.toLowerCase()} strategy</a> needs to account for seasonal demand, local search patterns, and the specific language your customers use.</p>
          <p>We have worked with <a href={`/industries/${industry.slug}/`}>{industry.full_name.toLowerCase()}</a> and know what moves the needle.</p>
        </div>
      </div>
    </section>
  )}

  {/* Case Studies - full width dark */}
  {relevantCases.length > 0 && (
    <section class="fw-section fw-dark">
      <div class="container">
        <span class="section-label section-label-light">Proven Results</span>
        <h2 class="fw-heading-light">{service.name} Results in {industry.name}</h2>
        <div class="combo-cases-grid">
          {relevantCases.map(cs => (
            <a href={`/case-studies/${cs.slug}/`} class="combo-case-card combo-case-dark">
              <span class="combo-case-tag">{cs.category}</span>
              <h3>{cs.metrics?.primary || cs.result}</h3>
              <span class="combo-case-client">{cs.title}</span>
              <span class="card-link">Read Case Study</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Other services - full width alt */}
  <section class="fw-section fw-alt">
    <div class="container">
      <span class="section-label">More for {industry.full_name}</span>
      <h2>Other Services for {industry.full_name}</h2>
      <div class="cross-link-grid">
        {otherServices.map(svc => (
          <a href={`/industries/${industry.slug}/${svc.slug}/`} class="cross-link-card">
            <h3>{svc.name}</h3>
            <p>{svc.short_description.split('.')[0]}.</p>
            <span class="card-link">{svc.name} for {industry.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Industries + Areas chips - full width dark */}
  <section class="fw-section fw-dark">
    <div class="container">
      <div class="combo-links-grid">
        <div>
          <span class="section-label section-label-light">{service.name} by Industry</span>
          <h3 class="fw-heading-light">{service.name} for Other Industries</h3>
          <div class="fw-chip-grid">
            {otherIndustries.map(ind => (
              <a href={`/industries/${ind.slug}/${service.slug}/`} class="fw-chip">{ind.full_name}</a>
            ))}
          </div>
        </div>
        <div>
          <span class="section-label section-label-light">{industry.name} by Area</span>
          <h3 class="fw-heading-light">{service.name} for {industry.name} Near You</h3>
          <div class="fw-chip-grid">
            {topAreas.map(a => (
              <a href={`/areas/${a.slug}/`} class="fw-chip">{a.name}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* FAQ - full width */}
  {faqQuestions.length > 0 && (
    <section class="fw-section fw-alt">
      <div class="container fw-narrow">
        <span class="section-label">Common Questions</span>
        <h2>{service.name} FAQ for {industry.full_name}</h2>
        <div class="faq-grid">
          {faqQuestions.map((q: any) => (
            <details class="faq-item">
              <summary>{q.question}</summary>
              <div class="faq-answer" set:html={renderMarkdown(q.answer)} />
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABand heading={`Get ${service.name} Results for Your ${industry.name} Business`} />
  <ReviewsSection compact={true} maxReviews={3} />
  <Footer slot="footer" />
</Base>

<style>
  .combo-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .combo-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(192,57,43,0.12) 0%, transparent 40%),
      radial-gradient(circle at 80% 20%, rgba(59,130,246,0.06) 0%, transparent 35%);
    pointer-events: none;
  }
  .combo-hero-inner { position: relative; z-index: 1; }

  .combo-badges {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .badge-industry {
    background: rgba(192,57,43,0.15);
    color: var(--color-primary);
    border: 1px solid rgba(192,57,43,0.2);
  }

  .badge-service {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255,255,255,0.8);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .combo-hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
    max-width: 700px;
  }

  .combo-hero-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-lg);
    max-width: 600px;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .combo-hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .combo-hero .btn-outline {
    border-color: var(--color-white);
    color: var(--color-white);
  }
  .combo-hero .btn-outline:hover {
    background: var(--color-white);
    color: var(--color-dark);
  }

  /* Full-width section system */
  .fw-section { padding: var(--space-3xl) 0; }
  .fw-alt { background: var(--color-gray-100); }
  .fw-dark { background: var(--color-dark); color: var(--color-white); }
  .fw-dark h2, .fw-dark h3 { color: var(--color-white); }
  .fw-dark h2::before { background: var(--color-primary); }
  .fw-dark p, .fw-dark li { color: rgba(255,255,255,0.7); }
  .fw-dark strong { color: var(--color-white); }
  .fw-dark a { color: var(--color-primary-light); }
  .fw-narrow { max-width: 800px; }
  .fw-heading-light { color: var(--color-white); margin-bottom: var(--space-xl); }
  .fw-heading-light::before { background: var(--color-primary); }
  .fw-cta-band { padding: var(--space-2xl) 0; position: relative; overflow: hidden; }
  .fw-cta-band::before { content: ''; position: absolute; top: 0; right: 0; width: 300px; height: 100%; background: radial-gradient(circle at 100% 50%, rgba(192,57,43,0.15) 0%, transparent 70%); pointer-events: none; }
  .fw-cta-band h3 { color: var(--color-white); font-size: var(--text-xl); margin-bottom: var(--space-xs); }
  .fw-cta-band h3::before { display: none; }
  .fw-cta-band p { color: rgba(255,255,255,0.6); margin-bottom: 0; max-width: 550px; }
  .fw-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: var(--space-lg); flex-wrap: wrap; position: relative; z-index: 1; }
  .section-label-light { color: rgba(255,255,255,0.4); }
  .card-link { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }

  /* Case studies (dark variant) */
  .combo-cases-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: var(--space-lg); margin-top: var(--space-lg); }
  .combo-case-card {
    display: flex; flex-direction: column; padding: var(--space-lg);
    background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 10px;
    text-decoration: none; color: inherit; transition: transform 0.15s, box-shadow 0.15s;
  }
  .combo-case-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .combo-case-dark { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); }
  .combo-case-dark:hover { background: rgba(255,255,255,0.08); }
  .combo-case-dark h3 { color: var(--color-white); }
  .combo-case-dark .combo-case-client { color: rgba(255,255,255,0.5); }
  .combo-case-tag { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); margin-bottom: var(--space-xs); }
  .combo-case-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-xs); }
  .combo-case-client { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-sm); }

  /* Cross-links */
  .cross-link-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-lg); margin-top: var(--space-xl); }
  .cross-link-card {
    display: block; padding: var(--space-lg);
    background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 10px;
    text-decoration: none; color: inherit; transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
  }
  .cross-link-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); border-color: var(--color-primary); }
  .cross-link-card h3 { font-size: var(--text-base); margin-bottom: var(--space-xs); }
  .cross-link-card p { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-sm); }

  /* Chip grids */
  .fw-chip-grid { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
  .fw-chip { display: inline-block; padding: 0.5rem 1.25rem; border: 1px solid rgba(255,255,255,0.15); border-radius: 6px; font-size: var(--text-sm); color: rgba(255,255,255,0.7); text-decoration: none; transition: all 0.15s; }
  .fw-chip:hover { border-color: var(--color-primary); color: var(--color-white); background: rgba(192,57,43,0.15); }
  .combo-links-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); }
  @media (min-width: 768px) { .combo-links-grid { grid-template-columns: 1fr 1fr; } }

  /* FAQ */
  .faq-grid { margin-top: var(--space-lg); }
  .faq-item { border: 1px solid var(--color-gray-200); border-radius: var(--radius-md); padding: var(--space-md) var(--space-lg); margin-bottom: var(--space-sm); background: var(--color-white); transition: box-shadow 0.15s; }
  .faq-item[open] { box-shadow: var(--shadow-sm); border-color: var(--color-primary); }
  .faq-item summary { font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: var(--text-xl); color: var(--color-primary); font-weight: 300; flex-shrink: 0; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-answer { padding-top: var(--space-md); color: var(--color-text-light); border-top: 1px solid var(--color-gray-100); margin-top: var(--space-md); }

  /* Dark section variants for feature cards */
  .fw-dark .feature-card { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.1); }
  .fw-dark .feature-card:hover { border-color: var(--color-primary); }
  .fw-dark .feature-card-title { color: var(--color-white); }
  .fw-dark .feature-card-desc { color: rgba(255,255,255,0.6); }
  .fw-dark .callout-box { background: rgba(255,255,255,0.06); }
  .fw-dark .callout-title { color: var(--color-white); }
  .fw-dark .visual-list { border-color: rgba(255,255,255,0.1); }
  .fw-dark .visual-list li { border-color: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7); }
</style>
