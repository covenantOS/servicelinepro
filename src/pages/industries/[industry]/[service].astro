---
import Base from '../../../layouts/Base.astro';
import config from '../../../lib/config';

export function getStaticPaths() {
  const paths: any[] = [];
  config.industries.forEach(ind => {
    config.services.forEach(svc => {
      paths.push({
        params: { industry: ind.slug, service: svc.slug },
        props: { industry: ind, service: svc },
      });
    });
  });
  return paths;
}

const { industry, service } = Astro.props;
---

<Base title={`${service.name} for ${industry.full_name}`} description={`${service.name} services tailored for ${industry.full_name.toLowerCase()}. ${service.short_description}`}>

<section class="section glow-red" style="padding-top: 6rem; position: relative; overflow: hidden;">
  <div class="container" style="position: relative; z-index: 1;">
    <div class="fade-in" style="max-width: 700px;">
      <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 1.5rem;">
        <a href={`/industries/${industry.slug}/`} style="font-size: 0.8rem; color: #888888; text-decoration: none;">{industry.name}</a>
        <span style="color: var(--gray-600);">/</span>
        <span style="font-size: 0.8rem; color: #666666;">{service.name}</span>
      </div>
      <h1>{service.name} for {industry.full_name}</h1>
      <p style="color: #666666; font-size: 1.05rem; line-height: 1.7; margin: 1.25rem 0 2rem;">
        {service.short_description} Our {service.name.toLowerCase()} strategies are customized for the unique challenges {industry.name.toLowerCase()} businesses face in today's competitive market.
      </p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="/contact/" class="btn btn--primary btn--lg">Get a Free {industry.name} Strategy Call</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn--outline btn--lg">Call {config.business.phone}</a>
      </div>
    </div>
  </div>
</section>

<section class="section bg-dark">
  <div class="container">
    <div class="grid grid--2" style="gap: 3rem; align-items: flex-start;">
      <div class="fade-in">
        <span class="section-label">Why It Works</span>
        <h2 style="margin-bottom: 1rem;">Why {industry.full_name} Choose ServiceLine Pro</h2>
        <p style="color: #666666; line-height: 1.7; margin-bottom: 1rem;">
          The {industry.name.toLowerCase()} industry has unique marketing challenges — seasonal demand, local competition, and the need for trust-building before a customer picks up the phone. Our {service.name.toLowerCase()} campaigns are designed specifically for these dynamics.
        </p>
        <p style="color: #666666; line-height: 1.7;">
          We combine industry expertise with data-driven execution to deliver measurable results. No generic strategies — every campaign is built for your specific market and competitive landscape.
        </p>
      </div>
      <div class="fade-in">
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: var(--radius-md); padding: 1.25rem;">
            <h4 style="font-size: 0.95rem; margin-bottom: 0.25rem;">No Long-Term Contracts</h4>
            <p style="color: #888888; font-size: 0.85rem;">Results keep you, not paperwork.</p>
          </div>
          <div style="background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: var(--radius-md); padding: 1.25rem;">
            <h4 style="font-size: 0.95rem; margin-bottom: 0.25rem;">Industry-Specific Strategy</h4>
            <p style="color: #888888; font-size: 0.85rem;">Custom approach for {industry.name.toLowerCase()} market dynamics.</p>
          </div>
          <div style="background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: var(--radius-md); padding: 1.25rem;">
            <h4 style="font-size: 0.95rem; margin-bottom: 0.25rem;">Real-Time Reporting</h4>
            <p style="color: #888888; font-size: 0.85rem;">Live dashboards with the metrics that matter.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Ready to Grow Your {industry.name} Business?</h2>
    <p style="margin-bottom: 2rem;">Free strategy call — we'll analyze your market and build a custom plan.</p>
    <a href="/contact/" class="btn btn--primary btn--lg">Get Your Free Strategy Call</a>
  </div>
</section>

</Base>
