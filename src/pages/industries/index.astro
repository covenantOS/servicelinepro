---
import Base from '../../layouts/Base.astro';
import config from '../../lib/config';
---

<Base title="Industries We Serve" description="ServiceLine Pro specializes in marketing for home service businesses including HVAC, plumbing, roofing, electrical, and 20+ more industries.">

<section class="section" style="padding-top: 5rem;">
  <div class="container">
    <div class="fade-in" style="text-align: center; margin-bottom: 3.5rem;">
      <span class="section-label">Industries</span>
      <h1>Marketing Built for <span class="gradient-text--red">Your Industry</span></h1>
      <p class="section-subtitle" style="margin: 1rem auto 0;">Every industry has unique challenges. We build strategies tailored to yours — from seasonal demand cycles to competitive dynamics.</p>
    </div>

    <div class="ind-grid stagger">
      {config.industries.map(ind => (
        <a href={`/industries/${ind.slug}/`} class="ind-card fade-in" style="text-decoration: none;">
          <h3 class="ind-card__name">{ind.full_name}</h3>
          <p class="ind-card__desc">{ind.description}</p>
          <span style="display: inline-flex; align-items: center; gap: 0.25rem; color: var(--red-light); font-size: 0.8rem; font-weight: 600; margin-top: auto;">
            View Services <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Don't See Your Industry?</h2>
    <p style="margin-bottom: 2rem;">We work with businesses across all service industries. Let's talk about your growth goals.</p>
    <a href="/contact/" class="btn btn--primary btn--lg">Get Your Free Strategy Call</a>
  </div>
</section>

</Base>

<style>
.ind-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
}
.ind-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1.5rem;
  background: #f8f9fa;
  border: 1px solid #e5e7eb;
  border-radius: var(--radius-md);
  transition: all var(--transition-med);
}
.ind-card:hover {
  border-color: var(--gray-600);
  transform: translateY(-2px);
}
.ind-card__name {
  font-size: 1.05rem;
  color: #1a1a1a;
}
.ind-card__desc {
  font-size: 0.85rem;
  color: #888888;
  line-height: 1.5;
}
</style>
