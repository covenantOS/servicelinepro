---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABand from '../../components/CTABand.astro';
import Footer from '../../components/Footer.astro';
import config from '../../lib/config';

const pageTitle = "Who We Work With";
const pageDescription = `${config.business.name} provides local SEO, Google Ads, website design, and TV advertising for ${config.industries.length}+ home service industries across the United States.`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Who We Work With' },
];
---

<Base title={pageTitle} description={pageDescription}>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />
      <h1>{pageTitle}</h1>
      <p class="page-hero-desc">Performance-driven marketing built for the businesses that keep America running. We know your customers, your seasonality, your competition, and exactly how to make your phone ring.</p>
    </div>
  </section>

  <section class="industries-grid-section section">
    <div class="container">
      <div class="industries-grid">
        {config.industries.map(industry => (
          <a href={`/industries/${industry.slug}/`} class="industry-card card">
            <div class="industry-card-body">
              <h2>{industry.full_name}</h2>
              <p>{industry.description}</p>
              <div class="industry-card-services">
                {config.services.map(svc => (
                  <span class="micro-badge">{svc.name}</span>
                ))}
              </div>
              <span class="card-link">View {industry.name} Solutions &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand heading="Don't See Your Industry? We Probably Cover It." />
  <Footer slot="footer" />
</Base>

<style>
  .page-hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
  }

  .page-hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
  }

  .page-hero-desc {
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--text-lg);
    max-width: 650px;
  }

  .industries-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-lg);
  }

  .industry-card {
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .industry-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .industry-card-body {
    padding: var(--space-xl);
  }

  .industry-card-body h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .industry-card-body p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-md);
  }

  .industry-card-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--space-md);
  }

  .micro-badge {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: var(--color-gray-100);
    border-radius: 999px;
    color: var(--color-text-light);
  }

  .card-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
  }
</style>
