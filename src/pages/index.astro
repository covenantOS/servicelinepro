---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import TrustBar from '../components/TrustBar.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import CTABand from '../components/CTABand.astro';
import Footer from '../components/Footer.astro';
import config from '../lib/config';

const title = "Home Service Marketing Agency | Local SEO, Google Ads, Web Design & TV Advertising";
const description = config.business.description;
---

<Base title={title} description={description}>
  <Header slot="header" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg-pattern"></div>
    <div class="container hero-grid">
      <div class="hero-content">
        <span class="hero-eyebrow">Performance Marketing for Home Services</span>
        <h1>We Scale Home Service Businesses <span class="hero-accent">from $1M to $10M</span></h1>
        <p class="hero-sub">Local SEO that puts you in the Map Pack. Google Ads with zero agency fees. Websites that convert. TV campaigns that build your brand. All under one roof.</p>
        <div class="hero-ctas">
          <a href="/contact" class="btn btn-primary btn-lg">Free Strategy Call &rarr;</a>
          <a href="/case-studies" class="btn btn-outline-light btn-lg">See Our Results</a>
        </div>
        <div class="hero-proof">
          <div class="hero-stat">
            <span class="hero-stat-value">$2M+</span>
            <span class="hero-stat-label">Generated for Clients</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">4.9&#9733;</span>
            <span class="hero-stat-label">Google Rating</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">300+</span>
            <span class="hero-stat-label">Leads (Single Client)</span>
          </div>
        </div>
      </div>
      <div class="hero-form-wrap">
        <div class="hero-form-header">
          <h2>Get Your Free Market Analysis</h2>
          <p>See exactly where you rank and where the opportunities are.</p>
        </div>
        <form class="hero-form" action={config.form.action} method="POST">
          <div class="form-group">
            <input type="text" name="name" placeholder="Full Name" required />
          </div>
          <div class="form-group">
            <input type="email" name="email" placeholder="Email" required />
          </div>
          <div class="form-group">
            <input type="tel" name="phone" placeholder="Phone Number" required />
          </div>
          <div class="form-group">
            <input type="text" name="company" placeholder="Company Name" required />
          </div>
          <div class="form-group">
            <input type="url" name="website" placeholder="Current Website (optional)" />
          </div>
          <div class="hp-field" aria-hidden="true">
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>
          <button type="submit" class="btn btn-primary btn-lg btn-block">Get My Free Analysis</button>
        </form>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- PROBLEM -->
  <section class="problems section">
    <div class="container">
      <span class="section-label">The Problem</span>
      <h2>Why Your Marketing Isn't Working</h2>
      <div class="problems-grid">
        <div class="problem-card">
          <div class="problem-num">01</div>
          <h3>Invisible on Google</h3>
          <p>Your competitors are in the Map Pack booking the jobs you should have. You are nowhere.</p>
        </div>
        <div class="problem-card">
          <div class="problem-num">02</div>
          <h3>Burning Money on Ads</h3>
          <p>Your agency charges 15-20% management fees on top of ad spend. You are paying for their overhead, not your growth.</p>
        </div>
        <div class="problem-card">
          <div class="problem-num">03</div>
          <h3>Website That Doesn't Convert</h3>
          <p>Pretty designs that take 8 seconds to load and never convert a visitor into a phone call. Looks great. Does nothing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ALL 4 SERVICES -->
  <section class="services-showcase section section-dark">
    <div class="container">
      <span class="section-label section-label-light">The Solution</span>
      <h2>Four Services. One Mission. Fill Your Calendar.</h2>
      <p class="section-subtitle">Every service we offer is built to generate leads for home service businesses. Nothing else.</p>

      <div class="services-mega-grid">
        <!-- LOCAL SEO -->
        <div class="service-mega-card service-featured">
          <div class="service-mega-badge">Most Popular</div>
          <div class="service-mega-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Local Ranking SEO</h3>
          <p class="service-mega-tagline">Top 3 in the Map Pack in 90 days or you don't pay.</p>
          <ul class="service-mega-features">
            <li>Full GBP Optimization (10 categories, 30+ services)</li>
            <li>Citation Building and NAP Consistency</li>
            <li>Local Authority Link Building</li>
            <li>Geo-Grid Tracking and Reporting</li>
          </ul>
          <div class="service-mega-pricing">
            <span class="service-price-from">From</span>
            <span class="service-price-amount">$1,800<span>/mo</span></span>
          </div>
          <a href="/services/local-seo/" class="btn btn-primary btn-block">Learn More</a>
        </div>

        <!-- PPC -->
        <div class="service-mega-card">
          <div class="service-mega-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h3>Google Ads (PPC)</h3>
          <p class="service-mega-tagline">No agency fee. Your entire budget funds your campaigns.</p>
          <ul class="service-mega-features">
            <li>$0 Agency Fee on $5K+ Spend</li>
            <li>First-Party Data from 30M+ Households</li>
            <li>Google, Bing, and Yahoo Coverage</li>
            <li>30-50% Higher CTR, 33% Lower CPC</li>
          </ul>
          <div class="service-mega-pricing">
            <span class="service-price-from">From</span>
            <span class="service-price-amount">$500<span>/mo</span></span>
          </div>
          <a href="/services/ppc/" class="btn btn-primary btn-block">Learn More</a>
        </div>

        <!-- WEB DESIGN -->
        <div class="service-mega-card">
          <div class="service-mega-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>Website Design</h3>
          <p class="service-mega-tagline">Sub-2-second loads. Built to convert visitors into booked jobs.</p>
          <ul class="service-mega-features">
            <li>Custom Performance Sites (Astro)</li>
            <li>WordPress with Full CMS</li>
            <li>Mobile-First, SEO-Optimized</li>
            <li>Conversion-Focused CTAs and Funnels</li>
          </ul>
          <div class="service-mega-pricing">
            <span class="service-price-from">From</span>
            <span class="service-price-amount">$2,500</span>
          </div>
          <a href="/services/website-design/" class="btn btn-primary btn-block">Learn More</a>
        </div>

        <!-- TV & STREAMING -->
        <div class="service-mega-card service-spectrum">
          <div class="service-mega-badge spectrum-badge">Spectrum Reach Partner</div>
          <div class="service-mega-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="15" rx="2"/><polyline points="17 2 12 7 7 2"/></svg>
          </div>
          <h3>TV & Streaming</h3>
          <p class="service-mega-tagline">Precision-targeted streaming campaigns. No agency fee on media spend.</p>
          <ul class="service-mega-features">
            <li>Connected TV and Streaming Platforms</li>
            <li>First-Party Data Targeting</li>
            <li>Professional Ad Production</li>
            <li>Full Attribution and Reporting</li>
          </ul>
          <div class="service-mega-pricing">
            <span class="service-price-from">Custom</span>
            <span class="service-price-amount">Quote</span>
          </div>
          <a href="/services/tv-streaming-advertising/" class="btn btn-primary btn-block">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SPECTRUM REACH PARTNERSHIP -->
  <section class="spectrum-section section">
    <div class="container spectrum-grid">
      <div class="spectrum-content">
        <span class="section-label">Exclusive Partnership</span>
        <h2>Powered by Spectrum Reach</h2>
        <p class="spectrum-lead">We are one of the only agencies in the country with a direct Spectrum Reach partnership. That means our clients get access to tools and data that other agencies cannot offer at any price.</p>
        <div class="spectrum-stats">
          <div class="spectrum-stat">
            <span class="spectrum-stat-value">30M+</span>
            <span class="spectrum-stat-label">Households of First-Party Data</span>
          </div>
          <div class="spectrum-stat">
            <span class="spectrum-stat-value">36</span>
            <span class="spectrum-stat-label">States Covered</span>
          </div>
          <div class="spectrum-stat">
            <span class="spectrum-stat-value">$0</span>
            <span class="spectrum-stat-label">Agency Fee on $5K+ Ad Spend</span>
          </div>
        </div>
        <div class="spectrum-certs">
          {config.spectrum_partnership.certifications.map(cert => (
            <span class="spectrum-cert">{cert}</span>
          ))}
        </div>
      </div>
      <div class="spectrum-visual">
        <div class="spectrum-card-stack">
          <div class="spectrum-feature-card">
            <h4>First-Party Data</h4>
            <p>Real behavioral data from 30M+ households. Not third-party guesses. Not cookie-based estimates. Real viewing and purchasing behavior.</p>
          </div>
          <div class="spectrum-feature-card">
            <h4>Zero Agency Fees</h4>
            <p>On ad budgets over $5K/month, there is no management fee. Your entire budget goes toward reaching your customers. Every dollar works.</p>
          </div>
          <div class="spectrum-feature-card">
            <h4>Multi-Platform Reach</h4>
            <p>Google, Bing, Yahoo, Connected TV, Streaming. 99% of all search and viewing traffic covered through a single partnership.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FREE 10-DAY BOOST -->
  <section class="boost-section section section-dark">
    <div class="container boost-grid">
      <div class="boost-content">
        <span class="section-label section-label-light">Limited Offer</span>
        <h2>Free 10-Day Local SEO Boost</h2>
        <p class="boost-lead">We will optimize your Google Business Profile, fix your citations, and boost your local signals for 10 days. No charge. No commitment. If you see results, we talk about what a full campaign looks like.</p>
        <div class="boost-requirements">
          <span class="boost-req-title">Requirements:</span>
          <ul>
            <li>Physical Google Business Profile (not virtual/PO Box)</li>
            <li>15+ existing Google reviews</li>
            <li>4.5+ star rating</li>
            <li>Existing website</li>
          </ul>
        </div>
        <a href="/contact?service=10-day-boost" class="btn btn-primary btn-lg">Apply for Free Boost &rarr;</a>
      </div>
      <div class="boost-results">
        <div class="boost-result-card">
          <span class="boost-result-label">Average Result After 10 Days</span>
          <div class="boost-metric">
            <span class="boost-metric-value">+47%</span>
            <span class="boost-metric-label">Increase in Search Appearances</span>
          </div>
          <div class="boost-metric">
            <span class="boost-metric-value">+23%</span>
            <span class="boost-metric-label">More Discovery Searches</span>
          </div>
          <div class="boost-metric">
            <span class="boost-metric-value">+15%</span>
            <span class="boost-metric-label">More Direction Requests</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASE STUDIES / RESULTS -->
  <section class="results-section section">
    <div class="container">
      <span class="section-label">Real Results</span>
      <h2>What We Do for Our Clients</h2>
      <div class="results-grid">
        {config.case_studies.slice(0, 4).map(cs => (
          <div class="result-card">
            <span class="result-category">{cs.category}</span>
            <h3 class="result-metric">{cs.result}</h3>
            <span class="result-client">{cs.title}</span>
          </div>
        ))}
      </div>
      <div class="results-more">
        <a href="/case-studies/" class="btn btn-outline">View All {config.case_studies.length} Case Studies &rarr;</a>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="process-section section section-alt">
    <div class="container">
      <span class="section-label">How It Works</span>
      <h2>From Invisible to Unavoidable</h2>
      <div class="process-grid">
        <div class="process-step">
          <div class="step-num">1</div>
          <div class="step-content">
            <h3>Free Strategy Call</h3>
            <p>15-minute no-pressure call. We analyze your market, your competition, and your current marketing spend. You get a clear picture of where the opportunities are.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-num">2</div>
          <div class="step-content">
            <h3>Custom Battle Plan</h3>
            <p>We build your strategy with specific timelines and KPIs. You see exactly what we are doing, when we are doing it, and how we measure success.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-num">3</div>
          <div class="step-content">
            <h3>Launch and Scale</h3>
            <p>We execute. Your phone rings. You track every lead in real time. When it works, we scale up together.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="industries-section section">
    <div class="container">
      <span class="section-label">Who We Work With</span>
      <h2>Built for the Businesses That Keep America Running</h2>
      <div class="industries-chips">
        {config.industries.map(ind => (
          <a href={`/industries/${ind.slug}/`} class="industry-chip">{ind.full_name}</a>
        ))}
      </div>
      <a href="/industries/" class="section-link">View All {config.industries.length} Industries &rarr;</a>
    </div>
  </section>

  <ReviewsSection compact={true} maxReviews={4} />

  <CTABand
    heading="Stop Losing Jobs to Competitors Who Showed Up First"
    text="Book a 15-minute strategy call. No pressure. No pitch deck. Just straight answers about what it takes to dominate your local market."
  />

  <Footer slot="footer" />
</Base>

<style>
  /* === HERO === */
  .hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .hero-bg-pattern {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(192,57,43,0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(192,57,43,0.08) 0%, transparent 40%);
    pointer-events: none;
  }
  .hero-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); align-items: start; position: relative; z-index: 1; }
  @media (min-width: 1024px) { .hero-grid { grid-template-columns: 1.3fr 1fr; } }

  .hero-eyebrow { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-primary); margin-bottom: var(--space-md); border: 1px solid rgba(192,57,43,0.3); padding: 0.25rem 0.75rem; border-radius: 4px; }
  .hero h1 { font-size: var(--text-3xl); line-height: 1.1; margin-bottom: var(--space-md); color: var(--color-white); }
  @media (min-width: 768px) { .hero h1 { font-size: var(--text-4xl); } }
  @media (min-width: 1280px) { .hero h1 { font-size: var(--text-5xl); } }
  .hero-accent { color: var(--color-primary); display: block; }
  .hero-sub { font-size: var(--text-lg); color: rgba(255,255,255,0.7); margin-bottom: var(--space-xl); line-height: 1.6; max-width: 540px; }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; margin-bottom: var(--space-2xl); }

  .btn-outline-light { background: transparent; border: 2px solid rgba(255,255,255,0.3); color: var(--color-white); border-radius: 6px; font-weight: 600; padding: 0.75rem 1.5rem; text-decoration: none; display: inline-block; cursor: pointer; transition: all 0.15s; }
  .btn-outline-light:hover { background: var(--color-white); color: var(--color-dark); border-color: var(--color-white); }

  .hero-proof { display: flex; gap: var(--space-xl); align-items: center; }
  .hero-stat-value { display: block; font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 800; color: var(--color-white); }
  .hero-stat-label { display: block; font-size: 0.7rem; color: rgba(255,255,255,0.45); }
  .hero-stat-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.15); }

  /* === HERO FORM === */
  .hero-form-wrap { background: rgba(255,255,255,0.04); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); overflow: hidden; backdrop-filter: blur(8px); }
  .hero-form-header { padding: var(--space-lg) var(--space-xl) 0; }
  .hero-form-header h2 { font-size: var(--text-lg); color: var(--color-white); margin-bottom: var(--space-xs); }
  .hero-form-header p { font-size: var(--text-sm); color: rgba(255,255,255,0.5); margin-bottom: 0; }
  .hero-form { display: flex; flex-direction: column; gap: var(--space-sm); padding: var(--space-lg) var(--space-xl) var(--space-xl); }
  .hero-form input { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 6px; padding: 0.7rem 0.875rem; color: var(--color-white); font-size: var(--text-sm); transition: border-color 0.15s; width: 100%; font-family: var(--font-body); }
  .hero-form input::placeholder { color: rgba(255,255,255,0.3); }
  .hero-form input:focus { outline: none; border-color: var(--color-primary); background: rgba(255,255,255,0.1); }
  .hp-field { position: absolute; left: -9999px; }
  .btn-block { display: block; width: 100%; text-align: center; }

  /* === PROBLEMS === */
  .section-label { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary); margin-bottom: var(--space-sm); }
  .section-label-light { color: rgba(255,255,255,0.4); }
  .problems-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-lg); margin-top: var(--space-xl); }
  .problem-card { padding: var(--space-xl); background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 10px; position: relative; transition: transform 0.2s, box-shadow 0.2s; }
  .problem-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .problem-num { font-family: var(--font-heading); font-size: var(--text-3xl); font-weight: 800; color: rgba(192,57,43,0.1); line-height: 1; margin-bottom: var(--space-sm); }
  .problem-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-sm); }
  .problem-card p { font-size: var(--text-sm); color: var(--color-text-light); line-height: 1.6; }

  /* === SERVICES SHOWCASE === */
  .section-subtitle { font-size: var(--text-base); color: rgba(255,255,255,0.55); margin-top: var(--space-sm); max-width: 540px; }
  .services-mega-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); margin-top: var(--space-2xl); }
  @media (min-width: 768px) { .services-mega-grid { grid-template-columns: 1fr 1fr; } }

  .service-mega-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: var(--space-xl);
    position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }
  .service-mega-card:hover { border-color: rgba(255,255,255,0.2); transform: translateY(-2px); }
  .service-featured { border-color: rgba(192,57,43,0.4); background: linear-gradient(135deg, rgba(192,57,43,0.08) 0%, rgba(255,255,255,0.02) 100%); }
  .service-spectrum { border-color: rgba(59,130,246,0.3); background: linear-gradient(135deg, rgba(59,130,246,0.06) 0%, rgba(255,255,255,0.02) 100%); }

  .service-mega-badge { position: absolute; top: var(--space-lg); right: var(--space-lg); font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); background: rgba(192,57,43,0.15); padding: 0.25rem 0.625rem; border-radius: 4px; }
  .spectrum-badge { color: #3b82f6; background: rgba(59,130,246,0.15); }

  .service-mega-icon { margin-bottom: var(--space-md); color: var(--color-primary); }
  .service-spectrum .service-mega-icon { color: #3b82f6; }
  .service-mega-card h3 { font-size: var(--text-xl); color: var(--color-white); margin-bottom: var(--space-xs); }
  .service-mega-tagline { font-size: var(--text-sm); color: rgba(255,255,255,0.55); margin-bottom: var(--space-lg); }

  .service-mega-features { list-style: none; padding: 0; margin-bottom: var(--space-lg); }
  .service-mega-features li { padding: 0.375rem 0; padding-left: 1.25rem; position: relative; font-size: var(--text-sm); color: rgba(255,255,255,0.7); }
  .service-mega-features li::before { content: ''; position: absolute; left: 0; top: 0.65rem; width: 6px; height: 6px; border-radius: 50%; background: var(--color-primary); }
  .service-spectrum .service-mega-features li::before { background: #3b82f6; }

  .service-mega-pricing { margin-bottom: var(--space-lg); padding: var(--space-sm) 0; border-top: 1px solid rgba(255,255,255,0.06); }
  .service-price-from { display: block; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.35); }
  .service-price-amount { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 800; color: var(--color-white); }
  .service-price-amount span { font-size: var(--text-sm); font-weight: 600; color: rgba(255,255,255,0.5); }

  /* === SPECTRUM SECTION === */
  .spectrum-section { background: linear-gradient(180deg, var(--color-white) 0%, #fafafa 100%); }
  .spectrum-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); }
  @media (min-width: 1024px) { .spectrum-grid { grid-template-columns: 1fr 1fr; align-items: center; } }
  .spectrum-lead { font-size: var(--text-base); color: var(--color-text-light); line-height: 1.7; margin-bottom: var(--space-xl); max-width: 480px; }
  .spectrum-stats { display: flex; gap: var(--space-xl); margin-bottom: var(--space-lg); }
  .spectrum-stat-value { display: block; font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 800; color: var(--color-dark); }
  .spectrum-stat-label { display: block; font-size: 0.7rem; color: var(--color-text-muted); }
