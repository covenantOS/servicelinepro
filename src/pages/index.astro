  .service-mega-card h3 { font-size: var(--text-xl); color: var(--color-white); margin-bottom: var(--space-xs); padding: 0 var(--space-xl); }
  .service-mega-tagline { font-size: var(--text-sm); color: rgba(255,255,255,0.55); margin-bottom: var(--space-lg); padding: 0 var(--space-xl); }

  .service-mega-features { list-style: none; padding: 0 var(--space-xl); margin-bottom: var(--space-lg); }
  .service-mega-features li { padding: 0.375rem 0; padding-left: 1.25rem; position: relative; font-size: var(--text-sm); color: rgba(255,255,255,0.7); }
  .service-mega-features li::before { content: ''; position: absolute; left: 0; top: 0.65rem; width: 6px; height: 6px; border-radius: 50%; background: var(--color-primary); }
