---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import CTABand from '../components/CTABand.astro';
import Footer from '../components/Footer.astro';
import IconBulletList from '../components/IconBulletList.astro';
import StatBar from '../components/StatBar.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import LogoStrip from '../components/LogoStrip.astro';
import HandwrittenCTA from '../components/HandwrittenCTA.astro';
import config from '../lib/config';

const title = "Home Service Marketing Agency | Local SEO, Google Ads, Web Design & TV Advertising";
const description = config.business.description;
---

<Base title={title} description={description}>
  <Header slot="header" />

  <!-- ===== HERO — Full Viewport, Dark, Massive ALL CAPS ===== -->
  <section class="hero">
    <div class="hero-texture"></div>
    <div class="container hero-inner">
      <span class="hero-eyebrow">Performance Marketing for Home Services</span>
      <h1>We Scale Home Service Businesses from $1M to $10M</h1>
      <IconBulletList items={[
        { icon: 'map', text: '<strong>Map Pack rankings</strong> that put your phone on the hook' },
        { icon: 'money', text: '<strong>Google Ads with zero agency fees</strong> on $5K+ spend' },
        { icon: 'globe', text: '<strong>Websites that convert</strong> visitors into booked jobs' },
      ]} />
      <div class="hero-ctas">
        <a href="/contact" class="btn btn-ghost btn-lg">Get In Touch</a>
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP — Dark continuation below hero ===== -->
  <section class="trust-strip">
    <div class="container">
      <StatBar stats={[
        { value: '5.0 ★', label: 'Google Rating' },
        { value: '20+', label: 'Five-Star Reviews' },
        { value: '$2M+', label: 'Revenue Generated' },
        { value: '300+', label: 'Leads Delivered' },
      ]} variant="dark" />
      <LogoStrip items={['Spectrum Reach', 'Google Partner', 'Yahoo', 'TAG Certified']} variant="dark" label="Trusted Partnerships" />
    </div>
  </section>

  <!-- ===== SERVICES — Icon Grid on Dark ===== -->
  <section class="section section-dark">
    <div class="container">
      <div class="section-header-center">
        <span class="section-eyebrow section-label-light">The Solution</span>
        <h2>Four Services. One Mission. Fill Your Calendar.</h2>
      </div>
      <FeatureGrid items={[
        { icon: 'map', heading: 'Local Ranking SEO', description: 'Monthly retainer Map Pack SEO with a free 10-day boost. Full GBP optimization, citation building, and geo-grid tracking.' },
        { icon: 'target', heading: 'Google, Bing & Yahoo Ads', description: '$0 agency fee on $5K+ spend. First-party data from 30M+ households. 30-50% higher CTR, 33% lower CPC.' },
        { icon: 'code', heading: 'Website Design', description: 'Sub-2-second loads. Conversion-focused. Mobile-first. Custom performance sites or WordPress with full CMS.' },
        { icon: 'tv', heading: 'TV & Streaming', description: 'Connected TV, streaming, and linear TV campaigns. Free professional video production included with every campaign.' },
      ]} variant="dark" columns={4} />
      <div style="text-align: center; margin-top: var(--space-xl);">
        <a href="/services/" class="btn btn-ghost">View All Services</a>
      </div>
    </div>
  </section>

  <!-- ===== STAT CALLOUT — White Break ===== -->
  <section class="section">
    <div class="container">
      <StatBar stats={[
        { value: '30M+', label: 'Households of First-Party Data' },
        { value: '36', label: 'States Covered' },
        { value: '$0', label: 'Agency Fee on $5K+ Spend' },
        { value: '10 Days', label: 'Free SEO Boost' },
      ]} variant="light" />
    </div>
  </section>

  <!-- ===== FREE 10-DAY BOOST ===== -->
  <section class="section section-dark">
    <div class="container boost-grid">
      <div class="boost-content">
        <span class="section-eyebrow" style="color: var(--color-primary);">Signature Offer</span>
        <h2>Free 10-Day Local SEO Boost</h2>
        <p class="boost-lead">We optimize your Google Business Profile, fix your citations, and boost your local signals for 10 full days. No charge. No contract. No catch.</p>
        <div class="boost-metrics">
          <div class="boost-metric">
            <span class="boost-val">+47%</span>
            <span class="boost-lbl">Search Appearances</span>
          </div>
          <div class="boost-metric">
            <span class="boost-val">+23%</span>
            <span class="boost-lbl">Discovery Searches</span>
          </div>
          <div class="boost-metric">
            <span class="boost-val">+15%</span>
            <span class="boost-lbl">Direction Requests</span>
          </div>
        </div>
        <a href="/contact?service=10-day-boost" class="btn btn-primary btn-lg">Apply for Your Free Boost</a>
      </div>
      <div class="boost-visual">
        <img src="/media/local-seo-graphic.webp" alt="Local SEO ranking improvement geo-grid results" width="550" height="450" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM SECTION — White ===== -->
  <section class="section">
    <div class="container">
      <span class="section-eyebrow">The Problem</span>
      <h2>Why Your Marketing Isn't Working</h2>
      <div class="problems-grid">
        <div class="problem-card">
          <div class="problem-num">01</div>
          <h3>Invisible on Google</h3>
          <p>Your competitors are in the Map Pack booking the jobs you should have. You are nowhere.</p>
        </div>
        <div class="problem-card">
          <div class="problem-num">02</div>
          <h3>Burning Money on Ads</h3>
          <p>Your agency charges 15-20% management fees on top of ad spend. You are paying for their overhead, not your growth.</p>
        </div>
        <div class="problem-card">
          <div class="problem-num">03</div>
          <h3>Website That Doesn't Convert</h3>
          <p>Pretty designs that take 8 seconds to load and never convert a visitor into a phone call.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SPECTRUM PARTNERSHIP — Dark ===== -->
  <section class="section section-dark">
    <div class="container spectrum-grid">
      <div class="spectrum-content">
        <span class="section-eyebrow" style="color: var(--color-primary);">Exclusive Partnership</span>
        <h2>Powered by Spectrum Reach</h2>
        <p class="spectrum-lead">We are one of the only agencies in the country with a direct Spectrum Reach partnership. Your campaigns run across <strong>Google, Bing, Yahoo, Connected TV, and Streaming</strong>.</p>
        <StatBar stats={[
          { value: '30M+', label: 'Households' },
          { value: '36', label: 'States' },
          { value: '$0', label: 'Agency Fee' },
        ]} variant="dark" />
        <div class="spectrum-certs">
          {config.spectrum_partnership.certifications.map(cert => (
            <span class="spectrum-cert">{cert}</span>
          ))}
        </div>
      </div>
      <div class="spectrum-visual">
        <img src="/media/seo-ppc-presentation.webp" alt="Spectrum Reach advertising platform" class="spectrum-img" width="560" height="400" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ===== CASE STUDIES — White Break ===== -->
  <section class="section">
    <div class="container">
      <span class="section-eyebrow">Real Results</span>
      <h2>What We Do for Our Clients</h2>
      <div class="results-grid">
        {config.case_studies.slice(0, 6).map(cs => (
          <div class="result-card">
            <span class="result-category">{cs.category}</span>
            <h3 class="result-metric">{cs.result}</h3>
            <span class="result-client">{cs.title}</span>
            <span class="result-detail">{cs.metrics.secondary}</span>
          </div>
        ))}
      </div>
      <div style="text-align: center; margin-top: var(--space-xl);">
        <a href="/case-studies/" class="btn btn-primary btn-lg">View All {config.case_studies.length} Case Studies</a>
      </div>
    </div>
  </section>

  <!-- ===== PORTFOLIO — Dark ===== -->
  <section class="section section-dark">
    <div class="container">
      <span class="section-eyebrow" style="color: var(--color-primary);">Our Work</span>
      <h2>Websites That Generate Revenue</h2>
      <p style="color: rgba(255,255,255,0.6); margin-bottom: var(--space-xl); max-width: 560px;">Every site we build is a conversion machine. Sub-2-second load times. SEO-optimized from day one.</p>
      <div class="portfolio-grid">
        <div class="portfolio-item portfolio-large">
          <img src="/media/case-studies/Website-Design-1.webp" alt="Client website design project" width="600" height="400" loading="lazy" />
          <div class="portfolio-overlay"><span class="portfolio-tag">Website Design</span></div>
        </div>
        <div class="portfolio-item">
          <img src="/media/case-studies/Website-Design-2.webp" alt="Client website design project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay"><span class="portfolio-tag">Website Design</span></div>
        </div>
        <div class="portfolio-item">
          <img src="/media/case-studies/Website-Design-Presentation-34.webp" alt="Client website design project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay"><span class="portfolio-tag">Website Design</span></div>
        </div>
        <div class="portfolio-item">
          <img src="/media/case-studies/Website-Design-Presentation-35.webp" alt="Client website design project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay"><span class="portfolio-tag">Website Design</span></div>
        </div>
        <div class="portfolio-item portfolio-large">
          <img src="/media/case-studies/Website-Designs-Presentation.webp" alt="Client website designs showcase" width="600" height="400" loading="lazy" />
          <div class="portfolio-overlay"><span class="portfolio-tag">Website Design</span></div>
        </div>
        <div class="portfolio-item">
          <img src="/media/case-studies/Website-Design-Presentation-38.webp" alt="Client website design project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay"><span class="portfolio-tag">Website Design</span></div>
        </div>
        <div class="portfolio-item">
          <img src="/media/case-studies/Website-Design-Presentation-40.webp" alt="Client website design project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay"><span class="portfolio-tag">Website Design</span></div>
        </div>
        <div class="portfolio-item">
          <img src="/media/case-studies/Website-Design-Presentation-44.webp" alt="Client website design project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay"><span class="portfolio-tag">Website Design</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TEAM — White ===== -->
  <section class="section">
    <div class="container team-grid">
      <div class="team-image-wrap">
        <img src="/media/about-hero.webp" alt="ServiceLine Pro team" class="team-image" width="560" height="420" loading="lazy" />
      </div>
      <div class="team-content">
        <span class="section-eyebrow">Meet the Team</span>
        <h2>Real People. Real Results.</h2>
        <p class="team-lead">We are a focused team of marketing specialists who only work with home service businesses. That specialization is why our clients see results in weeks, not months.</p>
        <div class="team-members">
          {config.business.team.map(member => (
            <div class="team-member">
              <span class="team-member-name">{member.name}</span>
              <span class="team-member-role">{member.role}</span>
            </div>
          ))}
        </div>
        <StatBar stats={[
          { value: '5.0★', label: 'Google Rating' },
          { value: '22+', label: 'Industries' },
          { value: 'Since 2020', label: 'Tampa, FL' },
        ]} variant="light" />
      </div>
    </div>
  </section>

  <!-- ===== PROCESS — Light Alt ===== -->
  <section class="section" style="background: var(--color-gray-100);">
    <div class="container">
      <div class="section-header-center">
        <span class="section-eyebrow">How It Works</span>
        <h2>From Invisible to Unavoidable</h2>
      </div>
      <div class="process-grid">
        <div class="process-step">
          <div class="step-num">1</div>
          <div class="step-content">
            <h3>Free Strategy Call</h3>
            <p>15-minute no-pressure call. We analyze your market, your competition, and your current marketing spend.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-num">2</div>
          <div class="step-content">
            <h3>Custom Battle Plan</h3>
            <p>We build your strategy with specific timelines and KPIs. You see exactly what we are doing and how we measure success.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-num">3</div>
          <div class="step-content">
            <h3>Launch and Scale</h3>
            <p>We execute. Your phone rings. You track every lead in real time. When it works, we scale up together.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRIES — Dark ===== -->
  <section class="section section-dark">
    <div class="container">
      <span class="section-eyebrow" style="color: var(--color-primary);">Who We Work With</span>
      <h2>Built for the Businesses That Keep America Running</h2>
      <div class="industries-chips">
        {config.industries.map(ind => (
          <a href={`/industries/${ind.slug}/`} class="industry-chip">{ind.full_name}</a>
        ))}
      </div>
      <a href="/industries/" class="see-all-link-light" style="display: inline-block; margin-top: var(--space-lg); font-size: var(--text-sm); font-weight: 600; color: var(--color-primary);">View All {config.industries.length} Industries &rarr;</a>
    </div>
  </section>

  <!-- ===== REVIEWS — White ===== -->
  <ReviewsSection compact={true} maxReviews={4} />

  <!-- ===== LEAD MAGNET — Dark ===== -->
  <section class="section section-dark">
    <div class="container leadmag-grid">
      <div class="leadmag-content">
        <span class="section-eyebrow" style="color: var(--color-primary);">Free Resource</span>
        <h2>Get Your Free Market Analysis</h2>
        <p class="leadmag-lead">See exactly where you rank in your local market, what your competitors are doing, and where the biggest opportunities are.</p>
        <ul class="leadmag-includes">
          <li>Your current Google Map Pack position</li>
          <li>Top 5 competitor breakdown</li>
          <li>Citation audit and NAP consistency check</li>
          <li>Website speed and conversion analysis</li>
          <li>Recommended strategy with estimated ROI</li>
        </ul>
      </div>
      <div class="leadmag-form-wrap">
        <form class="leadmag-form" action={config.form.action} method="POST">
          <div class="form-group"><input type="text" name="name" placeholder="Full Name" required /></div>
          <div class="form-group"><input type="email" name="email" placeholder="Email" required /></div>
          <div class="form-group"><input type="tel" name="phone" placeholder="Phone Number" required /></div>
          <div class="form-group"><input type="text" name="company" placeholder="Company Name" required /></div>
          <div class="form-group"><input type="url" name="website" placeholder="Current Website (optional)" /></div>
          <div class="hp-field" aria-hidden="true"><input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></div>
          <button type="submit" class="btn btn-primary btn-lg btn-block">Get My Free Analysis</button>
          <p class="leadmag-disclaimer">No spam. No sales calls unless you want one.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA with Handwritten Annotation ===== -->
  <HandwrittenCTA
    heading="Stop Losing Jobs to Competitors Who Showed Up First"
    buttonText="Schedule Your Strategy Call"
    annotation="No obligation. Just a 15-minute call."
  />

  <Footer slot="footer" />
</Base>

<style>
  /* ===== HERO — Full Viewport, Dark, Massive ===== */
  .hero {
    min-height: 70vh;
    max-height: 70vh;
    display: flex;
    align-items: center;
    background: var(--color-dark);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
    padding: var(--space-3xl) 0;
  }
  .hero-texture {
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.02) 10px, rgba(255,255,255,0.02) 11px),
      radial-gradient(circle at 20% 80%, rgba(192,57,43,0.18) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(192,57,43,0.1) 0%, transparent 40%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 1;
    max-width: 800px;
  }
  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }
  .hero h1 {
    color: var(--color-white);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.05;
    margin-bottom: var(--space-md);
  }
  .hero-ctas {
    margin-top: var(--space-xl);
  }

  /* ===== TRUST STRIP ===== */
  .trust-strip {
    background: var(--color-dark);
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: var(--space-lg) 0 var(--space-xl);
  }

  /* ===== BOOST SECTION ===== */
  .boost-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .boost-grid { grid-template-columns: 1.2fr 1fr; }
  }
  .boost-content h2 { color: var(--color-white); margin-bottom: var(--space-md); }
  .boost-lead { color: rgba(255,255,255,0.7); line-height: 1.7; margin-bottom: var(--space-xl); max-width: 520px; }
  .boost-metrics {
    display: flex; gap: var(--space-xl); margin-bottom: var(--space-xl);
    padding: var(--space-lg) 0; border-top: 1px solid rgba(255,255,255,0.08);
  }
  .boost-val { display: block; font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 800; color: var(--color-primary); }
  .boost-lbl { display: block; font-size: 0.7rem; color: rgba(255,255,255,0.45); }
  .boost-visual img { width: 100%; max-width: 550px; height: auto; border-radius: 10px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }

  /* ===== PROBLEMS ===== */
  .problems-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-lg); margin-top: var(--space-xl); }
  .problem-card { padding: var(--space-xl); background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: 10px; transition: transform 0.2s, box-shadow 0.2s; }
  .problem-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .problem-num { font-family: var(--font-heading); font-size: var(--text-3xl); font-weight: 800; color: rgba(192,57,43,0.1); line-height: 1; margin-bottom: var(--space-sm); }
  .problem-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-sm); text-transform: none; }
  .problem-card p { font-size: var(--text-sm); color: var(--color-text-light); line-height: 1.6; }

  /* ===== SPECTRUM ===== */
  .spectrum-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); }
  @media (min-width: 1024px) { .spectrum-grid { grid-template-columns: 1fr 1fr; align-items: center; } }
  .spectrum-content h2 { color: var(--color-white); margin-bottom: var(--space-md); }
  .spectrum-lead { color: rgba(255,255,255,0.7); line-height: 1.7; max-width: 480px; }
  .spectrum-lead :global(strong) { color: var(--color-white); }
  .spectrum-certs { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
  .spectrum-cert { font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.75rem; border: 1px solid rgba(255,255,255,0.15); border-radius: 4px; color: rgba(255,255,255,0.5); }
  .spectrum-img { width: 100%; height: auto; border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.3); }

  /* ===== RESULTS ===== */
  .results-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-lg); margin-top: var(--space-xl); }
  .result-card {
    padding: var(--space-xl); background: var(--color-white); border: 1px solid var(--color-gray-200);
    border-left: 3px solid var(--color-primary); border-radius: 0 10px 10px 0;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .result-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .result-category { display: block; font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-primary); margin-bottom: var(--space-xs); }
  .result-metric { font-size: var(--text-xl); margin-bottom: var(--space-xs); text-transform: none; }
  .result-client { display: block; font-size: var(--text-sm); color: var(--color-text-muted); }
  .result-detail { display: block; font-size: 0.7rem; color: var(--color-text-faint); margin-top: var(--space-xs); }

  /* ===== PORTFOLIO ===== */
  .portfolio-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-md); }
  @media (min-width: 768px) { .portfolio-grid { grid-template-columns: repeat(4, 1fr); } }
  .portfolio-item { position: relative; overflow: hidden; border-radius: 8px; aspect-ratio: 4/3; cursor: pointer; }
  .portfolio-item.portfolio-large { grid-column: span 2; }
  .portfolio-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .portfolio-item:hover img { transform: scale(1.08); }
  .portfolio-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(26,26,26,0.8) 0%, transparent 60%); display: flex; align-items: flex-end; padding: var(--space-lg); opacity: 0; transition: opacity 0.3s; }
  .portfolio-item:hover .portfolio-overlay { opacity: 1; }
  .portfolio-tag { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-white); background: var(--color-primary); padding: 0.25rem 0.625rem; border-radius: 4px; }

  /* ===== TEAM ===== */
  .team-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); }
  @media (min-width: 1024px) { .team-grid { grid-template-columns: 1fr 1.1fr; align-items: center; } }
  .team-image-wrap { position: relative; }
  .team-image { width: 100%; height: auto; border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.1); }
  .team-lead { color: var(--color-text-light); line-height: 1.7; margin-bottom: var(--space-xl); max-width: 480px; }
  .team-members { display: flex; flex-direction: column; gap: var(--space-md); margin-bottom: var(--space-xl); padding: var(--space-lg) 0; border-top: 1px solid var(--color-gray-200); border-bottom: 1px solid var(--color-gray-200); }
  .team-member { display: flex; align-items: center; gap: var(--space-md); }
  .team-member-name { font-family: var(--font-heading); font-weight: 700; font-size: var(--text-base); }
  .team-member-role { font-size: var(--text-sm); color: var(--color-text-muted); }

  /* ===== PROCESS ===== */
  .process-grid { display: flex; flex-direction: column; align-items: center; gap: 0; max-width: 600px; margin: 0 auto; }
  .process-step { display: flex; gap: var(--space-lg); align-items: flex-start; width: 100%; }
