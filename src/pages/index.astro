  .service-mega-badge { position: absolute; top: var(--space-md); right: var(--space-md); font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); background: rgba(192,57,43,0.15); padding: 0.25rem 0.625rem; border-radius: 4px; z-index: 3; backdrop-filter: blur(8px); }
