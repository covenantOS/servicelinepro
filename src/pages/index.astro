---
import Base from '../layouts/Base.astro';
import config from '../lib/config';
import realReviews from '../data/real-reviews.json';
const caseStudies = config.case_studies || [];
const services = config.services || [];
const featured = caseStudies.filter(cs => cs.metrics?.primary).slice(0, 6);
---

<Base title={`${config.business.name} — ${config.business.tagline}`} description={config.business.description}>

<!-- ====== HERO ====== -->
<section class="hero section">
  <div class="container">
    <div class="hero__inner">
      <div class="hero__text">
        <div class="hero__badge">
          <span class="hero__badge-stars">★★★★★</span>
          5.0 Google Rating — 22 Reviews
        </div>
        <h1 class="hero__headline">We Get Your Business to the Top of Google</h1>
        <p class="hero__sub">
          Google SEO. Google Ads. TV &amp; streaming ads. Websites. 50+ businesses trust us to bring them more calls, more customers, and more revenue.
        </p>
        <div class="hero__actions">
          <a href="/case-studies/" class="btn btn--primary btn--lg">See Our Results</a>
          <a href={`tel:${config.business.phone_raw}`} class="btn btn--outline btn--lg">
            Call {config.business.phone}
          </a>
        </div>
      </div>
      <div class="hero__image">
        <img
          src="/media/seo-hero.webp"
          alt="Google Maps Top 3 ranking screenshot"
          width="640"
          height="360"
          loading="eager"
          fetchpriority="high"
          class="hero__img"
        />
      </div>
    </div>
  </div>
</section>

<!-- ====== TRUST BAR ====== -->
<section class="trust-bar bg-gray">
  <div class="container">
    <div class="stats-row">
      <div class="stat">
        <span class="stat__number">50+</span>
        <span class="stat__label">Case Studies</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat__number">5.0</span>
        <span class="stat__label">Google Rating</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat__number">$0</span>
        <span class="stat__label">Agency Fees</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat__number">48</span>
        <span class="stat__label">States Served</span>
      </div>
    </div>
  </div>
</section>

<!-- ====== WHAT WE DO ====== -->
<section class="section">
  <div class="container">
    <div class="section-label">WHAT WE DO</div>
    <h2 class="section-title">Four Ways We Grow Your Business</h2>
    <div class="services-grid">
      <div class="card service-card reveal-up">
        <div class="service-card__image-wrap">
          <img
            src="/media/seo-hero.webp"
            alt="Google SEO ranking results"
            class="service-card__image"
            loading="lazy"
            width="400"
            height="225"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Google SEO</h3>
          <p class="service-card__desc">We rank your business in Google's Top 3 Map Pack in 90 days. Free 10-day ranking boost to start.</p>
          <a href="/services/local-seo/" class="service-card__link">Learn More →</a>
        </div>
      </div>

      <div class="card service-card reveal-up">
        <div class="service-card__image-wrap">
          <img
            src="/media/ppc-hero.webp"
            alt="Google Ads PPC dashboard"
            class="service-card__image"
            loading="lazy"
            width="400"
            height="225"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Google Ads &amp; PPC</h3>
          <p class="service-card__desc">Google Ads with $0 agency fees on budgets over $5K/mo through Spectrum Reach. Your entire budget goes to ads.</p>
          <a href="/services/google-ads/" class="service-card__link">Learn More →</a>
        </div>
      </div>

      <div class="card service-card reveal-up">
        <div class="service-card__image-wrap">
          <img
            src="/media/tv-streaming-hero.webp"
            alt="TV and streaming advertising"
            class="service-card__image"
            loading="lazy"
            width="400"
            height="225"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">TV &amp; Streaming Ads</h3>
          <p class="service-card__desc">Professional TV commercials on 200+ streaming channels across 48 states. Free video production included.</p>
          <a href="/services/tv-streaming/" class="service-card__link">Learn More →</a>
        </div>
      </div>

      <div class="card service-card reveal-up">
        <div class="service-card__image-wrap">
          <img
            src="/media/webdesign-hero.webp"
            alt="Custom website design on iMac and iPad"
            class="service-card__image"
            loading="lazy"
            width="400"
            height="225"
          />
        </div>
        <div class="service-card__body">
          <h3 class="service-card__title">Website Design</h3>
          <p class="service-card__desc">Custom websites that load in under 2 seconds and turn visitors into phone calls. Starting at $2,500.</p>
          <a href="/services/website-design/" class="service-card__link">Learn More →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ====== CASE STUDIES ====== -->
<section class="section bg-gray">
  <div class="container">
    <div class="section-label">CLIENT RESULTS</div>
    <h2 class="section-title">Real Numbers From Real Clients</h2>
    {featured.length > 0 ? (
      <div class="case-grid">
        {featured.map((cs) => (
          <div class="card case-card reveal-up">
            <div class="case-card__header">
              <span class="case-card__industry">{cs.industry || cs.category}</span>
            </div>
            <h3 class="case-card__title">{cs.title}</h3>
            <div class="case-card__metric">{cs.metrics?.primary}</div>
            {cs.metrics?.secondary && (
              <div class="case-card__secondary">{cs.metrics.secondary}</div>
            )}
          </div>
        ))}
      </div>
    ) : (
      <div class="case-grid">
        <div class="card case-card">
          <span class="case-card__industry">HVAC</span>
          <h3 class="case-card__title">HVAC Company — Tampa, FL</h3>
          <div class="case-card__metric">312% More Calls</div>
          <div class="case-card__secondary">In first 90 days of SEO</div>
        </div>
        <div class="card case-card">
          <span class="case-card__industry">Plumbing</span>
          <h3 class="case-card__title">Plumbing Contractor — Orlando, FL</h3>
          <div class="case-card__metric">#1 Google Ranking</div>
          <div class="case-card__secondary">For 14 local keywords</div>
        </div>
        <div class="card case-card">
          <span class="case-card__industry">Roofing</span>
          <h3 class="case-card__title">Roofing Company — Sarasota, FL</h3>
          <div class="case-card__metric">$180K New Revenue</div>
          <div class="case-card__secondary">From Google Ads in 6 months</div>
        </div>
      </div>
    )}
    <div class="section-cta">
      <a href="/case-studies/" class="btn btn--outline">See All 50+ Case Studies →</a>
    </div>
  </div>
</section>

<!-- ====== HOW WE'RE DIFFERENT ====== -->
<section class="section">
  <div class="container">
    <div class="diff__inner">
      <div class="diff__image">
        <img
          src="/media/will-hamilton.webp"
          alt="Will Hamilton, CEO of ServiceLine Pro"
          class="diff__photo"
          loading="lazy"
          width="480"
          height="600"
        />
      </div>
      <div class="diff__content">
        <div class="section-label">WHY SERVICELINE PRO</div>
        <h2 class="section-title" style="margin-bottom: 2rem;">A Real Team. Real Results. No Gimmicks.</h2>
        <ul class="diff__list">
          <li class="diff__item">
            <span class="diff__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="10" fill="#c0392b" opacity="0.12"/>
                <path d="M6 10l3 3 5-5" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <strong>$0 agency fee on Google Ads over $5K/mo</strong>
              <p>Every dollar of your ad budget goes to reaching customers — not paying our overhead.</p>
            </div>
          </li>
          <li class="diff__item">
            <span class="diff__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="10" fill="#c0392b" opacity="0.12"/>
                <path d="M6 10l3 3 5-5" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <strong>Rank in Google's Top 3 in 90 days — or we work free</strong>
              <p>We back our SEO with a performance guarantee. If we don't deliver, we keep working at no charge.</p>
            </div>
          </li>
          <li class="diff__item">
            <span class="diff__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="10" fill="#c0392b" opacity="0.12"/>
                <path d="M6 10l3 3 5-5" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <strong>3-person team — you talk to the people doing the work</strong>
              <p>No account managers. No hand-offs. You deal directly with the people executing your campaigns.</p>
            </div>
          </li>
          <li class="diff__item">
            <span class="diff__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="10" fill="#c0392b" opacity="0.12"/>
                <path d="M6 10l3 3 5-5" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <strong>50+ client results you can verify</strong>
              <p>Real case studies with real numbers. We'll walk you through them on your first call.</p>
            </div>
          </li>
          <li class="diff__item">
            <span class="diff__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="10" fill="#c0392b" opacity="0.12"/>
                <path d="M6 10l3 3 5-5" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <strong>Tampa-based, real office, real people</strong>
              <p>We're local. You can visit us. We're not an overseas call center or a faceless platform.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ====== REVIEWS ====== -->
<section class="section bg-gray">
  <div class="container">
    <div class="section-label">CLIENT REVIEWS</div>
    <h2 class="section-title">What Our Clients Say</h2>
    <div class="reviews-grid">
      {realReviews.slice(0, 6).map((review) => (
        <div class="card review-card reveal-up">
          <div class="review-card__stars">
            {'★'.repeat(review.rating)}
          </div>
          <p class="review-card__text">"{review.text}"</p>
          <div class="review-card__footer">
            <span class="review-card__author">{review.author}</span>
            <span class="review-card__date">{review.date}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ====== CTA BANNER ====== -->
<section class="section bg-dark cta-banner">
  <div class="container">
    <div class="cta-banner__inner">
      <h2 class="cta-banner__headline">Ready to Get More Calls From Google?</h2>
      <p class="cta-banner__sub">
        Schedule a free strategy call. We'll show you exactly where you rank, where your competitors rank, and what it takes to get to #1.
      </p>
      <div class="cta-banner__actions">
        <a href="/contact/" class="btn btn--primary btn--lg">Get Your Free Strategy Call</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn--outline-light btn--lg">
          Call {config.business.phone}
        </a>
      </div>
    </div>
  </div>
</section>

</Base>

<style>
/* ====== HERO ====== */
.hero {
  padding-top: clamp(3rem, 6vw, 5rem);
  padding-bottom: clamp(3rem, 6vw, 5rem);
  background: #ffffff;
}
.hero__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 4vw, 4rem);
  align-items: center;
}
@media (max-width: 768px) {
  .hero__inner {
    grid-template-columns: 1fr;
  }
  .hero__image {
    order: -1;
  }
}
.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: #fff8f8;
  border: 1px solid rgba(192, 57, 43, 0.2);
  color: #c0392b;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  padding: 0.4rem 0.85rem;
  border-radius: 999px;
  margin-bottom: 1.5rem;
}
.hero__badge-stars {
  color: #f4c542;
  letter-spacing: -0.05em;
}
.hero__headline {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4.5vw, 3.25rem);
  font-weight: 800;
  line-height: 1.1;
  color: var(--gray-900);
  margin-bottom: 1.25rem;
  letter-spacing: -0.02em;
}
.hero__sub {
  font-size: clamp(1rem, 1.5vw, 1.15rem);
  color: var(--gray-600);
  line-height: 1.65;
  margin-bottom: 2rem;
  max-width: 520px;
}
.hero__actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}
.hero__img {
  width: 100%;
  height: auto;
  border-radius: var(--radius-md);
  box-shadow: 0 8px 32px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
  object-fit: cover;
  aspect-ratio: 16/9;
}

/* ====== TRUST BAR ====== */
.trust-bar {
  padding: clamp(2rem, 3vw, 3rem) 0;
}
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
}
.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1rem 2.5rem;
}
.stat__number {
  font-family: var(--font-heading);
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 800;
  color: #c0392b;
  line-height: 1;
}
.stat__label {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--gray-600);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-top: 0.35rem;
}
.stat-divider {
  width: 1px;
  height: 3rem;
  background: var(--gray-300);
}
@media (max-width: 600px) {
  .stats-row {
    gap: 0.5rem;
  }
  .stat { padding: 0.75rem 1.25rem; }
  .stat-divider { display: none; }
}

/* ====== SECTION LABELS & TITLES ====== */
.section-label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #c0392b;
  margin-bottom: 0.75rem;
}
.section-title {
  font-family: var(--font-heading);
  font-size: clamp(1.6rem, 3vw, 2.25rem);
  font-weight: 800;
  color: var(--gray-900);
  line-height: 1.2;
  margin-bottom: 2.5rem;
  letter-spacing: -0.02em;
}
.section-cta {
  text-align: center;
  margin-top: 2.5rem;
}

/* ====== SERVICES GRID ====== */
.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}
@media (max-width: 1024px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .services-grid { grid-template-columns: 1fr; }
}
.service-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 0;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.service-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.12);
}
.service-card__image-wrap {
  width: 100%;
  overflow: hidden;
}
.service-card__image {
  width: 100%;
  height: auto;
  aspect-ratio: 16/9;
  object-fit: cover;
  border-radius: var(--radius-md) var(--radius-md) 0 0;
  display: block;
  transition: transform 0.35s ease;
}
.service-card:hover .service-card__image {
  transform: scale(1.03);
}
.service-card__body {
  padding: 1.25rem 1.5rem 1.5rem;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.service-card__title {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--gray-900);
  margin-bottom: 0.6rem;
}
.service-card__desc {
  font-size: 0.9rem;
  color: var(--gray-600);
  line-height: 1.6;
  flex: 1;
  margin-bottom: 1rem;
}
.service-card__link {
  font-size: 0.85rem;
  font-weight: 600;
  color: #c0392b;
  text-decoration: none;
  transition: color 0.2s;
}
.service-card__link:hover { color: #a93226; }

/* ====== CASE STUDIES ====== */
.case-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
@media (max-width: 900px) {
  .case-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 580px) {
  .case-grid { grid-template-columns: 1fr; }
}
.case-card {
  padding: 1.75rem;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.case-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 28px rgba(0,0,0,0.1);
}
.case-card__header {
  margin-bottom: 0.75rem;
}
.case-card__industry {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #c0392b;
  background: rgba(192,57,43,0.08);
  padding: 0.25rem 0.65rem;
  border-radius: 999px;
}
.case-card__title {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 1rem;
  line-height: 1.4;
}
.case-card__metric {
  font-family: var(--font-heading);
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  font-weight: 800;
  color: #c0392b;
  line-height: 1.1;
  margin-bottom: 0.4rem;
}
.case-card__secondary {
  font-size: 0.85rem;
  color: var(--gray-500);
}

/* ====== HOW WE'RE DIFFERENT ====== */
.diff__inner {
  display: grid;
  grid-template-columns: 1fr 1.35fr;
  gap: clamp(2rem, 5vw, 5rem);
  align-items: center;
}
@media (max-width: 768px) {
  .diff__inner {
    grid-template-columns: 1fr;
  }
  .diff__image { display: none; }
}
.diff__photo {
  width: 100%;
  height: auto;
  border-radius: var(--radius-md);
  box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  object-fit: cover;
  max-height: 560px;
  object-position: top;
}
.diff__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.diff__item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}
.diff__icon {
  flex-shrink: 0;
  margin-top: 0.1rem;
}
.diff__item strong {
  display: block;
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 700;
  color: var(--gray-900);
  margin-bottom: 0.25rem;
}
.diff__item p {
  font-size: 0.9rem;
  color: var(--gray-600);
  line-height: 1.6;
  margin: 0;
}

/* ====== REVIEWS ====== */
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
@media (max-width: 900px) {
  .reviews-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 580px) {
  .reviews-grid { grid-template-columns: 1fr; }
}
.review-card {
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  background: #ffffff;
}
.review-card__stars {
  color: #f4c542;
  font-size: 1.1rem;
  letter-spacing: 0.05em;
  margin-bottom: 1rem;
}
.review-card__text {
  font-size: 0.9rem;
  color: var(--gray-700);
  line-height: 1.7;
  flex: 1;
  margin-bottom: 1.25rem;
  font-style: italic;
}
.review-card__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.review-card__author {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--gray-900);
}
.review-card__date {
  font-size: 0.78rem;
  color: var(--gray-500);
}

/* ====== CTA BANNER ====== */
.cta-banner {
  text-align: center;
}
.cta-banner__inner {
  max-width: 680px;
  margin: 0 auto;
}
.cta-banner__headline {
  font-family: var(--font-heading);
  font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
  margin-bottom: 1.25rem;
  letter-spacing: -0.02em;
}
.cta-banner__sub {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.75);
  line-height: 1.65;
  margin-bottom: 2rem;
}
.cta-banner__actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}
.btn--outline-light {
  background: transparent;
  border: 2px solid rgba(255,255,255,0.35);
  color: #ffffff;
  transition: border-color 0.2s, background 0.2s;
}
.btn--outline-light:hover {
  border-color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.08);
}
.btn--lg {
  padding: 0.9rem 1.75rem;
  font-size: 1rem;
}
</style>
