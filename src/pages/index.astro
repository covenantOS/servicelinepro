  .spectrum-stats { display: flex; gap: var(--space-xl); margin-bottom: var(--space-lg); margin-top: var(--space-md); }
  .spectrum-stat-value { display: block; font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 800; color: var(--color-dark); }
  .spectrum-stat-label { display: block; font-size: 0.7rem; color: var(--color-text-muted); }
