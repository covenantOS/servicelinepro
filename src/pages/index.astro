---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import config from '../lib/config';
import reviews from '../data/real-reviews.json';

const title = "Home Service Marketing Agency | Local SEO, Google Ads, Web Design & TV Advertising";
const description = config.business.description;
const topReviews = reviews.slice(0, 4);
---

<Base title={title} description={description}>
  <Header slot="header" />

  <!-- ===== SECTION 1: HERO ===== -->
  <section class="hp-hero">
    <div class="hp-hero__bg"></div>
    <div class="hp-container hp-hero__grid">
      <!-- Left: Copy -->
      <div class="hp-hero__copy">
        <div class="hp-hero__badges">
          <span class="hp-badge">Google Certified</span>
          <span class="hp-badge">Spectrum Reach Partner</span>
        </div>
        <h1 class="hp-hero__h1">Local SEO & Google Ads<br/>Built to Scale You to <span class="hp-text-red">$10M</span></h1>
        <p class="hp-hero__sub">We help home service businesses go from $1M to $10M with Map Pack SEO and $0 Fee Google Ads.</p>
        <ul class="hp-hero__bullets">
          <li>
            <span class="hp-bullet-icon">✓</span>
            <span><strong>Map Pack Rankings</strong> — rank top 3 or don't pay</span>
          </li>
          <li>
            <span class="hp-bullet-icon">✓</span>
            <span><strong>$0 Agency Fee</strong> — on $5K+ ad spend through Spectrum Reach</span>
          </li>
          <li>
            <span class="hp-bullet-icon">✓</span>
            <span><strong>Free 10-Day SEO Boost</strong> — no credit card, no commitment</span>
          </li>
        </ul>
        <div class="hp-hero__ctas">
          <a href="/contact/" class="hp-btn hp-btn--red">Book Strategy Call</a>
          <a href="#case-studies" class="hp-btn hp-btn--ghost">See Our Results</a>
        </div>
      </div>

      <!-- Right: Lead Form -->
      <div class="hp-hero__form-wrap">
        <form class="hp-lead-form" action="/contact/" method="GET">
          <h3 class="hp-lead-form__title">Get Your Free Strategy Call</h3>
          <p class="hp-lead-form__sub">Fill out the form and we'll reach out within 24 hours.</p>
          <input type="text" name="name" placeholder="Full Name" required class="hp-input" />
          <input type="email" name="email" placeholder="Email Address" required class="hp-input" />
          <input type="tel" name="phone" placeholder="Phone Number" class="hp-input" />
          <input type="text" name="company" placeholder="Company Name" class="hp-input" />
          <select name="service" class="hp-input">
            <option value="">Select a Service</option>
            <option value="local-seo">Local SEO</option>
            <option value="ppc">Google Ads (PPC)</option>
            <option value="website-design">Website Design</option>
            <option value="tv-streaming">TV & Streaming Ads</option>
            <option value="other">Other</option>
          </select>
          <button type="submit" class="hp-btn hp-btn--red hp-btn--full">Let's Get Started</button>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: SOCIAL PROOF STRIP ===== -->
  <section class="hp-proof-strip">
    <div class="hp-container">
      <div class="hp-proof-strip__inner">
        <div class="hp-proof-strip__rating">
          <svg class="hp-google-g" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <span class="hp-proof-strip__score">5.0</span>
          <span class="hp-proof-strip__stars">★★★★★</span>
          <span class="hp-proof-strip__count">20 Reviews</span>
        </div>
        <div class="hp-proof-strip__divider"></div>
        <div class="hp-proof-strip__partners">
          <span>Spectrum Reach</span>
          <span class="hp-dot">•</span>
          <span>Google Partner</span>
          <span class="hp-dot">•</span>
          <span>Yahoo</span>
          <span class="hp-dot">•</span>
          <span>TAG Certified</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 3: PROBLEM SECTION ===== -->
  <section class="hp-section hp-section--dark-alt">
    <div class="hp-container">
      <span class="hp-eyebrow">The Problem</span>
      <h2 class="hp-h2">Why Your Current Marketing Isn't Working</h2>
      <div class="hp-card-grid hp-card-grid--3">
        <div class="hp-card">
          <div class="hp-card__icon">🎯</div>
          <h3 class="hp-card__title">Invisible to Customers</h3>
          <p class="hp-card__text">Your competitors are booking the jobs you should have. If you're not in the Map Pack, you don't exist.</p>
        </div>
        <div class="hp-card">
          <div class="hp-card__icon">📞</div>
          <h3 class="hp-card__title">Clicks ≠ Calls</h3>
          <p class="hp-card__text">Traffic is useless if it doesn't turn into booked jobs. Most agencies optimize for vanity metrics, not revenue.</p>
        </div>
        <div class="hp-card">
          <div class="hp-card__icon">📅</div>
          <h3 class="hp-card__title">Inconsistent Lead Flow</h3>
          <p class="hp-card__text">You can't scale on a feast-or-famine schedule. Your pipeline should be predictable, not a rollercoaster.</p>
        </div>
      </div>
      <p class="hp-transition-text">Two Services. One Mission. Fill Your Calendar.</p>
    </div>
  </section>

  <!-- ===== SECTION 4: SERVICES ===== -->
  <section class="hp-section hp-section--dark">
    <div class="hp-container">
      <span class="hp-eyebrow">The Solution</span>
      <h2 class="hp-h2">Two Weapons to Dominate Your Market</h2>
      <div class="hp-services-grid">
        <!-- SEO Card -->
        <div class="hp-service-card hp-service-card--main">
          <div class="hp-service-card__img-wrap">
            <img src="/media/local-seo-graphic.webp" alt="Local SEO Rankings" loading="lazy" />
          </div>
          <div class="hp-service-card__body">
            <h3>Local Ranking SEO</h3>
            <p class="hp-service-card__tagline">Rank Top 3 in 90 Days or Don't Pay</p>
            <ul class="hp-check-list">
              <li>Full GBP Optimization</li>
              <li>Targeted Keyword Ranking</li>
              <li>Geo-Grid Tracking</li>
              <li>Free 10-Day Boost</li>
            </ul>
            <a href="/services/local-seo/" class="hp-link-arrow">Learn About Local SEO →</a>
          </div>
        </div>
        <!-- PPC Card -->
        <div class="hp-service-card hp-service-card--main">
          <div class="hp-service-card__img-wrap">
            <img src="/media/ppc-graphic.webp" alt="Google Ads PPC" loading="lazy" />
          </div>
          <div class="hp-service-card__body">
            <h3>Google, Bing & Yahoo Ads</h3>
            <p class="hp-service-card__tagline">$0 Agency Fee on $5K+ Spend</p>
            <ul class="hp-check-list">
              <li>First-Party Data from 30M+ Households</li>
              <li>Multi-Platform Coverage</li>
              <li>30-50% Higher CTR</li>
              <li>Real-Time Optimization</li>
            </ul>
            <a href="/services/ppc/" class="hp-link-arrow">Learn About Google Ads →</a>
          </div>
        </div>
      </div>
      <!-- Secondary services -->
      <div class="hp-services-secondary">
        <a href="/services/website-design/" class="hp-service-mini">
          <div class="hp-service-mini__icon">🖥</div>
          <div>
            <h4>Website Design</h4>
            <p>Sub-2-second loads. Conversion-focused. You own it.</p>
          </div>
        </a>
        <a href="/services/tv-streaming/" class="hp-service-mini">
          <div class="hp-service-mini__icon">📺</div>
          <div>
            <h4>TV & Streaming Ads</h4>
            <p>Free video production with every FL campaign.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 5: REAL GOOGLE REVIEWS ===== -->
  <section class="hp-section hp-section--light" id="reviews">
    <div class="hp-container">
      <span class="hp-eyebrow hp-eyebrow--dark">What Our Clients Say</span>
      <div class="hp-reviews-layout">
        <div class="hp-reviews-left">
          <svg class="hp-google-g-lg" width="48" height="48" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <div class="hp-reviews-left__rating">5.0</div>
          <div class="hp-reviews-left__stars">★★★★★</div>
          <p class="hp-reviews-left__count">20 reviews on Google</p>
          <a href="https://www.google.com/maps/place/ServiceLine+Pro" target="_blank" rel="noopener" class="hp-link-arrow hp-link-arrow--dark">Read All Reviews on Google →</a>
        </div>
        <div class="hp-reviews-right">
          {topReviews.map((review) => (
            <div class="hp-review-card">
              <div class="hp-review-card__header">
                <div class="hp-review-card__avatar">{review.author.charAt(0)}</div>
                <div>
                  <div class="hp-review-card__name">{review.author}</div>
                  <div class="hp-review-card__stars">★★★★★</div>
                </div>
              </div>
              <p class="hp-review-card__text">{review.text.length > 160 ? review.text.slice(0, 160) + '…' : review.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 6: CASE STUDIES ===== -->
  <section class="hp-section hp-section--dark" id="case-studies">
    <div class="hp-container">
      <span class="hp-eyebrow">Real Results</span>
      <h2 class="hp-h2">The ServiceLine Effect</h2>
      <div class="hp-card-grid hp-card-grid--3">
        <div class="hp-case-card">
          <div class="hp-case-card__img">
            <img src="/media/case-studies/True-Corp-Work-Trucks.webp" alt="True Corp Construction" loading="lazy" />
            <div class="hp-case-card__overlay">
              <span class="hp-case-card__label">True Corp Construction</span>
              <span class="hp-case-card__result">Full Digital Transformation</span>
            </div>
          </div>
        </div>
        <div class="hp-case-card">
          <div class="hp-case-card__img">
            <img src="/media/case-studies/Website-Designs-Presentation.webp" alt="Website Portfolio" loading="lazy" />
            <div class="hp-case-card__overlay">
              <span class="hp-case-card__label">Website Portfolio</span>
              <span class="hp-case-card__result">20+ Websites Delivered</span>
            </div>
          </div>
        </div>
        <div class="hp-case-card">
          <div class="hp-case-card__img">
            <img src="/media/case-studies/Job-Revenue-Total.webp" alt="Revenue Tracking" loading="lazy" />
            <div class="hp-case-card__overlay">
              <span class="hp-case-card__label">Revenue Tracking</span>
              <span class="hp-case-card__result">Real-Time ROI Dashboard</span>
            </div>
          </div>
        </div>
      </div>
      <div class="hp-section-cta">
        <a href="/case-studies/" class="hp-btn hp-btn--ghost">See All Case Studies →</a>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 7: HOW IT WORKS ===== -->
  <section class="hp-section hp-section--dark-alt">
    <div class="hp-container">
      <span class="hp-eyebrow">Next Steps</span>
      <h2 class="hp-h2">How We Take You From Invisible to Unavoidable</h2>
      <div class="hp-steps">
        <div class="hp-step">
          <span class="hp-step__num">01</span>
          <h3 class="hp-step__title">Free Strategy Call</h3>
          <p class="hp-step__text">15-minute no-pressure call. We analyze your market and competition.</p>
        </div>
        <div class="hp-step">
          <span class="hp-step__num">02</span>
          <h3 class="hp-step__title">Custom Battle Plan</h3>
          <p class="hp-step__text">You see exactly what we're doing, when, and how we measure success.</p>
        </div>
        <div class="hp-step">
          <span class="hp-step__num">03</span>
          <h3 class="hp-step__title">Launch & Dominate</h3>
          <p class="hp-step__text">We execute. Your phone rings. You track every lead in real time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 8: MEET THE TEAM ===== -->
  <section class="hp-section hp-section--light" id="team">
    <div class="hp-container hp-team-section">
      <span class="hp-eyebrow hp-eyebrow--dark">Our Team</span>
      <h2 class="hp-h2 hp-h2--dark">Meet the Team Behind Your Growth</h2>
      <div class="hp-team-photo-wrap">
        <img src="/media/team-photo-gbp.jpg" alt="ServiceLine Pro Team" class="hp-team-photo" loading="lazy" />
      </div>
      <p class="hp-team-copy">We started ServiceLine Pro with a simple belief: home service businesses deserve marketing that actually works. Every team member is invested in your growth — from strategy to execution.</p>
      <div class="hp-team-grid">
        {config.business.team.map((member: { name: string; role: string }) => (
          <div class="hp-team-member">
            <span class="hp-team-member__name">{member.name}</span>
            <span class="hp-team-member__role">{member.role}</span>
          </div>
        ))}
      </div>
      <div class="hp-section-cta">
        <a href="/about/" class="hp-btn hp-btn--dark">About Our Team →</a>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 9: WHY SERVICELINE ===== -->
  <section class="hp-section hp-section--dark">
    <div class="hp-container">
      <span class="hp-eyebrow">Why ServiceLine</span>
      <h2 class="hp-h2">Built Different. Built for You.</h2>
      <div class="hp-card-grid hp-card-grid--3">
        <div class="hp-card">
          <div class="hp-card__icon">🏠</div>
          <h3 class="hp-card__title">Built for Home Services</h3>
          <p class="hp-card__text">We know your industry. Our strategies drive real growth for painting, HVAC, plumbing, contracting, and more.</p>
        </div>
        <div class="hp-card">
          <div class="hp-card__icon">📈</div>
          <h3 class="hp-card__title">Growth Without Burnout</h3>
          <p class="hp-card__text">We scale at a pace your team can handle. No wasted leads, no overwhelmed staff.</p>
        </div>
        <div class="hp-card">
          <div class="hp-card__icon">🤝</div>
          <h3 class="hp-card__title">Personal Service, Real Results</h3>
          <p class="hp-card__text">Dedicated team, direct communication, strategy built for your goals. No call centers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 10: FAQ ===== -->
  <section class="hp-section hp-section--light" id="faq">
    <div class="hp-container hp-faq-section">
      <span class="hp-eyebrow hp-eyebrow--dark">FAQ</span>
      <h2 class="hp-h2 hp-h2--dark">Frequently Asked Questions</h2>
      <div class="hp-faq-list">
        <details class="hp-faq">
          <summary>How fast will I see results?</summary>
          <p>SEO typically shows measurable improvements within 30-60 days. PPC campaigns can generate leads within the first week of launch. Every market is different, and we'll set clear expectations during your strategy call.</p>
        </details>
        <details class="hp-faq">
          <summary>How much time will this take from me or my team?</summary>
          <p>Very little. After an initial strategy call, we handle everything. You'll get regular updates and reports without lifting a finger.</p>
        </details>
        <details class="hp-faq">
          <summary>What experience do you have with businesses like mine?</summary>
          <p>We specialize exclusively in home service businesses — HVAC, plumbing, painting, roofing, electrical, contracting, and more. Every strategy is built for your industry.</p>
        </details>
        <details class="hp-faq">
          <summary>Can I pause or stop services if I need to?</summary>
          <p>Absolutely. We don't believe in trapping clients. You can adjust or pause services based on your business needs.</p>
        </details>
        <details class="hp-faq">
          <summary>Who will be my main point of contact?</summary>
          <p>You'll have a dedicated team with direct access. No call centers, no ticket systems — just real people who know your account.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 11: FINAL CTA ===== -->
  <section class="hp-final-cta">
    <div class="hp-container">
      <h2 class="hp-final-cta__h2">Ready to Fill Your Calendar?</h2>
      <p class="hp-final-cta__sub">Book a free 15-minute strategy call. No pressure, no obligation.</p>
      <a href="/contact/" class="hp-btn hp-btn--red hp-btn--lg">Book Your Strategy Call</a>
      <p class="hp-final-cta__phone"><a href="tel:+18135213199">(813) 521-3199</a></p>
      <div class="hp-final-cta__social">
        <a href="https://www.facebook.com/servicelinepro" target="_blank" rel="noopener" aria-label="Facebook">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.google.com/maps/place/ServiceLine+Pro" target="_blank" rel="noopener" aria-label="Google Business">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="currentColor"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="currentColor"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="currentColor"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="currentColor"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  /* ============================================
     HOMEPAGE — Complete Rebuild
     Inspired by Hook Agency + Scorpion
     Dark, cinematic, conversion-focused
     ============================================ */

  /* --- Shared Utilities --- */
  .hp-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hp-text-red { color: var(--color-primary); }

  .hp-eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .hp-eyebrow--dark {
    color: var(--color-primary);
  }

  .hp-h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 2.5rem;
    line-height: 1.15;
  }

  .hp-h2--dark {
    color: var(--color-dark);
  }

  .hp-section {
    padding: 5rem 0;
  }

  .hp-section--dark {
    background: var(--color-dark);
  }

  .hp-section--dark-alt {
    background: #151515;
  }

  .hp-section--light {
    background: #f9f9f9;
  }

  .hp-section-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* --- Buttons --- */
  .hp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 2rem;
    border-radius: 6px;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 2px solid transparent;
  }

  .hp-btn--red {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .hp-btn--red:hover {
    background: #a5311f;
    border-color: #a5311f;
  }

  .hp-btn--ghost {
    background: transparent;
    color: #fff;
    border-color: rgba(255,255,255,0.3);
  }

  .hp-btn--ghost:hover {
    border-color: #fff;
    color: #fff;
  }

  .hp-btn--dark {
    background: var(--color-dark);
    color: #fff;
    border-color: var(--color-dark);
  }

  .hp-btn--dark:hover {
    background: #333;
  }

  .hp-btn--full {
    width: 100%;
  }

  .hp-btn--lg {
    padding: 1.1rem 2.8rem;
