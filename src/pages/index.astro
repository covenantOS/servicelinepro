---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import TrustBar from '../components/TrustBar.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import CTABand from '../components/CTABand.astro';
import Footer from '../components/Footer.astro';
import config from '../lib/config';

const title = "Home Service Marketing Agency | Local SEO, Google Ads, Web Design & TV Advertising";
const description = config.business.description;
---

<Base title={title} description={description}>
  <Header slot="header" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg-pattern"></div>
    <div class="container hero-grid">
      <div class="hero-content">
        <span class="hero-eyebrow">Performance Marketing for Home Services</span>
        <h1>We Scale Home Service Businesses <span class="hero-accent">from $1M to $10M</span></h1>
        <p class="hero-sub">Local SEO that puts you in the Map Pack. Google Ads with zero agency fees. Websites that convert. TV campaigns that build your brand. All under one roof.</p>
        <div class="hero-ctas">
          <a href="/contact" class="btn btn-primary btn-lg">Free Strategy Call &rarr;</a>
          <a href="/case-studies" class="btn btn-outline-light btn-lg">See Our Results</a>
        </div>
        <div class="hero-proof">
          <div class="hero-stat">
            <span class="hero-stat-value">$2M+</span>
            <span class="hero-stat-label">Revenue Generated</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">5.0&#9733;</span>
            <span class="hero-stat-label">Google Rating</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">300+</span>
            <span class="hero-stat-label">Leads Generated</span>
          </div>
        </div>
      </div>
      <div class="hero-image-wrap">
        <img src="/media/hero-collage.webp" alt="ServiceLine Pro marketing results for home service businesses" class="hero-image" width="600" height="500" loading="eager" />
        <div class="hero-image-glow"></div>
      </div>
    </div>
  </section>

  <!-- PARTNER LOGOS -->
  <section class="partners-strip">
    <div class="container">
      <p class="partners-label">Trusted Partnership</p>
      <img src="/media/partner-logos.webp" alt="ServiceLine Pro partner logos including Spectrum Reach, Google, Yahoo" class="partners-image" width="900" height="80" loading="eager" />
    </div>
  </section>

  <!-- FREE 10-DAY BOOST - SIGNATURE OFFER -->
  <section class="boost-hero section">
    <div class="boost-hero-bg"></div>
    <div class="container boost-hero-grid">
      <div class="boost-hero-content">
        <span class="boost-badge">Signature Offer</span>
        <h2>Free 10-Day<br/>Local SEO Boost</h2>
        <p class="boost-hero-lead">We optimize your Google Business Profile, fix your citations, and boost your local signals for 10 full days. No charge. No contract. No catch.</p>
        <p class="boost-hero-lead">If the results speak for themselves, we talk about what a full campaign looks like. If not, you keep every improvement we made. Free.</p>
        <div class="boost-hero-metrics">
          <div class="boost-hero-metric">
            <span class="boost-hero-metric-val">+47%</span>
            <span class="boost-hero-metric-lbl">Search Appearances</span>
          </div>
          <div class="boost-hero-metric">
            <span class="boost-hero-metric-val">+23%</span>
            <span class="boost-hero-metric-lbl">Discovery Searches</span>
          </div>
          <div class="boost-hero-metric">
            <span class="boost-hero-metric-val">+15%</span>
            <span class="boost-hero-metric-lbl">Direction Requests</span>
          </div>
        </div>
        <div class="boost-hero-reqs">
          <span class="boost-hero-reqs-title">Requirements to Qualify:</span>
          <div class="boost-hero-reqs-grid">
            <span class="boost-req-chip">Physical Google Business Profile</span>
            <span class="boost-req-chip">15+ Five-Star Reviews</span>
            <span class="boost-req-chip">4.5+ Average Rating</span>
            <span class="boost-req-chip">Existing Website</span>
          </div>
        </div>
        <a href="/contact?service=10-day-boost" class="btn btn-primary btn-lg boost-cta-btn">Apply for Your Free Boost &rarr;</a>
      </div>
      <div class="boost-hero-visual">
        <img src="/media/local-seo-graphic.webp" alt="Local SEO ranking improvement geo-grid results" class="boost-hero-img" width="550" height="450" loading="lazy" />
        <div class="boost-hero-card">
          <span class="boost-card-label">Average Result After 10 Days</span>
          <div class="boost-card-stat">
            <span class="boost-card-num">2,784%</span>
            <span class="boost-card-desc">More Search Appearances</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="problems section">
    <div class="container">
      <span class="section-label">The Problem</span>
      <h2>Why Your Marketing Isn't Working</h2>
      <div class="problems-grid">
        <div class="problem-card">
          <div class="problem-num">01</div>
          <h3>Invisible on Google</h3>
          <p>Your competitors are in the Map Pack booking the jobs you should have. You are nowhere.</p>
        </div>
        <div class="problem-card">
          <div class="problem-num">02</div>
          <h3>Burning Money on Ads</h3>
          <p>Your agency charges 15-20% management fees on top of ad spend. You are paying for their overhead, not your growth.</p>
        </div>
        <div class="problem-card">
          <div class="problem-num">03</div>
          <h3>Website That Doesn't Convert</h3>
          <p>Pretty designs that take 8 seconds to load and never convert a visitor into a phone call. Looks great. Does nothing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ALL 4 SERVICES -->
  <section class="services-showcase section section-dark">
    <div class="container">
      <span class="section-label section-label-light">The Solution</span>
      <h2>Four Services. One Mission. Fill Your Calendar.</h2>
      <p class="section-subtitle">Every service we offer is built to generate leads for home service businesses. Nothing else.</p>

      <div class="services-mega-grid">
        <!-- LOCAL SEO -->
        <div class="service-mega-card service-featured">
          <div class="service-mega-badge">Most Popular</div>
          <div class="service-card-image">
            <img src="/media/local-seo-graphic.webp" alt="Local SEO geo-grid tracking and ranking results" width="400" height="220" loading="lazy" />
          </div>
          <h3>Local Ranking SEO</h3>
          <p class="service-mega-tagline">Top 3 in the Map Pack in 90 days or you don't pay.</p>
          <ul class="service-mega-features">
            <li>Full GBP Optimization (10 categories, 30+ services)</li>
            <li>Citation Building and NAP Consistency</li>
            <li>Local Authority Link Building</li>
            <li>Geo-Grid Tracking and Reporting</li>
          </ul>
          <div class="service-mega-pricing">
            <span class="service-price-from">From</span>
            <span class="service-price-amount">$1,800<span>/mo</span></span>
          </div>
          <a href="/services/local-seo/" class="btn btn-primary btn-block">Learn More</a>
        </div>

        <!-- PPC -->
        <div class="service-mega-card">
          <div class="service-card-image">
            <img src="/media/ppc-graphic.webp" alt="PPC and Google Ads campaign performance dashboard" width="400" height="220" loading="lazy" />
          </div>
          <h3>Google Ads (PPC)</h3>
          <p class="service-mega-tagline">No agency fee. Your entire budget funds your campaigns.</p>
          <ul class="service-mega-features">
            <li>$0 Agency Fee on $5K+ Spend</li>
            <li>First-Party Data from 30M+ Households</li>
            <li>Google, Bing, and Yahoo Coverage</li>
            <li>30-50% Higher CTR, 33% Lower CPC</li>
          </ul>
          <div class="service-mega-pricing">
            <span class="service-price-from">From</span>
            <span class="service-price-amount">$500<span>/mo</span></span>
          </div>
          <a href="/services/ppc/" class="btn btn-primary btn-block">Learn More</a>
        </div>

        <!-- WEB DESIGN -->
        <div class="service-mega-card">
          <div class="service-card-image">
            <img src="/media/service-presentation.webp" alt="Website design and development showcase" width="400" height="220" loading="lazy" />
          </div>
          <h3>Website Design</h3>
          <p class="service-mega-tagline">Sub-2-second loads. Built to convert visitors into booked jobs.</p>
          <ul class="service-mega-features">
            <li>Custom Performance Sites (Astro)</li>
            <li>WordPress with Full CMS</li>
            <li>Mobile-First, SEO-Optimized</li>
            <li>Conversion-Focused CTAs and Funnels</li>
          </ul>
          <div class="service-mega-pricing">
            <span class="service-price-from">From</span>
            <span class="service-price-amount">$2,500</span>
          </div>
          <a href="/services/website-design/" class="btn btn-primary btn-block">Learn More</a>
        </div>

        <!-- TV & STREAMING -->
        <div class="service-mega-card service-spectrum">
          <div class="service-mega-badge spectrum-badge">Spectrum Reach Partner</div>
          <div class="service-card-image">
            <img src="/media/seo-ppc-hero.webp" alt="TV and streaming advertising campaign across platforms" width="400" height="220" loading="lazy" />
          </div>
          <h3>TV & Streaming</h3>
          <p class="service-mega-tagline">Precision-targeted streaming campaigns. No agency fee on media spend.</p>
          <ul class="service-mega-features">
            <li>Connected TV and Streaming Platforms</li>
            <li>First-Party Data Targeting</li>
            <li>Professional Ad Production</li>
            <li>Full Attribution and Reporting</li>
          </ul>
          <div class="service-mega-pricing">
            <span class="service-price-from">Custom</span>
            <span class="service-price-amount">Quote</span>
          </div>
          <a href="/services/tv-streaming-advertising/" class="btn btn-primary btn-block">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SPECTRUM REACH PARTNERSHIP -->
  <section class="spectrum-section section">
    <div class="container spectrum-grid">
      <div class="spectrum-content">
        <span class="section-label">Exclusive Partnership</span>
        <h2>Powered by Spectrum Reach</h2>
        <p class="spectrum-lead">We are one of the only agencies in the country with a direct Spectrum Reach partnership. That means our clients get access to tools and data that other agencies cannot offer at any price.</p>
        <p class="spectrum-lead">This partnership covers advertising across <strong>Google, Bing, Yahoo, Connected TV, and Streaming</strong>. Not just Google. The entire search and viewing landscape.</p>
        <div class="spectrum-stats">
          <div class="spectrum-stat">
            <span class="spectrum-stat-value">30M+</span>
            <span class="spectrum-stat-label">Households of First-Party Data</span>
          </div>
          <div class="spectrum-stat">
            <span class="spectrum-stat-value">36</span>
            <span class="spectrum-stat-label">States Covered</span>
          </div>
          <div class="spectrum-stat">
            <span class="spectrum-stat-value">$0</span>
            <span class="spectrum-stat-label">Agency Fee on $5K+ Ad Spend</span>
          </div>
        </div>
        <div class="spectrum-certs">
          {config.spectrum_partnership.certifications.map(cert => (
            <span class="spectrum-cert">{cert}</span>
          ))}
        </div>
      </div>
      <div class="spectrum-visual">
        <img src="/media/seo-ppc-presentation.webp" alt="Spectrum Reach advertising platform capabilities and reach" class="spectrum-img" width="560" height="400" loading="lazy" />
        <div class="spectrum-card-stack">
          <div class="spectrum-feature-card">
            <h4>First-Party Data</h4>
            <p>Real behavioral data from 30M+ households. Not third-party guesses. Not cookie-based estimates. Real viewing and purchasing behavior.</p>
          </div>
          <div class="spectrum-feature-card">
            <h4>Zero Agency Fees</h4>
            <p>On ad budgets over $5K/month, there is no management fee. Your entire budget goes toward reaching your customers. Every dollar works.</p>
          </div>
          <div class="spectrum-feature-card">
            <h4>Multi-Platform Reach</h4>
            <p>Google, Bing, Yahoo, Connected TV, Streaming. 99% of all search and viewing traffic covered through a single partnership.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASE STUDIES / RESULTS -->
  <section class="results-section section section-dark">
    <div class="container">
      <span class="section-label section-label-light">Real Results</span>
      <h2>What We Do for Our Clients</h2>
      <div class="results-grid">
        {config.case_studies.slice(0, 6).map(cs => (
          <div class="result-card">
            <span class="result-category">{cs.category}</span>
            <h3 class="result-metric">{cs.result}</h3>
            <span class="result-client">{cs.title}</span>
            <span class="result-detail">{cs.metrics.secondary}</span>
          </div>
        ))}
      </div>
      <div class="results-more">
        <a href="/case-studies/" class="btn btn-outline-light btn-lg">View All {config.case_studies.length} Case Studies &rarr;</a>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO / PROJECT SHOWCASE -->
  <section class="portfolio-section section">
    <div class="container">
      <span class="section-label">Our Work</span>
      <h2>Websites That Generate Revenue</h2>
      <p class="portfolio-subtitle">Every site we build is a conversion machine. Sub-2-second load times. SEO-optimized from day one. Designed to turn searches into booked jobs.</p>
      <div class="portfolio-grid">
        <div class="portfolio-item portfolio-large">
          <img src="/media/project-1.webp" alt="Client website project - conversion-focused design" width="600" height="400" loading="lazy" />
          <div class="portfolio-overlay">
            <span class="portfolio-tag">Website Design</span>
          </div>
        </div>
        <div class="portfolio-item">
          <img src="/media/project-2.webp" alt="Client website project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay">
            <span class="portfolio-tag">Website Design</span>
          </div>
        </div>
        <div class="portfolio-item">
          <img src="/media/project-3.webp" alt="Client website project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay">
            <span class="portfolio-tag">Website Design</span>
          </div>
        </div>
        <div class="portfolio-item">
          <img src="/media/project-4.webp" alt="Client website project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay">
            <span class="portfolio-tag">Website Design</span>
          </div>
        </div>
        <div class="portfolio-item portfolio-large">
          <img src="/media/project-5.webp" alt="Client website project - lead generation design" width="600" height="400" loading="lazy" />
          <div class="portfolio-overlay">
            <span class="portfolio-tag">Website Design</span>
          </div>
        </div>
        <div class="portfolio-item">
          <img src="/media/project-6.webp" alt="Client website project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay">
            <span class="portfolio-tag">Website Design</span>
          </div>
        </div>
        <div class="portfolio-item">
          <img src="/media/project-7.webp" alt="Client website project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay">
            <span class="portfolio-tag">Website Design</span>
          </div>
        </div>
        <div class="portfolio-item">
          <img src="/media/project-8.webp" alt="Client website project" width="400" height="300" loading="lazy" />
          <div class="portfolio-overlay">
            <span class="portfolio-tag">Website Design</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EDUCATION / LEARN IT YOURSELF -->
  <section class="education-section section section-dark">
    <div class="education-bg"></div>
    <div class="container education-grid">
      <div class="education-content">
        <span class="section-label section-label-light">Our Philosophy</span>
        <h2>We Teach You Everything</h2>
        <p class="education-lead">Most agencies hide their methods so you stay dependent. We do the opposite. We teach you exactly what we are doing, why it works, and how to maintain it yourself.</p>
        <p class="education-lead">Want to learn local SEO? We will walk you through it. Want to understand your ad campaigns? We break down every metric. You should never feel trapped by an agency that keeps secrets.</p>
        <div class="education-points">
          <div class="education-point">
            <div class="education-point-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <div>
              <h4>Full Transparency</h4>
              <p>You see every report, every ranking change, every dollar spent. Real-time dashboards. No black boxes.</p>
            </div>
          </div>
          <div class="education-point">
            <div class="education-point-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <h4>DIY Resources</h4>
              <p>Free guides, walkthroughs, and training materials. If you want to do it yourself, we give you the playbook.</p>
            </div>
          </div>
          <div class="education-point">
            <div class="education-point-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <h4>Ownership Mindset</h4>
              <p>You own your accounts, your data, your website. Everything. If you leave, it all goes with you. No hostage situations.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="education-visual">
        <img src="/media/video-thumb.webp" alt="ServiceLine Pro educational content and marketing training" class="education-img" width="560" height="380" loading="lazy" />
        <div class="education-play-badge">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span>Watch How We Work</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="team-section section">
    <div class="container team-grid">
      <div class="team-image-wrap">
        <img src="/media/team.webp" alt="ServiceLine Pro team - William Hamilton, Victoria Hamilton, and Daniel Gomez" class="team-image" width="560" height="420" loading="lazy" />
        <div class="team-image-accent"></div>
      </div>
      <div class="team-content">
        <span class="section-label">Meet the Team</span>
        <h2>Real People. Real Results.</h2>
        <p class="team-lead">ServiceLine Pro is not a faceless agency. We are a focused team of marketing specialists who only work with home service businesses. That specialization is why our clients see results in weeks, not months.</p>
        <div class="team-members">
          {config.business.team.map(member => (
            <div class="team-member">
              <span class="team-member-name">{member.name}</span>
              <span class="team-member-role">{member.role}</span>
            </div>
          ))}
        </div>
        <div class="team-trust">
          <div class="team-trust-item">
            <span class="team-trust-val">5.0&#9733;</span>
            <span class="team-trust-lbl">Google Rating</span>
          </div>
          <div class="team-trust-item">
            <span class="team-trust-val">22+</span>
            <span class="team-trust-lbl">Industries Served</span>
          </div>
          <div class="team-trust-item">
            <span class="team-trust-val">Since 2020</span>
            <span class="team-trust-lbl">Tampa, FL</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="process-section section section-alt">
    <div class="container">
      <span class="section-label">How It Works</span>
      <h2>From Invisible to Unavoidable</h2>
      <div class="process-grid">
        <div class="process-step">
          <div class="step-num">1</div>
          <div class="step-content">
            <h3>Free Strategy Call</h3>
            <p>15-minute no-pressure call. We analyze your market, your competition, and your current marketing spend. You get a clear picture of where the opportunities are.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-num">2</div>
          <div class="step-content">
            <h3>Custom Battle Plan</h3>
            <p>We build your strategy with specific timelines and KPIs. You see exactly what we are doing, when we are doing it, and how we measure success.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-num">3</div>
          <div class="step-content">
            <h3>Launch and Scale</h3>
            <p>We execute. Your phone rings. You track every lead in real time. When it works, we scale up together.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="industries-section section">
    <div class="container">
      <span class="section-label">Who We Work With</span>
      <h2>Built for the Businesses That Keep America Running</h2>
      <div class="industries-chips">
        {config.industries.map(ind => (
          <a href={`/industries/${ind.slug}/`} class="industry-chip">{ind.full_name}</a>
        ))}
      </div>
      <a href="/industries/" class="section-link">View All {config.industries.length} Industries &rarr;</a>
    </div>
  </section>

  <ReviewsSection compact={true} maxReviews={4} />

  <!-- LEAD MAGNET / FORM CTA -->
  <section class="leadmag-section section section-dark">
    <div class="leadmag-bg"></div>
    <div class="container leadmag-grid">
      <div class="leadmag-content">
        <span class="section-label section-label-light">Free Resource</span>
        <h2>Get Your Free Market Analysis</h2>
        <p class="leadmag-lead">See exactly where you rank in your local market, what your competitors are doing, and where the biggest opportunities are. No pitch. No obligation. Just data.</p>
        <ul class="leadmag-includes">
          <li>Your current Google Map Pack position</li>
          <li>Top 5 competitor breakdown</li>
          <li>Citation audit and NAP consistency check</li>
          <li>Website speed and conversion analysis</li>
          <li>Recommended strategy with estimated ROI</li>
        </ul>
      </div>
      <div class="leadmag-form-wrap">
        <form class="leadmag-form" action={config.form.action} method="POST">
          <div class="form-group">
            <input type="text" name="name" placeholder="Full Name" required />
          </div>
          <div class="form-group">
            <input type="email" name="email" placeholder="Email" required />
          </div>
          <div class="form-group">
            <input type="tel" name="phone" placeholder="Phone Number" required />
          </div>
          <div class="form-group">
            <input type="text" name="company" placeholder="Company Name" required />
          </div>
          <div class="form-group">
            <input type="url" name="website" placeholder="Current Website (optional)" />
          </div>
          <div class="hp-field" aria-hidden="true">
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>
          <button type="submit" class="btn btn-primary btn-lg btn-block">Get My Free Analysis</button>
          <p class="leadmag-disclaimer">No spam. No sales calls unless you want one. Just your analysis.</p>
        </form>
      </div>
    </div>
  </section>

  <CTABand
    heading="Stop Losing Jobs to Competitors Who Showed Up First"
    text="Book a 15-minute strategy call. No pressure. No pitch deck. Just straight answers about what it takes to dominate your local market."
  />

  <Footer slot="footer" />
</Base>

<style>
  /* === HERO === */
  .hero {
    background: var(--color-dark);
    padding: var(--space-3xl) 0 var(--space-2xl);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .hero-bg-pattern {
