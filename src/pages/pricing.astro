---
import Base from '../layouts/Base.astro';
import config from '../lib/config';
---

<Base title="Pricing" description="Transparent pricing for ServiceLine Pro's SEO, PPC, web design, and TV/streaming services. No hidden fees.">

<section class="section" style="padding-top: 5rem;">
  <div class="container">
    <div class="fade-in" style="text-align: center; margin-bottom: 3.5rem;">
      <span class="section-label">Pricing</span>
      <h1>Transparent Pricing. <span class="gradient-text--red">No Surprises.</span></h1>
      <p class="section-subtitle" style="margin: 1rem auto 0;">Every dollar accounted for. No hidden fees, no surprise charges. What you see is what you pay.</p>
    </div>

    {config.services.filter(s => s.pricing?.tiers).map(service => (
      <div class="fade-in" style="margin-bottom: 4rem;">
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem;">{service.name}</h2>
        {service.pricing?.setup_fee && <p style="color: var(--gray-500); font-size: 0.85rem; margin-bottom: 1.5rem;">One-time setup: ${service.pricing.setup_fee.toLocaleString()}</p>}
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
          {service.pricing?.tiers?.map(tier => (
            <div style={`background: var(--dark-2); border: 1px solid ${tier.featured ? 'var(--red)' : 'var(--dark-4)'}; border-radius: var(--radius-lg); padding: 2rem; display: flex; flex-direction: column; position: relative;`}>
              {tier.featured && <div style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--red); color: var(--white); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.3rem 1rem; border-radius: var(--radius-full);">Most Popular</div>}
              <h3 style="font-size: 1.1rem; margin-bottom: 0.25rem;">{tier.name}</h3>
              <p style="color: var(--gray-500); font-size: 0.8rem; margin-bottom: 1rem;">{tier.description}</p>
              <div style="display: flex; align-items: baseline; gap: 0.25rem; margin-bottom: 1.25rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--dark-4);">
                {tier.price === 0 ? (
                  <span style="font-family: var(--font-heading); font-weight: 800; font-size: 2rem; color: var(--white);">{tier.price_label}</span>
                ) : (
                  <>
                    <span style="font-family: var(--font-heading); font-weight: 800; font-size: 2rem; color: var(--white);">${tier.price.toLocaleString()}</span>
                    <span style="font-size: 0.85rem; color: var(--gray-500);">{tier.price_label || '/mo'}</span>
                  </>
                )}
              </div>
              <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; flex: 1;">
                {tier.features.map(f => (
                  <li style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--gray-300);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="/contact/" class={`btn ${tier.featured ? 'btn--primary' : 'btn--outline'} btn--lg`} style="width: 100%;">Get Started</a>
            </div>
          ))}
        </div>
      </div>
    ))}

    {config.services.filter(s => s.pricing?.quote_based).map(service => (
      <div class="fade-in" style="margin-bottom: 3rem; text-align: center; background: var(--dark-2); border: 1px solid var(--dark-4); border-radius: var(--radius-lg); padding: 3rem;">
        <h2 style="font-size: 1.5rem; margin-bottom: 0.75rem;">{service.name}</h2>
        <p style="color: var(--gray-400); max-width: 600px; margin: 0 auto 1.5rem;">{service.pricing?.description}</p>
        <a href="/contact/" class="btn btn--primary btn--lg">Request a Quote</a>
      </div>
    ))}
  </div>
</section>

<section class="cta-banner">
  <div class="container" style="position: relative; z-index: 1;">
    <h2 style="margin-bottom: 1rem;">Questions About Pricing?</h2>
    <p style="margin-bottom: 2rem;">We'll walk you through everything on a free strategy call.</p>
    <a href="/contact/" class="btn btn--lime btn--lg">Get Your Free Strategy Call</a>
  </div>
</section>

</Base>
