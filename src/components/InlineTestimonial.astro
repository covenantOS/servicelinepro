---
interface Props {
  quote: string;
  author: string;
  company: string;
  rating?: number;
}

const { quote, author, company, rating = 5 } = Astro.props;
const stars = '★'.repeat(rating);
---

<div class="inline-testimonial">
  <div class="inline-testimonial-stars">{stars}</div>
  <blockquote class="inline-testimonial-quote">{quote}</blockquote>
  <div class="inline-testimonial-author">
    <strong>{author}</strong>
    <span>{company}</span>
  </div>
</div>

<style>
  .inline-testimonial {
    margin: var(--space-2xl) 0;
    padding: var(--space-xl) var(--space-xl) var(--space-xl) var(--space-2xl);
    background: var(--color-gray-100);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    position: relative;
  }
  .inline-testimonial::before {
    content: '\201C';
    position: absolute;
    top: -4px;
    left: 12px;
    font-size: 3.5rem;
    color: var(--color-primary);
    opacity: 0.15;
    font-family: Georgia, serif;
    line-height: 1;
  }
  .inline-testimonial-stars {
    color: #f5c518;
    font-size: var(--text-lg);
    letter-spacing: 2px;
    margin-bottom: var(--space-sm);
  }
  .inline-testimonial-quote {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text);
    font-style: italic;
    margin: 0 0 var(--space-md) 0;
    border: none;
    padding: 0;
    background: none;
  }
  .inline-testimonial-author strong {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-dark);
  }
  .inline-testimonial-author span {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
