---
import config from '../lib/config';
import ContactForm from './ContactForm.astro';

interface Props {
  heading: string;
  subheading?: string;
  image?: string;
}

const {
  heading,
  subheading = config.business.description,
  image = '/media/hero-collage.webp',
} = Astro.props;
---

<section class="hero" aria-label="Hero">
  <div class="hero-bg">
    <img src={image} alt={`${config.business.name} project collage`} class="hero-bg-img" loading="eager" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badges">
        <span class="hero-badge">{config.trust_signals.rating}-Star Rated on {config.trust_signals.review_platform}</span>
        {config.trust_signals.badges[1] && <span class="hero-badge">{config.trust_signals.badges[1]}</span>}
      </div>

      <h1>{heading}</h1>
      <p class="hero-description">{subheading}</p>
      <p class="hero-tagline">{config.business.tagline}</p>

      <div class="hero-tags">
        {config.services.slice(0, 4).map(service => (
          <span class="hero-tag">{service.name}</span>
        ))}
      </div>

      <div class="hero-ctas">
        <a href="/contact" class="btn btn-primary btn-lg">Get Your Free Estimate</a>
        <a href={`tel:${config.business.phone_raw}`} class="btn btn-outline btn-lg hero-phone-btn">Call {config.business.phone}</a>
      </div>
    </div>

    <div class="hero-form-wrap">
      <ContactForm variant="hero" />
      <div class="hero-form-badges">
        <span class="form-badge">{config.trust_signals.badges[0] || `${config.trust_signals.rating} Rating`}</span>
        <span class="form-badge">{config.trust_signals.badges[1] || 'Insured'}</span>
        <span class="form-badge">{config.trust_signals.badges[5] || '24hr Response'}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 600px;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: var(--space-3xl) 0;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26, 26, 26, 0.92) 0%, rgba(26, 26, 26, 0.75) 60%, rgba(26, 26, 26, 0.5) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1.2fr 1fr;
      gap: var(--space-3xl);
    }
  }

  .hero-content {
    color: var(--color-white);
  }

  .hero-badges {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-sm);
    padding: 0.375rem 0.75rem;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .hero h1 {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
    max-width: 600px;
    line-height: var(--leading-tight);
  }

  @media (min-width: 1024px) {
    .hero h1 {
      font-size: var(--text-5xl);
    }
  }

  .hero-description {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    max-width: 540px;
    margin-bottom: var(--space-sm);
  }

  .hero-tagline {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--color-secondary);
    margin-bottom: var(--space-lg);
  }

  .hero-tags {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .hero-tag {
    background: rgba(45, 90, 39, 0.3);
    border: 1px solid rgba(45, 90, 39, 0.5);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 500;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-sm);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-phone-btn {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .hero-phone-btn:hover {
    background: var(--color-white);
    color: var(--color-dark);
  }

  /* Form wrap */
  .hero-form-wrap {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-lg);
  }

  .hero-form-badges {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-gray-200);
  }

  .form-badge {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .form-badge::before {
    content: '✓';
    color: var(--color-primary);
    font-weight: 700;
  }
</style>
