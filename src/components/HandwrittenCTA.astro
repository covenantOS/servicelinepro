---
interface Props {
  heading?: string;
  buttonText?: string;
  buttonHref?: string;
  annotation?: string;
}

const {
  heading = "Ready to Take the Leap?",
  buttonText = "Schedule Your Strategy Call",
  buttonHref = "/contact",
  annotation = "No obligation. Just a 15-minute call."
} = Astro.props;
---

<section class="handwritten-cta section-dark-textured">
  <div class="container hcta-inner">
    <span class="section-eyebrow section-label-light">Let's Talk</span>
    <h2 class="hcta-heading">{heading}</h2>
    <div class="hcta-action">
      <a href={buttonHref} class="btn btn-ghost btn-lg">{buttonText}</a>
      <div class="hcta-annotation">
        <svg class="hcta-arrow" width="60" height="40" viewBox="0 0 60 40" fill="none">
          <path d="M5 35 C 15 10, 40 5, 55 15" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M50 10 L 55 15 L 48 17" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        </svg>
        <span class="hcta-script">{annotation}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .handwritten-cta {
    padding: var(--space-5xl) 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .handwritten-cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(192,57,43,0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 50%, rgba(192,57,43,0.08) 0%, transparent 50%);
    pointer-events: none;
  }
  .hcta-inner {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }
  .hcta-heading {
    color: var(--color-white);
    margin-bottom: var(--space-xl);
  }
  .hcta-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }
  .hcta-annotation {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
  }
  .hcta-arrow {
    flex-shrink: 0;
    transform: rotate(-10deg);
  }
  .hcta-script {
    font-family: var(--font-script);
    font-style: italic;
    font-size: var(--text-lg);
    color: rgba(255,255,255,0.45);
    line-height: 1.3;
  }
  .section-label-light {
    color: rgba(255,255,255,0.4);
  }

  @media (max-width: 767px) {
    .hcta-arrow {
      display: none;
    }
    .hcta-script {
      font-size: var(--text-base);
    }
  }
</style>
