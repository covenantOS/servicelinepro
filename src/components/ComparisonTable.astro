---
import config from '../lib/config';
---

<div class="comparison-wrapper">
  <h2>How We Compare</h2>
  <div class="comparison-table-scroll">
    <table class="comparison-table">
      <thead>
        <tr>
          <th></th>
          <th class="comp-highlight">{config.business.name}</th>
          <th>DIY / In-House</th>
          <th>Other Agencies</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="comp-feature">Home Service Specialization</td>
          <td class="comp-highlight"><span class="comp-yes">&#10003;</span> Only industry we serve</td>
          <td><span class="comp-no">&#10007;</span> No expertise</td>
          <td><span class="comp-partial">~</span> Generalists</td>
        </tr>
        <tr>
          <td class="comp-feature">Agency Fees on PPC</td>
          <td class="comp-highlight"><span class="comp-yes">&#10003;</span> $0 on $5K+ spend</td>
          <td><span class="comp-yes">&#10003;</span> No fees (self-managed)</td>
          <td><span class="comp-no">&#10007;</span> 15-20% of ad spend</td>
        </tr>
        <tr>
          <td class="comp-feature">Free Trial / Proof First</td>
          <td class="comp-highlight"><span class="comp-yes">&#10003;</span> 10 days free SEO boost</td>
          <td><span class="comp-no">&#10007;</span> N/A</td>
          <td><span class="comp-no">&#10007;</span> Contracts required</td>
        </tr>
        <tr>
          <td class="comp-feature">Map Pack Guarantee</td>
          <td class="comp-highlight"><span class="comp-yes">&#10003;</span> Top 3 in 90 days</td>
          <td><span class="comp-no">&#10007;</span> No guarantee</td>
          <td><span class="comp-partial">~</span> Rarely guaranteed</td>
        </tr>
        <tr>
          <td class="comp-feature">You Own Everything</td>
          <td class="comp-highlight"><span class="comp-yes">&#10003;</span> Accounts, data, website</td>
          <td><span class="comp-yes">&#10003;</span> You own it</td>
          <td><span class="comp-no">&#10007;</span> Often held hostage</td>
        </tr>
        <tr>
          <td class="comp-feature">Spectrum Reach Data</td>
          <td class="comp-highlight"><span class="comp-yes">&#10003;</span> 30M+ households</td>
          <td><span class="comp-no">&#10007;</span> No access</td>
          <td><span class="comp-no">&#10007;</span> No access</td>
        </tr>
        <tr>
          <td class="comp-feature">Free Video Production</td>
          <td class="comp-highlight"><span class="comp-yes">&#10003;</span> Included with TV campaigns</td>
          <td><span class="comp-no">&#10007;</span> $3K-$10K cost</td>
          <td><span class="comp-no">&#10007;</span> Extra cost</td>
        </tr>
        <tr>
          <td class="comp-feature">Full Transparency</td>
          <td class="comp-highlight"><span class="comp-yes">&#10003;</span> We teach you everything</td>
          <td><span class="comp-yes">&#10003;</span> Full visibility</td>
          <td><span class="comp-partial">~</span> Black box reports</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<style>
  .comparison-wrapper {
    margin: var(--space-2xl) 0;
  }
  .comparison-wrapper h2 {
    margin-bottom: var(--space-lg);
  }
  .comparison-table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-200);
  }
  .comparison-table {
    width: 100%;
    min-width: 600px;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .comparison-table thead th {
    padding: var(--space-md) var(--space-lg);
    font-family: var(--font-heading);
    font-weight: 600;
    text-align: left;
    font-size: var(--text-sm);
    background: var(--color-gray-100);
    border-bottom: 2px solid var(--color-gray-200);
    white-space: nowrap;
  }
  .comparison-table thead th.comp-highlight {
    background: var(--color-dark);
    color: var(--color-white);
  }
  .comparison-table td {
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--color-gray-100);
    vertical-align: top;
  }
  .comparison-table td.comp-highlight {
    background: rgba(192, 57, 43, 0.03);
    font-weight: 500;
  }
  .comp-feature {
    font-weight: 600;
    color: var(--color-dark);
    white-space: nowrap;
  }
  .comp-yes {
    color: #16a34a;
    font-weight: 700;
    margin-right: 0.25rem;
  }
  .comp-no {
    color: #dc2626;
    font-weight: 700;
    margin-right: 0.25rem;
  }
  .comp-partial {
    color: #d97706;
    font-weight: 700;
    margin-right: 0.25rem;
  }
</style>
