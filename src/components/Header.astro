---
import config from '../lib/config';

const topCaseStudy = config.case_studies.find(cs => cs.slug === 'remodeling') || config.case_studies[0];
const featuredAreas = config.areas.slice(0, 6);

// Service icons as inline SVG paths for the mega menu
const serviceIcons: Record<string, string> = {
  'local-seo': '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  'ppc': '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  'website-design': '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
  'tv-streaming-advertising': '<rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/>',
};
---

<header class="site-header" id="site-header">
  <div class="top-bar">
    <div class="container top-bar-inner">
      <div class="top-bar-left">
        <a href={`tel:${config.business.phone_raw}`} class="top-bar-phone">{config.business.phone}</a>
        <span class="top-bar-sep">|</span>
        <a href={`mailto:${config.business.email}`} class="top-bar-email">{config.business.email}</a>
      </div>
      <div class="top-bar-right">
        <span class="top-bar-badge">Home Service Marketing Experts</span>
        <span class="top-bar-sep">|</span>
        <span class="top-bar-rating">&#9733; {config.trust_signals.rating} on {config.trust_signals.review_platform}</span>
      </div>
    </div>
  </div>

  <div class="main-header">
    <div class="container header-inner">
      <a href="/" class="logo-link">
        <img
          src="/media/slp-logo.png"
          alt={`${config.business.name} - ${config.business.tagline}`}
          class="logo-img"
          width="180"
          height="48"
        />
      </a>

      <nav class="desktop-nav" aria-label="Main navigation">
        <!-- Services Mega Menu -->
        <div class="nav-dropdown">
          <button class="nav-link dropdown-trigger" aria-expanded="false">
            Services <span class="dropdown-arrow">&#9662;</span>
          </button>
          <div class="mega-menu mega-menu-services">
            <div class="mega-services-grid">
              <div class="mega-services-list">
                <span class="mega-label">What We Do</span>
                {config.services.map(service => (
                  <a href={`/services/${service.slug}/`} class="mega-service-card">
                    <span class="mega-service-icon">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={serviceIcons[service.slug] || serviceIcons['local-seo']} />
                    </span>
                    <span class="mega-service-text">
                      <span class="mega-service-name">{service.name}</span>
                      <span class="mega-service-desc">{service.short_description.split('.')[0]}.</span>
                    </span>
                  </a>
                ))}
              </div>
              <div class="mega-highlight">
                <span class="mega-label">Featured Result</span>
                {topCaseStudy && (
                  <div class="mega-case-study">
                    <span class="mega-cs-category">{topCaseStudy.category}</span>
                    <span class="mega-cs-title">{topCaseStudy.title}</span>
                    <span class="mega-cs-metric">{topCaseStudy.metrics.primary}</span>
                    <span class="mega-cs-secondary">{topCaseStudy.metrics.secondary}</span>
                    <a href="/case-studies/" class="mega-cs-link">View All Case Studies &rarr;</a>
                  </div>
                )}
              </div>
            </div>
            <div class="mega-footer">
              <a href="/services/" class="mega-footer-link">All Services</a>
              <a href="/pricing/" class="mega-footer-link">Pricing</a>
              <a href="/contact" class="mega-footer-cta">Book a Strategy Call &rarr;</a>
            </div>
          </div>
        </div>

        <!-- Industries - simple link -->
        <a href="/industries/" class="nav-link">Industries</a>

        <!-- Areas Dropdown -->
        <div class="nav-dropdown">
          <button class="nav-link dropdown-trigger" aria-expanded="false">
            Areas <span class="dropdown-arrow">&#9662;</span>
          </button>
          <div class="mega-menu mega-menu-areas">
            <span class="mega-label">Featured Markets</span>
            <div class="mega-area-grid">
              {featuredAreas.map(area => (
                <a href={`/areas/${area.slug}/`} class="mega-area-link">{area.name}, FL</a>
              ))}
            </div>
            <div class="mega-footer">
              <a href="/areas/" class="mega-footer-link">See All {config.areas.length} Areas &rarr;</a>
            </div>
          </div>
        </div>

        <a href="/case-studies" class="nav-link">Results</a>
        <a href="/about" class="nav-link">About</a>
      </nav>

      <div class="header-ctas">
        <a href={`tel:${config.business.phone_raw}`} class="header-phone">{config.business.phone}</a>
        <a href="/contact" class="btn btn-primary btn-sm">Free Strategy Call</a>
      </div>

      <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <div class="mobile-nav-inner">
      <div class="mobile-nav-group">
        <button class="mobile-nav-heading">Services</button>
        <div class="mobile-nav-sub">
          {config.services.map(service => (
            <a href={`/services/${service.slug}/`} class="mobile-nav-link sub">{service.name}</a>
          ))}
          <a href="/pricing/" class="mobile-nav-link sub">Pricing</a>
        </div>
      </div>
      <a href="/industries/" class="mobile-nav-link">Industries</a>
      <div class="mobile-nav-group">
        <button class="mobile-nav-heading">Areas</button>
        <div class="mobile-nav-sub">
          {featuredAreas.map(area => (
            <a href={`/areas/${area.slug}/`} class="mobile-nav-link sub">{area.name}</a>
          ))}
          <a href="/areas/" class="mobile-nav-link sub accent">View All Areas &rarr;</a>
        </div>
      </div>
      <a href="/case-studies" class="mobile-nav-link">Results</a>
      <a href="/about" class="mobile-nav-link">About</a>
      <a href="/contact" class="mobile-nav-link">Contact</a>
      <div class="mobile-nav-ctas">
        <a href={`tel:${config.business.phone_raw}`} class="btn btn-phone btn-full">Call {config.business.phone}</a>
        <a href="/contact" class="btn btn-primary btn-full">Free Strategy Call</a>
      </div>
    </div>
  </div>
</header>

<div class="mobile-sticky-bar">
  <a href={`tel:${config.business.phone_raw}`} class="mobile-sticky-btn call">Call Now</a>
  <a href="/contact" class="mobile-sticky-btn estimate">Free Strategy Call</a>
</div>

<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }, { passive: true });

  const toggle = document.getElementById('mobile-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    mobileNav?.setAttribute('aria-hidden', String(isOpen));
    document.body.style.overflow = isOpen ? '' : 'hidden';
    toggle.classList.toggle('active');
  });

  document.querySelectorAll('.nav-dropdown').forEach(dropdown => {
    const trigger = dropdown.querySelector('.dropdown-trigger');
    dropdown.addEventListener('mouseenter', () => {
      trigger?.setAttribute('aria-expanded', 'true');
    });
    dropdown.addEventListener('mouseleave', () => {
      trigger?.setAttribute('aria-expanded', 'false');
    });
  });

  document.querySelectorAll('.mobile-nav-heading').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('open');
      const sub = btn.nextElementSibling;
      if (sub) sub.classList.toggle('show');
    });
  });
</script>

<style>
  /* === TOP BAR === */
  .top-bar {
    background: var(--color-dark);
    color: rgba(255,255,255,0.7);
    font-size: 0.7rem;
    padding: 0.35rem 0;
    letter-spacing: 0.02em;
  }
  .top-bar-inner { display: flex; justify-content: space-between; align-items: center; }
  .top-bar-left { display: flex; align-items: center; }
  .top-bar-right { display: flex; align-items: center; }
  .top-bar-phone, .top-bar-email {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }
  .top-bar-phone:hover, .top-bar-email:hover { color: var(--color-white); }
  .top-bar-sep { color: rgba(255,255,255,0.15); margin: 0 0.5rem; }
  .top-bar-badge {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
  }
  .top-bar-rating { color: #f5c518; font-weight: 600; }
  .top-bar-badge, .top-bar-email, .top-bar-sep { display: none; }
  @media (min-width: 768px) { .top-bar-badge, .top-bar-email, .top-bar-sep { display: inline; } }

  /* === MAIN HEADER === */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--color-white);
    transition: box-shadow 0.2s ease;
  }
  .site-header.scrolled {
    box-shadow: 0 1px 16px rgba(0,0,0,0.08);
  }
  .site-header.scrolled .top-bar { display: none; }
  .main-header { border-bottom: 1px solid var(--color-gray-200); }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    gap: var(--space-md);
  }

  /* === LOGO === */
  .logo-link {
    text-decoration: none;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .logo-img {
    height: 40px;
    width: auto;
    display: block;
  }
  @media (min-width: 768px) {
    .logo-img { height: 44px; }
  }

  /* === DESKTOP NAV === */
  .desktop-nav { display: none; align-items: center; gap: 0; }
  @media (min-width: 1024px) { .desktop-nav { display: flex; } }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-dark);
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    cursor: pointer;
    transition: color 0.15s;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
  .nav-link:hover { color: var(--color-primary); }
  .dropdown-arrow { font-size: 0.6em; margin-left: 2px; opacity: 0.4; transition: transform 0.2s; }
  .dropdown-trigger[aria-expanded="true"] .dropdown-arrow { transform: rotate(180deg); }

  /* === HEADER CTAs === */
  .header-ctas { display: none; align-items: center; gap: var(--space-md); flex-shrink: 0; }
  @media (min-width: 1024px) { .header-ctas { display: flex; } }
  .header-phone {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-dark);
    text-decoration: none;
    transition: color 0.15s;
  }
  .header-phone:hover { color: var(--color-primary); }

  /* === DROPDOWN (shared) === */
  .nav-dropdown { position: relative; }
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 10px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.03);
    padding: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease, visibility 0.15s ease, transform 0.15s ease;
    z-index: 100;
  }
  .nav-dropdown:hover .mega-menu,
  .dropdown-trigger[aria-expanded="true"] + .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .mega-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  /* === SERVICES MEGA MENU === */
  .mega-menu-services {
    min-width: 640px;
    max-width: 720px;
  }
  .mega-services-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 0;
  }
  .mega-services-list {
    padding: var(--space-lg) var(--space-lg) var(--space-md);
  }
  .mega-highlight {
    padding: var(--space-lg);
    background: var(--color-gray-100);
    border-left: 1px solid var(--color-gray-200);
    border-radius: 0 10px 0 0;
  }

  .mega-service-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.625rem 0.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
    margin-bottom: 2px;
  }
  .mega-service-card:hover { background: var(--color-gray-100); }
  .mega-service-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-gray-100);
    border-radius: 8px;
    color: var(--color-primary);
    transition: background 0.15s, color 0.15s;
  }
  .mega-service-card:hover .mega-service-icon {
    background: var(--color-primary);
    color: var(--color-white);
  }
  .mega-service-text { display: flex; flex-direction: column; min-width: 0; }
  .mega-service-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-dark);
    line-height: 1.2;
  }
  .mega-service-card:hover .mega-service-name { color: var(--color-primary); }
  .mega-service-desc {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.35;
    margin-top: 2px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Case study highlight */
  .mega-case-study {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .mega-cs-category {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
  }
  .mega-cs-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.3;
  }
  .mega-cs-metric {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-dark);
    line-height: 1.1;
    margin-top: 0.25rem;
    font-family: var(--font-heading);
  }
  .mega-cs-secondary {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .mega-cs-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .mega-cs-link:hover { text-decoration: underline; }

  /* === AREAS MEGA MENU === */
  .mega-menu-areas {
    min-width: 300px;
    max-width: 380px;
    padding: var(--space-lg);
  }
  .mega-area-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
  }
  .mega-area-link {
    display: block;
    padding: 0.4rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text);
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
  }
  .mega-area-link:hover {
    background: var(--color-gray-100);
    color: var(--color-primary);
  }

  /* === MEGA FOOTER === */
  .mega-footer {
    padding: 0.625rem var(--space-lg);
    border-top: 1px solid var(--color-gray-200);
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    background: var(--color-white);
    border-radius: 0 0 10px 10px;
  }
  .mega-footer-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .mega-footer-link:hover { color: var(--color-primary); }
  .mega-footer-cta {
    margin-left: auto;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    background: rgba(192,57,43,0.06);
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .mega-footer-cta:hover { background: rgba(192,57,43,0.12); }

  /* === MOBILE TOGGLE === */
  .mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
  }
  @media (min-width: 1024px) { .mobile-toggle { display: none; } }
  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-dark);
    transition: transform 0.25s, opacity 0.25s;
    border-radius: 1px;
  }
  .mobile-toggle.active .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .mobile-toggle.active .hamburger-line:nth-child(2) { opacity: 0; }
  .mobile-toggle.active .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* === MOBILE NAV === */
  .mobile-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-white);
    z-index: 999;
    overflow-y: auto;
    padding: calc(68px + 50px) var(--space-lg) var(--space-2xl);
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }
  .mobile-nav[aria-hidden="false"] { transform: translateX(0); }
  .mobile-nav-link {
    display: block;
    padding: 0.75rem 0;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-dark);
    border-bottom: 1px solid var(--color-gray-200);
    text-decoration: none;
  }
  .mobile-nav-link.sub {
    font-size: var(--text-base);
    font-weight: 500;
    padding-left: var(--space-lg);
    color: var(--color-text-light);
  }
  .mobile-nav-link.accent { color: var(--color-primary); font-weight: 600; }
  .mobile-nav-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.75rem 0;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-dark);
    border: none;
    background: none;
    border-bottom: 1px solid var(--color-gray-200);
    cursor: pointer;
  }
  .mobile-nav-heading::after { content: '+'; font-size: var(--text-xl); color: var(--color-primary); }
  .mobile-nav-heading.open::after { content: '\2212'; }
  .mobile-nav-sub { display: none; }
  .mobile-nav-sub.show { display: block; }
  .mobile-nav-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
  }

  /* === MOBILE STICKY BAR === */
  .mobile-sticky-bar {
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 998;
    background: var(--color-white);
    border-top: 1px solid var(--color-gray-200);
    box-shadow: 0 -2px 8px rgba(0,0,0,0.08);
  }
  @media (min-width: 1024px) { .mobile-sticky-bar { display: none; } }
  .mobile-sticky-btn {
    flex: 1;
    text-align: center;
    padding: 0.875rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
  }
  .mobile-sticky-btn.call { background: var(--color-primary); color: var(--color-white); }
  .mobile-sticky-btn.estimate { background: var(--color-dark); color: var(--color-white); }
</style>
