---
import config from '../lib/config';

interface Props {
  heading?: string;
  description?: string;
  bulletPoints?: string[];
  videoUrl?: string;
  thumbnailImage?: string;
}

const {
  heading = 'Watch Our Craftsmanship',
  description = `Every project starts with a vision and ends with a homeowner thrilled with the result. Watch our team bring quality craftsmanship to ${config.business.address.city} homes.`,
  bulletPoints = [
    'Premium materials on every project',
    'Skilled tradesmen with years of experience',
    'Clean job sites, respectful crews',
    'Projects completed on time and on budget',
  ],
  videoUrl = '',
  thumbnailImage = '/media/video-thumb.webp',
} = Astro.props;
---

<section class="video-section section section-alt" aria-label="Video showcase">
  <div class="container video-grid">
    <div class="video-content">
      <p class="section-label">See Us In Action</p>
      <h2>{heading}</h2>
      <p class="video-description">{description}</p>
      <ul class="video-bullets">
        {bulletPoints.map(point => (
          <li>
            <span class="bullet-check">✓</span>
            {point}
          </li>
        ))}
      </ul>
    </div>

    <div class="video-player">
      <div class="video-thumb-wrap">
        <img src={thumbnailImage} alt={`${config.business.name} project showcase`} loading="lazy" width="640" height="360" />
        {videoUrl && (
          <a href={videoUrl} target="_blank" rel="noopener" class="play-button" aria-label="Play video">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
              <circle cx="32" cy="32" r="32" fill="rgba(0,0,0,0.6)"/>
              <polygon points="26,20 26,44 46,32" fill="white"/>
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .video-grid {
      grid-template-columns: 1fr 1.1fr;
    }
  }

  .video-content h2 {
    margin-bottom: var(--space-md);
  }

  .video-description {
    color: var(--color-text-light);
    margin-bottom: var(--space-lg);
  }

  .video-bullets {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .video-bullets li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-base);
    color: var(--color-text);
    font-weight: 500;
  }

  .bullet-check {
    color: var(--color-primary);
    font-weight: 700;
    flex-shrink: 0;
  }

  .video-thumb-wrap {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    aspect-ratio: 16/9;
  }

  .video-thumb-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: transform var(--transition-base);
  }

  .play-button:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }
</style>
