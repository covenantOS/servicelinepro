---
import config from '../lib/config';

interface Props {
  currentService?: string;
  currentArea?: string;
  serviceSlug?: string;
}

const { currentService = '', currentArea = '', serviceSlug = '' } = Astro.props;

const primaryArea = config.areas.find(a => a.is_primary) || config.areas[0];
const city = primaryArea.name.toLowerCase().replace(/\s+/g, '-');
const state = config.business.address.state.toLowerCase();

const currentServiceData = config.services.find(s => s.slug === currentService);
---

<aside class="sidebar" aria-label="Sidebar navigation">
  <div class="sidebar-sticky">
    <!-- Phone CTA -->
    <a href={`tel:${config.business.phone_raw}`} class="btn btn-phone btn-full sidebar-phone">{config.business.phone}</a>

    <!-- Estimate CTA -->
    <a href={`/contact${currentService ? `?service=${encodeURIComponent(currentServiceData?.name || '')}` : ''}`} class="btn btn-primary btn-full sidebar-estimate">Free Estimate</a>

    <!-- Contact box -->
    <div class="sidebar-box">
      <h3>Get Your Free Estimate</h3>
      <p class="sidebar-box-sub">Call us today or fill out the form below</p>
      <a href={`tel:${config.business.phone_raw}`} class="sidebar-link">{config.business.phone}</a>
      <a href={`/contact${currentService ? `?service=${encodeURIComponent(currentServiceData?.name || '')}` : ''}`} class="sidebar-link accent">Request Estimate Online</a>
    </div>

    <!-- Services list -->
    <div class="sidebar-box">
      <h3>Our Services</h3>
      <ul class="sidebar-list">
        {config.services.map(service => (
          <li>
            <a
              href={`/services/${service.slug}-${city}-${state}`}
              class:list={['sidebar-list-link', service.slug === currentService ? 'active' : '']}
            >
              {service.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Area links -->
    {currentService && (
      <div class="sidebar-box">
        <h3>{currentServiceData?.name || 'Service'} Near You</h3>
        <ul class="sidebar-list">
          {config.areas.slice(0, 9).map(area => (
            <li>
              <a
                href={`/areas/${area.slug}`}
                class:list={['sidebar-list-link', area.slug === currentArea ? 'active' : '']}
              >
                {area.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Trust badges -->
    <div class="sidebar-box sidebar-trust">
      <h3>Why Choose Us</h3>
      <ul class="sidebar-trust-list">
        <li><span class="trust-check">✓</span> {config.trust_signals.rating} {config.trust_signals.review_platform} Rating</li>
        {config.trust_signals.badges.slice(1, 4).map((badge: string) => (
          <li><span class="trust-check">✓</span> {badge}</li>
        ))}
      </ul>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .sidebar-sticky {
      position: sticky;
      top: calc(var(--header-height) + 1.5rem);
      max-height: calc(100vh - var(--header-height) - 3rem);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--color-gray-300) transparent;
    }

    .sidebar-sticky::-webkit-scrollbar {
      width: 4px;
    }

    .sidebar-sticky::-webkit-scrollbar-thumb {
      background: var(--color-gray-300);
      border-radius: 2px;
    }
  }

  .sidebar-phone {
    margin-bottom: var(--space-sm);
  }

  .sidebar-estimate {
    margin-bottom: var(--space-lg);
  }

  .sidebar-box {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .sidebar-box h3 {
    font-size: var(--text-base);
    font-weight: 700;
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--color-primary);
  }

  .sidebar-box-sub {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .sidebar-link {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .sidebar-link.accent {
    color: var(--color-primary);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
  }

  .sidebar-list li {
    margin-bottom: 0;
  }

  .sidebar-list-link {
    display: block;
    padding: 0.375rem 0.625rem;
    font-size: var(--text-sm);
    color: var(--color-text-light);
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .sidebar-list-link:hover {
    background: var(--color-gray-100);
    color: var(--color-primary);
  }

  .sidebar-list-link.active {
    background: rgba(45, 90, 39, 0.08);
    color: var(--color-primary);
    font-weight: 600;
  }

  .sidebar-trust-list {
    list-style: none;
    padding: 0;
  }

  .sidebar-trust-list li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    padding: 0.25rem 0;
  }

  .trust-check {
    color: var(--color-primary);
    font-weight: 700;
  }
</style>
