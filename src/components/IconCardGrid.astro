---
interface Props {
  cards: Array<{icon: string, title: string, description: string}>;
  columns?: 2 | 3;
  darkBg?: boolean;
}
const { cards, columns = 3, darkBg = false } = Astro.props;

const iconPaths: Record<string, string> = {
  money: '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
  target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  chart: '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  globe: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  map: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  phone: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
  tv: '<rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/>',
  eye: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  check: '<polyline points="20 6 9 17 4 12"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  bar: '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
};
---

<div class={`icon-card-grid icon-card-grid-${columns}col ${darkBg ? 'icon-card-grid-dark' : ''}`}>
  {cards.map(card => (
    <div class="icon-card">
      <div class="icon-card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[card.icon] || iconPaths['check']} />
      </div>
      <h3 class="icon-card-title">{card.title}</h3>
      <p class="icon-card-desc">{card.description}</p>
    </div>
  ))}
</div>

<style>
  .icon-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 768px) {
    .icon-card-grid-2col { grid-template-columns: repeat(2, 1fr); }
    .icon-card-grid-3col { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .icon-card-grid-3col { grid-template-columns: repeat(3, 1fr); }
  }

  .icon-card {
    padding: var(--space-xl);
    border-radius: var(--radius-card);
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .icon-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    border-color: var(--color-primary);
  }

  .icon-card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(192,57,43,0.08);
    border-radius: 50%;
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .icon-card-title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-sm);
    text-transform: none;
    color: var(--color-dark);
  }

  .icon-card-desc {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text-light);
    margin-bottom: 0;
  }

  /* Dark variant */
  .icon-card-grid-dark .icon-card {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.1);
  }
  .icon-card-grid-dark .icon-card:hover {
    background: rgba(255,255,255,0.08);
    border-color: var(--color-primary);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }
  .icon-card-grid-dark .icon-card-icon {
    background: rgba(192,57,43,0.15);
  }
  .icon-card-grid-dark .icon-card-title {
    color: #ffffff;
  }
  .icon-card-grid-dark .icon-card-desc {
    color: rgba(255,255,255,0.75);
  }
</style>
