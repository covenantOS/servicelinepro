<div class="slp-cw">
<div class="slp-cw-nudge" id="cwNudge"><button class="slp-cw-nudge-x" id="cwNudgeX">&#10005;</button><span id="cwNudgeMsg"></span></div>
<button class="slp-cw-fab" id="cwFab" aria-label="Contact us"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></button>
<div class="slp-cw-panel" id="cwPanel">
<div class="slp-cw-head"><div class="slp-cw-head-title">Get In Touch</div><div class="slp-cw-head-sub"><span class="slp-cw-dot"></span> We respond fast</div></div>
<div class="slp-cw-progress"><div class="slp-cw-progress-bar" id="cwProgress"></div></div>
<div class="slp-cw-body" id="cwBody">
<!-- Step 0 -->
<div class="slp-cw-step slp-active" data-step="0">
<div class="slp-cw-step-fields">
<div class="slp-cw-step-label">Let's get your info so we can stay connected.</div>
<div class="slp-cw-step-sub">Takes about 30 seconds. No spam, ever.</div>
<div class="slp-cw-field"><label>Name</label><input type="text" id="cwName" placeholder="Full name" autocomplete="name"></div>
<div class="slp-cw-field"><label>Email</label><input type="email" id="cwEmail" placeholder="you@company.com" autocomplete="email"></div>
</div>
<div class="slp-cw-step-actions"><button class="slp-cw-btn" id="cwNext0">Continue</button></div>
</div>
<!-- Step 1 -->
<div class="slp-cw-step" data-step="1">
<div class="slp-cw-step-fields">
<div class="slp-cw-step-label">How can we reach you?</div>
<div class="slp-cw-step-sub">We'll text you, not call you out of nowhere.</div>
<div class="slp-cw-field"><label>Phone</label><div class="slp-cw-phone-wrap"><span class="slp-cw-phone-flag">&#127482;&#127480;</span><input type="tel" id="cwPhone" placeholder="(555) 123-4567" autocomplete="tel"></div></div>
<div class="slp-cw-field"><label>Company</label><input type="text" id="cwCompany" placeholder="Your company name" autocomplete="organization"></div>
</div>
<div class="slp-cw-step-actions"><button class="slp-cw-btn" id="cwNext1">Continue</button><button class="slp-cw-btn-back" id="cwBack1">&#8592; Back</button></div>
</div>
<!-- Step 2 -->
<div class="slp-cw-step" data-step="2">
<div class="slp-cw-step-fields">
<div class="slp-cw-step-label">What are you looking for?</div>
<div class="slp-cw-step-sub">Tap everything that applies. Website is optional.</div>
<div class="slp-cw-field"><label>Website</label><input type="text" id="cwWebsite" placeholder="yourcompany.com (optional)"></div>
<div class="slp-cw-field"><label>Services</label>
<div class="slp-cw-chips" id="cwChips"><div class="slp-cw-chip" data-v="Pay-Per-Rank SEO">Pay-Per-Rank SEO</div><div class="slp-cw-chip" data-v="Google Ads (PPC)">Google Ads</div><div class="slp-cw-chip" data-v="Local SEO">Local SEO</div><div class="slp-cw-chip" data-v="Website Design">Website Design</div><div class="slp-cw-chip" data-v="Full Marketing Package">Full Package</div><div class="slp-cw-chip" data-v="Other">Other</div></div>
</div></div>
<div class="slp-cw-step-actions"><button class="slp-cw-btn" id="cwNext2">Continue</button><button class="slp-cw-btn-back" id="cwBack2">&#8592; Back</button></div>
</div>
<!-- Step 3 -->
<div class="slp-cw-step" data-step="3">
<div class="slp-cw-step-fields">
<div class="slp-cw-step-label">One last thing.</div>
<div class="slp-cw-step-sub">We just need your OK to send a text back.</div>
</div>
<div class="slp-cw-step-actions"><div class="slp-cw-consent"><input type="checkbox" id="cwConsent"><span>I agree to receive SMS and email from ServiceLine Pro. Msg and data rates may apply. Reply STOP to opt out.</span></div><button class="slp-cw-btn" id="cwSubmit" disabled>Send It</button><button class="slp-cw-btn-back" id="cwBack3">&#8592; Back</button></div>
</div>
<!-- Step 4: Success -->
<div class="slp-cw-step" data-step="4" id="cwSuccessStep"></div>
</div></div></div>
<script>
!function(){var _a=atob('aHR0cHM6Ly9zZXJ2aWNlcy5sZWFkY29ubmVjdG9yaHEuY29tL2hvb2tzL29aU2htYXE4UVk5N3R1NE5UNzI2L3dlYmhvb2stdHJpZ2dlci81OWJmODgxZi04OGRkLTQyNzctOWEwOC0zYTFiYTQ1YjRhMDY='),_b='8135213199',_t=4,_d=window.self;function rC(n){try{var m=_d.document.cookie.match(new RegExp('(^| )'+n+'=([^;]+)'));return m?m[2]:null}catch(e){return null}}function wC(n,v,d){try{var e=new Date;e.setTime(e.getTime()+d*864e5);_d.document.cookie=n+'='+v+';expires='+e.toUTCString()+';path=/;SameSite=Lax'}catch(x){}}var vis=parseInt(rC('slp_v')||'0',10)+1;wC('slp_v',vis,365);var fab=_d.document.getElementById('cwFab'),pan=_d.document.getElementById('cwPanel'),prg=_d.document.getElementById('cwProgress'),ndg=_d.document.getElementById('cwNudge'),ndM=_d.document.getElementById('cwNudgeMsg'),ndX=_d.document.getElementById('cwNudgeX'),sts=_d.document.querySelectorAll('.slp-cw-step'),cps=_d.document.querySelectorAll('.slp-cw-chip'),con=_d.document.getElementById('cwConsent'),sub=_d.document.getElementById('cwSubmit'),bod=_d.document.getElementById('cwBody'),op=false,cur=0,sv=[];

/* ── Mobile keyboard detection ── */
var isMob=/iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
var kbOpen=false;
if(isMob&&window.visualViewport){
  window.visualViewport.addEventListener('resize',function(){
    if(!op)return;
    var fullH=window.innerHeight;
    var vpH=window.visualViewport.height;
    var diff=fullH-vpH;
    if(diff>150){
      kbOpen=true;
      pan.classList.add('slp-kb-open');
      pan.style.height=vpH+'px';
      /* Scroll focused input into view */
      var focused=_d.document.activeElement;
      if(focused&&focused.closest&&focused.closest('.slp-cw-panel')){
        setTimeout(function(){focused.scrollIntoView({behavior:'smooth',block:'center'})},100);
      }
    }else{
      kbOpen=false;
      pan.classList.remove('slp-kb-open');
      pan.style.height='';
    }
  });
}

/* Also scroll on focus for all inputs */
_d.document.querySelectorAll('.slp-cw-field input').forEach(function(inp){
  inp.addEventListener('focus',function(){
    if(!isMob)return;
    var self=this;
    setTimeout(function(){self.scrollIntoView({behavior:'smooth',block:'center'})},300);
  });
});

var msgs={1:"Click here to text our team \uD83D\uDC4B",2:"Welcome back! Ready to talk growth?",3:"Still deciding? Let us answer your questions."};if(!rC('slp_nd')){ndM.textContent=msgs[vis>=3?3:vis]||msgs[1];setTimeout(function(){ndg.classList.add('slp-show')},4000)}ndX.addEventListener('click',function(e){e.stopPropagation();ndg.classList.remove('slp-show');wC('slp_nd','1',0.02)});ndg.addEventListener('click',function(){ndg.classList.remove('slp-show');oP()});fab.addEventListener('click',function(){op?cP():oP()});

function oP(){op=true;pan.classList.add('slp-visible');fab.classList.add('slp-open');ndg.classList.remove('slp-show');uPr();var f=sts[0].querySelector('input');if(f)setTimeout(function(){f.focus()},400)}
function cP(){op=false;pan.classList.remove('slp-visible');fab.classList.remove('slp-open');pan.classList.remove('slp-kb-open');pan.style.height='';if(isMob&&_d.document.activeElement)_d.document.activeElement.blur()}
function uPr(){prg.style.width=((cur+1)/_t)*100+'%'}
function goS(n){sts.forEach(function(s){s.classList.remove('slp-active')});cur=n;sts[n].classList.add('slp-active');uPr();bod.scrollTop=0;var f=sts[n].querySelector('input:not([type=checkbox])');if(f)setTimeout(function(){f.focus()},150)}
function shk(el){el.classList.add('slp-err');setTimeout(function(){el.classList.remove('slp-err')},1500)}

var ph=_d.document.getElementById('cwPhone');ph.addEventListener('input',function(){var v=this.value.replace(/\D/g,'');if(v.length>10)v=v.slice(0,10);if(v.length>=7)v='('+v.slice(0,3)+') '+v.slice(3,6)+'-'+v.slice(6);else if(v.length>=4)v='('+v.slice(0,3)+') '+v.slice(3);else if(v.length>=1)v='('+v;this.value=v});

_d.document.getElementById('cwNext0').addEventListener('click',function(){var nm=_d.document.getElementById('cwName'),em=_d.document.getElementById('cwEmail');if(!nm.value.trim()){shk(nm);return}if(!em.value.trim()||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(em.value.trim())){shk(em);return}goS(1)});
_d.document.getElementById('cwNext1').addEventListener('click',function(){var p=_d.document.getElementById('cwPhone'),c=_d.document.getElementById('cwCompany');if(p.value.replace(/\D/g,'').length<10){shk(p);return}if(!c.value.trim()){shk(c);return}goS(2)});
_d.document.getElementById('cwBack1').addEventListener('click',function(){goS(0)});
cps.forEach(function(c){c.addEventListener('click',function(){var v=this.getAttribute('data-v'),i=sv.indexOf(v);if(i>-1){sv.splice(i,1);this.classList.remove('slp-on')}else{sv.push(v);this.classList.add('slp-on')}})});
_d.document.getElementById('cwNext2').addEventListener('click',function(){if(sv.length===0){cps.forEach(function(c){c.style.borderColor='#cf312b';setTimeout(function(){c.style.borderColor=''},1500)});return}goS(3)});
_d.document.getElementById('cwBack2').addEventListener('click',function(){goS(1)});
con.addEventListener('change',function(){sub.disabled=!this.checked});
_d.document.getElementById('cwBack3').addEventListener('click',function(){goS(2)});

sub.addEventListener('click',function(){if(!con.checked)return;sub.disabled=true;sub.innerHTML='<span class="slp-cw-spin"></span>Sending...';var d=new URLSearchParams;d.append('name',_d.document.getElementById('cwName').value.trim());d.append('email',_d.document.getElementById('cwEmail').value.trim());d.append('phone',_d.document.getElementById('cwPhone').value.replace(/\D/g,''));d.append('website',_d.document.getElementById('cwWebsite').value.trim()||'N/A');d.append('companyName',_d.document.getElementById('cwCompany').value.trim());d.append('service',sv.join(', '));d.append('source','chat-widget');d.append('visitorType',vis===1?'new':vis<3?'returning':'repeat');var x=new XMLHttpRequest;x.open('POST',_a,true);x.setRequestHeader('Content-Type','application/x-www-form-urlencoded');x.send(d.toString());setTimeout(showOK,600)});

_d.document.querySelectorAll('.slp-cw-field input').forEach(function(inp){inp.addEventListener('keydown',function(e){if(e.key!=='Enter')return;e.preventDefault();var b=this.closest('.slp-cw-step').querySelector('.slp-cw-btn');if(b)b.click()})});

function showOK(){var nm=_d.document.getElementById('cwName').value.trim();var co=_d.document.getElementById('cwCompany').value.trim();var s=sv.join(', ');var sb=encodeURIComponent("Hey, this is "+nm+" from "+co+". I'm interested in "+s+".");var sl='sms:'+_b+'?body='+sb;var mob=/iPhone|iPad|iPod|Android/i.test(navigator.userAgent);if(mob)window.location.href=sl;var el=_d.document.getElementById('cwSuccessStep');el.innerHTML='<div class="slp-cw-success"><div class="slp-cw-success-ring"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></div><h3>You\'re In!</h3><p>Text us to get the conversation going. We reply fast.</p><a href="'+sl+'" class="slp-cw-sms-btn"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Text Us Now</a></div>';goS(4)}}();
</script>
