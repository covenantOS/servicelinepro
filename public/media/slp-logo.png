.slp-cw *,.slp-cw *::before,.slp-cw *::after{box-sizing:border-box;margin:0;padding:0}.slp-cw{font-family:'DM Sans',-apple-system,BlinkMacSystemFont,sans-serif}
.slp-cw-fab{position:fixed;bottom:24px;right:24px;z-index:99998;width:60px;height:60px;border-radius:50%;background:#cf312b;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(207,49,43,.45);transition:all .3s cubic-bezier(.34,1.56,.64,1);animation:slpcwP 2s 3s ease-in-out 3}.slp-cw-fab:hover{transform:scale(1.08);box-shadow:0 6px 28px rgba(207,49,43,.55)}.slp-cw-fab svg{width:26px;height:26px;fill:#fff;transition:transform .3s ease}.slp-cw-fab.slp-open svg{transform:rotate(45deg)}.slp-cw-fab.slp-open{background:#25221c;animation:none}@keyframes slpcwP{0%,100%{box-shadow:0 4px 20px rgba(207,49,43,.45)}50%{box-shadow:0 4px 20px rgba(207,49,43,.45),0 0 0 12px rgba(207,49,43,.12)}}
.slp-cw-nudge{position:fixed;bottom:92px;right:24px;z-index:99997;background:#fff;color:#1a1a1a;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;padding:12px 18px;border-radius:16px 16px 4px 16px;box-shadow:0 4px 24px rgba(0,0,0,.12);max-width:230px;line-height:1.45;opacity:0;transform:translateY(8px) scale(.95);pointer-events:none;transition:all .35s cubic-bezier(.34,1.56,.64,1)}.slp-cw-nudge.slp-show{opacity:1;transform:translateY(0) scale(1);pointer-events:auto}.slp-cw-nudge-x{position:absolute;top:-8px;right:-8px;width:22px;height:22px;background:#e5e7eb;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:11px;color:#6b7280;transition:background .15s}.slp-cw-nudge-x:hover{background:#d1d5db}
.slp-cw-panel{position:fixed;bottom:96px;right:24px;z-index:99999;width:380px;border-radius:20px;background:#fff;box-shadow:0 12px 48px rgba(0,0,0,.18),0 2px 8px rgba(0,0,0,.08);display:flex;flex-direction:column;opacity:0;transform:translateY(16px) scale(.96);pointer-events:none;transition:opacity .35s cubic-bezier(.34,1.56,.64,1),transform .35s cubic-bezier(.34,1.56,.64,1);overflow:hidden;max-height:520px}.slp-cw-panel.slp-visible{opacity:1;transform:translateY(0) scale(1);pointer-events:auto}
.slp-cw-head{background:#25221c;padding:20px 24px;flex-shrink:0}.slp-cw-head-title{font-size:17px;font-weight:700;color:#fff;margin-bottom:3px}.slp-cw-head-sub{font-size:12.5px;color:rgba(255,255,255,.55);display:flex;align-items:center;gap:6px}.slp-cw-dot{width:7px;height:7px;border-radius:50%;background:#22c55e}
.slp-cw-progress{height:3px;background:#f0f0f0;flex-shrink:0}.slp-cw-progress-bar{height:100%;background:#cf312b;border-radius:0 2px 2px 0;transition:width .4s cubic-bezier(.22,1,.36,1);width:0%}
.slp-cw-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain}
.slp-cw-step{display:none}.slp-cw-step.slp-active{display:flex;flex-direction:column;min-height:100%;animation:slpcwS .35s ease}@keyframes slpcwS{from{opacity:0;transform:translateX(12px)}to{opacity:1;transform:translateX(0)}}
.slp-cw-step-fields{padding:24px 24px 0;flex:1}
.slp-cw-step-actions{padding:8px 24px 20px;flex-shrink:0;position:sticky;bottom:0;background:#fff;z-index:2}
.slp-cw-step-label{font-size:15.5px;font-weight:600;color:#1a1a1a;margin-bottom:4px;line-height:1.4}.slp-cw-step-sub{font-size:13px;color:#6b7280;margin-bottom:18px;line-height:1.45}
.slp-cw-field{margin-bottom:14px}.slp-cw-field label{display:block;font-size:12px;font-weight:600;color:#6b7280;margin-bottom:5px;text-transform:uppercase;letter-spacing:.04em}.slp-cw-field input{width:100%;height:46px;padding:0 14px;font-family:'DM Sans',sans-serif;font-size:16px;font-weight:500;color:#1a1a1a;background:#f9fafb;border:1.5px solid #e5e7eb;border-radius:10px;outline:none;transition:all .2s}.slp-cw-field input::placeholder{color:#9ca3af;font-weight:400}.slp-cw-field input:focus{border-color:#cf312b;background:#fff;box-shadow:0 0 0 3px rgba(207,49,43,.08)}.slp-cw-field input.slp-err{border-color:#cf312b;background:#fef2f2}
.slp-cw-phone-wrap{position:relative}.slp-cw-phone-flag{position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:16px;pointer-events:none}.slp-cw-phone-wrap input{padding-left:38px}
.slp-cw-chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:2px}.slp-cw-chip{padding:9px 16px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;background:#f9fafb;border:1.5px solid #e5e7eb;border-radius:24px;cursor:pointer;transition:all .2s;color:#374151;user-select:none}.slp-cw-chip:hover{border-color:#cf312b;background:#fef2f2}.slp-cw-chip.slp-on{background:#cf312b;color:#fff;border-color:#cf312b}
.slp-cw-btn{width:100%;height:48px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;color:#fff;background:#cf312b;border:none;border-radius:50px;cursor:pointer;transition:all .25s;letter-spacing:.01em}.slp-cw-btn:hover{background:#b82925;transform:translateY(-1px);box-shadow:0 4px 16px rgba(207,49,43,.3)}.slp-cw-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
.slp-cw-btn-back{background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;color:#9ca3af;padding:8px 0;transition:color .2s;display:block;margin:4px auto 0;text-align:center}.slp-cw-btn-back:hover{color:#6b7280}
.slp-cw-consent{display:flex;align-items:flex-start;gap:8px;margin:0 0 8px}.slp-cw-consent input[type="checkbox"]{width:16px;height:16px;margin-top:1px;accent-color:#cf312b;cursor:pointer;flex-shrink:0}.slp-cw-consent span{font-size:11.5px;color:#6b7280;line-height:1.4;cursor:pointer}
.slp-cw-spin{display:inline-block;width:18px;height:18px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:slpcwSp .6s linear infinite;vertical-align:middle;margin-right:6px}@keyframes slpcwSp{to{transform:rotate(360deg)}}
.slp-cw-success{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:36px 24px;text-align:center;min-height:300px}.slp-cw-success-ring{width:68px;height:68px;background:#cf312b;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:20px;box-shadow:0 4px 16px rgba(207,49,43,.35);animation:slpcwPop .5s cubic-bezier(.34,1.56,.64,1)}@keyframes slpcwPop{0%{transform:scale(0)}100%{transform:scale(1)}}.slp-cw-success-ring svg{width:28px;height:28px;stroke:#fff;stroke-width:3;fill:none;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:32;stroke-dashoffset:32;animation:slpcwDr .35s .4s ease forwards}@keyframes slpcwDr{to{stroke-dashoffset:0}}.slp-cw-success h3{font-family:'DM Sans',sans-serif;font-size:20px;font-weight:700;color:#1a1a1a;margin-bottom:8px;opacity:0;animation:slpcwUp .35s .55s ease forwards}.slp-cw-success p{font-family:'DM Sans',sans-serif;font-size:14px;color:#6b7280;line-height:1.5;margin-bottom:22px;max-width:280px;opacity:0;animation:slpcwUp .35s .7s ease forwards}@keyframes slpcwUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}.slp-cw-sms-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#cf312b;color:#fff;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;border-radius:50px;text-decoration:none;transition:all .25s;box-shadow:0 4px 16px rgba(207,49,43,.3);opacity:0;animation:slpcwUp .35s .85s ease forwards}.slp-cw-sms-btn:hover{background:#b82925;transform:translateY(-1px)}.slp-cw-sms-btn svg{width:18px;height:18px;fill:#fff}
@media(max-width:440px){
.slp-cw-panel{right:0;left:0;bottom:0;width:100%;max-height:100dvh;max-height:100vh;border-radius:20px 20px 0 0;transition:opacity .25s ease,transform .25s ease,max-height .2s ease}
.slp-cw-panel.slp-kb-open{max-height:100dvh;max-height:100vh;bottom:0;border-radius:0}
.slp-cw-fab{bottom:16px;right:16px}
.slp-cw-nudge{bottom:84px;right:16px}
.slp-cw-body{max-height:none;flex:1}
.slp-cw-step-actions{position:sticky;bottom:0;padding-bottom:max(20px,env(safe-area-inset-bottom))}
